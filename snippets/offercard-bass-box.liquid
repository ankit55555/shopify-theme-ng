  <div id="pincode-container">
  <iframe id="pincode-frame" src="https://help.ngearsafe.com/pincode/" loading="lazy" style="margin-top:10px; border: none; overflow: hidden;height:130px;border-radius: 12px;" onload="adjustIframeHeight()"></iframe>
</div> 

<style>
  #pincode-frame{width:61%;} 
  @media only screen and (max-width:768px){
    #pincode-frame{width:100%;}
.banner-container {max-width: 100%;}
  }

</style>

<script>
  function adjustIframeHeight() {
    const iframe = document.getElementById("pincode-frame");

    iframe.contentWindow.postMessage("getHeight", "*");

    window.addEventListener("message", function (event) {
      if (event.data.height) {
        iframe.style.height = event.data.height + "px";
      }
    });
  }
</script>

  <script>
        // Hide pincode container for UK domain
document.addEventListener("DOMContentLoaded", function() {
    // Check if current domain is UK
    if (window.location.hostname === 'ngearsafe.co.uk') {
        
        // Multiple possible selectors for pincode elements
        const selectors = [
            '.pincode-container',
            '#pincode-container', 
            '.pincode-check',
            '.delivery-pincode',
            '[data-pincode]',
            '[class*="pincode"]',
          '.banner-container',
            '[id*="pincode"]'
        ];
        
        selectors.forEach(selector => {
            const elements = document.querySelectorAll(selector);
            elements.forEach(element => {
                element.style.display = 'none';
            });
        });
        
        // Also hide parent containers that might only contain pincode
        const pincodeParents = document.querySelectorAll('.delivery-info, .shipping-info');
        pincodeParents.forEach(parent => {
            const hasPincodeChild = parent.querySelector('[class*="pincode"], [id*="pincode"]');
            if (hasPincodeChild) {
                parent.style.display = 'none';
            }
        });
    }
});
    </script>

