

<style>
/* Blog Article Beautification CSS with Specific Classes */

article img{width:100%;}

  .t4s-article-title {
    display: block;
    max-width: 832px;
    margin: 50px auto;
    justify-content: center;
    align-items: flex-start;
    position: relative;
    padding: 0px 24px;
}

   .t4s-article-content.t4s-rte {
    max-width: 832px;
    margin: 0px auto;
    justify-content: center;
    align-items: flex-start;
    position: relative;
    padding: 0px 24px;
}

   .t4s-article-related {
    display: block;
    max-width: 832px;
    margin: 0px auto;
    justify-content: center;
    align-items: flex-start;
    position: relative;
    padding: 0px 24px;
}

  .t4s-main-article-page>div:not(:last-child) {
    margin-bottom: 30px;
}

/* Article Title */
.t4s-article-title h1 {
  font-size: 2.5em !important;
  color: #222 !important;
  margin-bottom: 20px !important;
  font-weight: 700 !important;
  text-transform: capitalize !important;
}

.t4s-article-title ul {
  text-align: center !important;
  padding: 0 !important;
}

.t4s-article-title ul li span {
  font-size: 1em !important;
  color: #555 !important;
  display: inline-block !important;
  margin-top: 10px !important;
}

