    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const slider = document.getElementById('mediaSlider');
            const sliderWrapper = document.getElementById('mediaSliderWrapper');
            const prevBtn = document.getElementById('prevBtn');
            const nextBtn = document.getElementById('nextBtn');
            
            // Mouse drag functionality
            let isDown = false;
            let startX;
            let scrollLeft;

            sliderWrapper.addEventListener('mousedown', (e) => {
                isDown = true;
                sliderWrapper.classList.add('active');
                startX = e.pageX - sliderWrapper.offsetLeft;
                scrollLeft = sliderWrapper.scrollLeft;
            });

            sliderWrapper.addEventListener('mouseleave', () => {
                isDown = false;
                sliderWrapper.classList.remove('active');
            });

            sliderWrapper.addEventListener('mouseup', () => {
                isDown = false;
                sliderWrapper.classList.remove('active');
            });

            sliderWrapper.addEventListener('mousemove', (e) => {
                if(!isDown) return;
                e.preventDefault();
                const x = e.pageX - sliderWrapper.offsetLeft;
                const walk = (x - startX) * 2;
                sliderWrapper.scrollLeft = scrollLeft - walk;
            });

            // Mouse wheel scrolling
            sliderWrapper.addEventListener('wheel', (e) => {
                e.preventDefault();
                sliderWrapper.scrollLeft += e.deltaY;
            });

            // Navigation buttons
            const cardWidth = slider.querySelector('.media-card').offsetWidth + 20;

            nextBtn.addEventListener('click', () => {
                sliderWrapper.scrollLeft += cardWidth;
            });

            prevBtn.addEventListener('click', () => {
                sliderWrapper.scrollLeft -= cardWidth;
            });

            // Auto-scrolling
            let autoScrollInterval;
            const startAutoScroll = () => {
                autoScrollInterval = setInterval(() => {
                    if (sliderWrapper.scrollLeft + sliderWrapper.clientWidth >= slider.scrollWidth) {
                        sliderWrapper.scrollLeft = 0;
                    } else {
                        sliderWrapper.scrollLeft += cardWidth;
                    }
                }, 5000);
            };

            const stopAutoScroll = () => {
                clearInterval(autoScrollInterval);
            };

            startAutoScroll();

            sliderWrapper.addEventListener('mouseenter', stopAutoScroll);
            sliderWrapper.addEventListener('mouseleave', startAutoScroll);
        });
    </script>