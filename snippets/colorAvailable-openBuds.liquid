    <div class="container_compare">
        <div class="mask-container_compare">
            <div class="mask-image-container_compare">
            </div>
        </div>
        <div class="border_compare"></div>
        <!-- <div class="circle_compare"></div> -->
      <div class="circle_compare" style="left: 675px;">

      <i class="las la-chevron-left"></i>
      <i class="las la-chevron-right"></i>
</div>
    </div>

    <script>
        const container = document.querySelector(".container_compare");
        const maskContainer = document.querySelector(".mask-container_compare");
        const border = document.querySelector(".border_compare");
        const circle = document.querySelector(".circle_compare");
        
        let isDragging = false;
        let startX;
        let circleLeft;

        function updatePositions(pageX) {
            const containerRect = container.getBoundingClientRect();
            let newLeft = Math.max(0, Math.min(containerRect.width, pageX - containerRect.left));
            
            maskContainer.style.width = `${newLeft}px`;
            border.style.left = `${newLeft}px`;
            circle.style.left = `${newLeft}px`;
        }

        // Mouse Events
        circle.addEventListener('mousedown', (e) => {
            isDragging = true;
            startX = e.pageX - circle.offsetLeft;
            container.style.cursor = 'ew-resize';
        });

        document.addEventListener('mousemove', (e) => {
            if (!isDragging) return;
            e.preventDefault();
            updatePositions(e.pageX - startX);
        });

        document.addEventListener('mouseup', () => {
            isDragging = false;
            container.style.cursor = 'default';
        });

        // Touch Events
        circle.addEventListener('touchstart', (e) => {
            isDragging = true;
            startX = e.touches[0].pageX - circle.offsetLeft;
            e.preventDefault(); // Prevent scrolling while dragging
        });

        document.addEventListener('touchmove', (e) => {
            if (!isDragging) return;
            e.preventDefault();
            updatePositions(e.touches[0].pageX - startX);
        });

        document.addEventListener('touchend', () => {
            isDragging = false;
        });

        // Initialize position
        updatePositions(window.innerWidth / 2);
    </script>