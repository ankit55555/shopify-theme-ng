    <style>
        .container_compare {
            position: relative;
            width: 100%;
            height: 100vh;
            background-image: url(https://cdn.shopify.com/s/files/1/0804/5762/9975/files/Ivory_Buds_Color_available_banners_copy.svg?v=1739536937);
            background-position: center center;
            background-size: cover;
            overflow: hidden;
            /* touch-action: none;  */
 touch-action: pan-y; /* Allow vertical scrolling */
        }
        .mask-container_compare {
            position: absolute;
            top: 0;
            left: 0;
            height: 100%;
            width: 50%;
            overflow: hidden;
            transition: width 0.05s ease-out;
        }
        .mask-image-container_compare {
            position: absolute;
            top: 0;
            left: 0;
            height: 100vh;
            width: 100vw;
            background-image: url(https://cdn.shopify.com/s/files/1/0804/5762/9975/files/Black_Buds_Color_available_bannerscopy.svg?v=1740988001);
            background-position: center center;
            background-size: cover;
        }
        .border_compare {
            position: absolute;
            width: 4px;
            height: 100vh;
            left: 50%;
            margin-left: -2px;
            /* background-color: rgba(0,0,0,0.4); */
            transition: left 0.05s ease-out;
        }
        .circle_compare {
            position: absolute;
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: steelblue;
            top: 50%;
            margin-top: -25px;
            left: 50%;
            margin-left: -25px;
            opacity: 0.9;
            cursor: ew-resize;
            transition: left 0.05s ease-out;
            touch-action: none;

          width: 50px;
    height: 50px;
