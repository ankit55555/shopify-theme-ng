.product-content{display:grid;grid-template-columns:auto 1fr;gap:30px;align-items:center}
.product-image{background:linear-gradient(135deg,#f6f8f9 0,#e5ebee 100%);border-radius:20px;display:flex;justify-content:center;align-items:center;transition:transform .3s ease}
.product-image:hover{transform:translateY(-5px)}
.product-image img{width:150px;height:150px;background-color:#ccc;border-radius:10px}
.product-details{display:grid;gap:15px}
.price-section{display:flex;align-items:center;padding:10px 15px;border-radius:8px;justify-content:center}
.original-price{text-decoration:line-through;color:#999;font-size:16px;margin-right:15px}
.discounted-price{color:#e74c3c;font-size:24px;font-weight:700}
.action-buttons{display:grid;grid-template-columns:auto;gap:15px;margin:0 auto;width:80%}
.btn{text-align: center;padding:12px 25px;border:none;border-radius:8px;font-weight:600;cursor:pointer;transition:all .3s ease}
.btn-primary{border:2px solid #222;border-radius:25px;background-color:#222;color:#fff}
.btn-secondary{background-color:transparent;color:#2c3e50;border:0 solid #2c3e50}
.btn:hover{transform:translateY(-3px);box-shadow:0 4px 17px rgba(0,0,0,.15)}
.btn-primary:hover{background-color:#243747}
.product-description{color:#666;font-size:15px;line-height:1.5;text-align:center}
.features{display:grid;grid-template-columns:repeat(3,1fr);gap:15px;margin-top:20px}
.feature{text-align:center;padding:15px;border-radius:10px;transition:transform .3s ease}
.feature:hover{transform:scale(1.05);box-shadow:0 5px 15px rgba(0,0,0,.06)}
.feature img{width:40px;margin-bottom:10px}
.feature p:first-of-type{font-size:16px;font-weight:600;color:#2c3e50;margin-bottom:5px}
.feature p{font-size:14px;color:#666;margin-top:5px}
.images-section{display:grid;gap:20px}
.main-image{width:100%;border-radius:15px;overflow:hidden;box-shadow:0 10px 30px rgba(0,0,0,.1);margin-bottom:0;transition:all .3s ease}
.main-image:hover{transform:translateY(-5px);box-shadow:0 15px 35px rgba(0,0,0,.12)}
.main-image img{width:100%;height:100%;display:block}
.sub-images{display:grid;grid-template-columns:1fr 1fr;gap:20px}
.sub-images div{border-radius:10px;overflow:hidden;box-shadow:0 5px 15px rgba(0,0,0,.08);transition:all .3s ease}
.sub-images div:hover{transform:translateY(-5px);box-shadow:0 10px 20px rgba(0,0,0,.1)}
.sub-images img{width:100%;height:100%;display:block}
.carousel-container{max-width:1200px;margin:0 auto 30px;position:relative;padding:0;overflow:hidden;border-radius:12px;box-shadow:0 5px 15px rgba(0,0,0,.08)}
.carousel-track{display:flex;transition:transform .5s ease;width:500%}
.carousel-slide{width:20%;flex:0 0 auto}
.carousel-controls{display:flex;justify-content:center;margin-top:15px;gap:15px}
.carousel-arrow{color:#000;position:absolute;top:50%;transform:translateY(-50%);width:40px;height:40px;background-color:rgba(255,255,255,.8);border-radius:50%;display:flex;justify-content:center;align-items:center;font-size:18px;font-weight:700;cursor:pointer;border:none;box-shadow:0 2px 10px rgba(0,0,0,.1);z-index:10;transition:all .3s ease}
.carousel-arrow:hover{background-color:#fff;box-shadow:0 4px 15px rgba(0,0,0,.15)}
.prev-arrow{left:15px}
.next-arrow{right:15px}
