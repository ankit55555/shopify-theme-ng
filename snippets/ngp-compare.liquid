.select-box:after{content:'';border-left:6px solid transparent;border-right:6px solid transparent;border-top:6px solid #666;pointer-events:none}
.select-options{position:absolute;top:100%;left:0;width:100%;background:#fff;border-radius:0 0 8px 8px;box-shadow:0 5px 10px rgba(0,0,0,.1);z-index:10;display:none;max-height:300px;overflow-y:auto}
