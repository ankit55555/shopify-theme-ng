.compare-btn{margin-top:20px;background-color:#1a2233;color:#fff;border:none;border-radius:25px;padding:12px 40px;font-weight:600;text-transform:uppercase;letter-spacing:1px;cursor:pointer;transition:background-color .3s}
.compare-btn:hover{background-color:#2a334d}
.comparison-table{margin-top:40px;width:100%;display:none;border-collapse:collapse;box-shadow:0 0 20px rgba(0,0,0,.1);border-radius:10px;overflow:hidden}
