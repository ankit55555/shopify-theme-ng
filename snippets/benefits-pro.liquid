<script src='https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js'></script>

<script>
  var $jque = jQuery.noConflict();
  $jque(window).scroll(function() {
 $jque(".animation .anm_mod").each(function() {
  const position = $jque(this).offset().top;
  const scroll = $jque(window).scrollTop();
  const windowHeight = $jque(window).height();
  if (scroll > position - windowHeight) {
   $jque(this).addClass("active");
  }
  if (scroll < 100) {
   $jque(this).removeClass("active");
  }
 });
});

$jque(function() {
 $jque('a[href^="#"]').click(function() {
  const speed = 800;
  const href = $jque(this).attr("href");
  const target = $jque(href == "#" || href == "" ? "html" : href);
  const position = target.offset().top;
 $jque("html, body").animate({ scrollTop: position }, speed, "swing");
  return false;
 });
});

</script>






