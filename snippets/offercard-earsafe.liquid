<style>
  .buttons-container-m{display:flex;flex-wrap:wrap;gap:0;margin:0;padding:0;margin-bottom:15px;}
.buy-button-wrapper-m{position:relative;width:auto;margin:0;margin-right:10px}
.buy-text-m{position:absolute;top:-6px;left:14px;background-color:#fff;padding:0 5px;font-size:10px;font-weight:600;color:#333;z-index:1}
.buy-button-m{display:flex;align-items:center;justify-content:space-between;background-color:#fff;border:1px solid #ffa41c;border-radius:10px;padding:15px 20px;height:40px;width:150px;text-decoration:none;box-sizing:border-box;margin:0}
.logo-m{width:80%}
.arrow-m{color:#ffa41c;font-size:24px;}
.buy-button-m a{border-bottom: 0px solid currentColor !important;}
</style>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const currentUrl = window.location.href;
        let amazonUrl = "";
        let flipkartUrl = "";
        let productName = "";

        const urlPath = new URL(currentUrl).pathname;

        if (urlPath === "/products/ng-earsafe-lite-open-ear-headphones") {
            amazonUrl = "https://www.amazon.in/Conduction-Headphones-Water-Resistant-sweatproof-2024/dp/B0CYLBDFZ5?ref_=automaticdeals_bs_dp&th=1&psc=1";
            flipkartUrl = "https://www.flipkart.com/ng-earsafe-lite-bluetooth/p/itmae0018a6fc6c7?pid=ACCGZSQYPVNFFFWH";
            productName = "ng-earsafe-lite";
        } else if (urlPath === "/products/ng-earsafe-openbuds-with-air-conduction-technology") {
            amazonUrl = "https://www.amazon.in/EarSafe-OpenBuds-Conduction-Immersive-Silicone/dp/B0DF342T66?ref_=automaticdeals_bs_dp&th=1&psc=1";
            flipkartUrl = "https://www.flipkart.com/ng-earsafe-openbuds-air-conduction-open-ear-buds-bluetooth/p/itm4da83b4545a92?pid=ACCH4D9FHYRKBTYW";
            productName = "ng-earsafe-openbuds";
        } else if (urlPath === "/products/earsafe-open-ear-bluetooth-headphones") {
            amazonUrl = "https://www.amazon.in/NG-EarSafe-Wireless-Bluetooth-Headphones/dp/B08C8W178M?ref_=automaticdeals_bs_dp&th=1&psc=1";
            flipkartUrl = "https://ngearsafe.com/products/earsafe-open-ear-bluetooth-headphones";
            productName = "earsafe-open-ear";
        } else if (urlPath === "/products/ng-earsafe-pro-open-ear-bone-conduction-headphones") {
            amazonUrl = "https://www.amazon.in/Conduction-Headphones-Waterproof-Bluetooth-2024/dp/B0CVXHPX37?ref_=automaticdeals_bs_dp&th=1&psc=1";
            flipkartUrl = "https://www.flipkart.com/ng-earsafe-pro-open-ear-bone-conduction-headphones-2024-model-black-bluetooth/p/itm43be93bf3c4a4?pid=ACCH4D7TQDHZYTFN";
            productName = "ng-earsafe-pro";
        } else if (urlPath === "/products/ng-earsafe-pro-mini-open-ear-bone-conduction-headphones-wireless") {
            amazonUrl = "https://www.amazon.in/Conduction-Headphones-2025-Resistant-Lightweight/dp/B0DS8HVPGV?ref_=automaticdeals_bs_dp";
            flipkartUrl = "https://www.flipkart.com/ng-pro-mini-bluetooth/p/itm1337e5d6c5568?pid=ACCH9D4GBKHY7FMQ";
            productName = "ng-earsafe-pro-mini";
        } else if (urlPath === "/products/ng-earsafe-comm-open-ear-headphones-with-noise-canceling-boom-mic") {
            amazonUrl = "https://www.amazon.in/Communication-Bluetooth-Cancelling-Adjustable-2023/dp/B0BWY68HZ8";
            flipkartUrl = "https://www.flipkart.com/ng-earsafe-comm-open-ear-communication-bluetooth-headphone-noise-cancelling/p/itm36e16e6f8d59b?pid=ACCGNZG7PBWWHKTQ";
            productName = "ng-earsafe-comm";
        } else if (urlPath === "/products/open-ear-headphones-with-mic-2-0-ng-earsafe") {
            amazonUrl = "https://www.amazon.in/Communication-Bluetooth-Cancelling-Adjustable-2023/dp/B0BWY68HZ8";
            flipkartUrl = "#";
            productName = "ng-earsafe-comm2point0";
        } else if (urlPath === "/products/ngwehear") {
            amazonUrl = "https://www.amazon.in/NG-Earsafe-Bluetooth-Note-Taking-Translation/dp/B0GY8LNDST";
            flipkartUrl = "SAFEBUDS_FLIPKART_URL_HERE";
            productName = "ng-x-wehear-safebuds";
        }

        if (!amazonUrl) {
            amazonUrl = 'https://www.amazon.in/dp/B0FQP6Q6KW';
        }
        if (!flipkartUrl || flipkartUrl === '#') {
            flipkartUrl = 'https://www.flipkart.com/ng-earplugs-waterproof-noise-reduction-25-db-swimming-sleeping-travel-ear-plug/p/itma0160f3d28f11';
        }

        if (amazonUrl) {
            document.querySelectorAll(".buyNowLink:not(.flipkartLink)").forEach(link => {
                link.href = amazonUrl;
                link.setAttribute("data-product", productName);
                link.setAttribute("data-store", "amazon");
            });
        }

        if (flipkartUrl) {
            document.querySelectorAll(".flipkartLink").forEach(link => {
                link.href = flipkartUrl;
                link.setAttribute("data-product", productName);
                link.setAttribute("data-store", "flipkart");
            });
        }
    });

    function trackBuyNowClick(store) {
        const linkElement = event.target.closest("a");
        const productName = linkElement.getAttribute("data-product");
        gtag('event', 'buy_now_click', {
            'event_category': 'Button Click',
            'event_label': productName,
            'event_store': store,
            'event_value': 1
        });
        console.log("Tracked Buy Now Click:", productName, "Store:", store);
    }
</script>

<style>
.banner-container{display:none;justify-content:space-between;align-items:center;background:linear-gradient(to right,#a8e0ff,#7fd8f8);border-radius:12px;padding:15px 20px;max-width:350px;box-shadow:0 4px 8px rgba(0,0,0,.1);font-family:Arial,sans-serif;overflow:hidden}
.banner-text{color:#333;font-size:14px;line-height:1.4;flex:1;margin-right:10px;font-weight:700;}
.flip-container{perspective:1000px;width:120px;height:40px}
.flipper{width:100%;height:100%;position:relative;transform-style:preserve-3d;animation:flip 6s infinite}
.back,.front{width:100%;height:100%;position:absolute;backface-visibility:hidden;display:flex;align-items:center;justify-content:center;border-radius:6px;font-size:22px;font-weight:700;color:#333;background:rgba(255,255,255,.2);overflow:hidden}
.back{transform:rotateY(180deg)}
.back::before,.front::before{content:'';position:absolute;top:-50%;left:-50%;width:200%;height:200%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.8),transparent);transform:rotate(30deg);animation:shimmer-sweep 3s infinite}
@keyframes shimmer-sweep{
0%{transform:translateX(-150%) rotate(30deg)}
100%{transform:translateX(150%) rotate(30deg)}
}
@keyframes flip{
0%,45%{transform:rotateY(0)}
50%,95%{transform:rotateY(180deg)}
100%{transform:rotateY(0)}
}
</style>

