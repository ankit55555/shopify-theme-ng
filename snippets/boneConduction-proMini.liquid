
    <style>

        .banner {
            position: relative;
            width: 100%;
            height: 100vh; /* Full screen height */
            background-size: cover;
            background-position: center;
            display: flex;
            align-items: center;
            justify-content: flex-end; /* Align content to the right */
            padding: 0 5%;
        }

        .banner-content {
            max-width: 40%;
            color: white;
            padding: 20px;
            border-radius: 10px;
        }

        .banner h4 {
            font-size: 4rem;
            margin-bottom: 10px;
          font-weight:700;
          color:#fff;
        }

        .banner p {
            font-size: 1.5rem;
            line-height: 1.5;
          font-weight:500;
         color: #e9e9e9;
        }

        /* Mobile styles */
        @media (max-width: 768px) {
               .banner {
        height: 100vh !important;
        padding: 0px 0px;
        justify-content: center;
        background-position: center;
        background-size: cover;
        background-repeat: no-repeat;
        display: block;
        margin: 0 auto;
    }

            .banner-content {
        max-width: 100%;
        text-align: center;
        padding: 45px 25px;
    }
          .banner h4 {
    font-size: 3rem;
    margin-bottom: 10px;
    font-weight: 700;
}
          .banner p {
    font-size: 1.4rem;
    line-height: 1.5;
    font-weight: 500;
    color: #e3e3e3;
}
        }
    </style>

    <div class="banner">
        <div class="banner-content">
            <h4>Bone Conduction Technology</h4>
            <p>
                Experience audio in a safer, more natural way with our cutting-edge Bone Conduction Technology.
                Unlike traditional headphones, NG EarSafe Pro Mini transmits sound through your cheekbones, keeping your ears open to surrounding sounds.
                Enjoy your music and calls without compromising your awareness or comfort—ideal for work, safe travel, and outdoor activities.
            </p>
        </div>
    </div>

    <script>
        function updateBackground() {
            const banner = document.querySelector(".banner");
            const desktopImg = "https://cdn.shopify.com/s/files/1/0804/5762/9975/files/Bone_conductionDescription_desktop_banner_1.webp?v=1739524804";
            const mobileImg = "https://cdn.shopify.com/s/files/1/0804/5762/9975/files/Bone_conductionDescription_mobile_banner_1.webp?v=1739524803";

            if (window.innerWidth <= 768) {
                banner.style.backgroundImage = `url('${mobileImg}')`;
            } else {
                banner.style.backgroundImage = `url('${desktopImg}')`;
            }
        }

        window.addEventListener("load", updateBackground);
        window.addEventListener("resize", updateBackground);
    </script>
