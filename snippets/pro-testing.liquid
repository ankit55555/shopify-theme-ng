<script>

const spaceHolder = document.querySelector('.space-holder');
const horizontal = document.querySelector('.horizontal');
const secondCard = document.querySelector('.second-card');

// Adjust the space-holder height dynamically
function updateSpaceHolderHeight() {
  const vw = window.innerWidth;
  const vh = window.innerHeight;
  const objectWidth = horizontal.scrollWidth; // The total width of the horizontal scroll area
  spaceHolder.style.height = `${objectWidth - vw + vh}px`;
}

window.addEventListener('resize', () => {
  updateSpaceHolderHeight();
});

// Set the height initially
updateSpaceHolderHeight();

// Horizontal scrolling based on scroll position
window.addEventListener('scroll', () => {
  const sticky = document.querySelector('.sticky');
  horizontal.style.transform = `translateX(-${sticky.offsetTop}px)`; // Move the horizontal scroll based on scroll position
});

// IntersectionObserver for revealing the second card
const observerIntro = new IntersectionObserver((entries) => {
  entries.forEach(entry => {
    if (entry.isIntersecting) {
      // When the second card enters the viewport, reveal it
      entry.target.classList.add('show-second-card');
    }
  });
}, {
  threshold: 0.1  // Trigger when 10% of the card is visible
});

observerIntro.observe(secondCard);


</script>