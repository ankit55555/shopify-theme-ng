{% comment %}
  Renders product-specific JSON-LD schema (Product + FAQPage) if custom.json_ld metafield is set.
  Falls back to generic FAQPage schema for products without a custom schema.
{% endcomment %}

{% if product.metafields.custom.json_ld != blank %}
  <script type="application/ld+json">
    {{ product.metafields.custom.json_ld | json }}
  </script>
{% else %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "If these are open ears, will people around me be able to hear the music I am listening to on my pair of NG EarSafe?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "No, since the speaker sits near your ear, only you can hear the music you are listening to. These open ear Bluetooth headphones are designed for personal listening. However, in quiet environments and at volumes above 80%, there is a chance someone sitting close to you might hear slightly."
        }
      },
      {
        "@type": "Question",
        "name": "Can I use them while working out? Are they water resistant?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, these open ear headphones are IPx4-rated water and sweat resistant, making them perfect for workouts. Whether you're using them outdoors or at the gym, their water-resistant design ensures durability."
        }
      },
      {
        "@type": "Question",
        "name": "What is the Bluetooth connection range?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "The Bluetooth 5.0 chipset in these open ear wireless headphones provides a latency-free connection for up to 10 meters, ensuring smooth performance for streaming or calls."
        }
      },
      {
        "@type": "Question",
        "name": "How can I claim my warranty in case of any issues?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You are eligible to claim a warranty within 1 year of purchase. You can mail us at support@ngearsafe.com or fill up a form at ngearsafe.com/pages/claim-warranty. Warranty covers defects related to your NG EarSafe headphones."
        }
      },
      {
        "@type": "Question",
        "name": "In how many days will my NG EarSafe Headphones be delivered?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "You can expect delivery of your open ear Bluetooth headphones within 4-5 business days once shipped. We dispatch the product a day after receiving your order."
        }
      },
      {
        "@type": "Question",
        "name": "Can I connect NG EarSafe to a laptop?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, these open earphones are compatible with phones, tablets, and laptops that have Bluetooth connectivity."
        }
      },
      {
        "@type": "Question",
        "name": "Is there a return policy?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes, we offer an easy 7-day return policy for your NG EarSafe headphones (physical and water damage not covered)."
        }
      }
    ]
  }
  </script>
{% endif %}