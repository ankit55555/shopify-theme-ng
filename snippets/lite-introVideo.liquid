.space-holder {
  position: relative;
  width: 100%;
}

.sticky {
  position: sticky;
  top: 0;
  height: 100vh;
  width: 100%;
  overflow-x: hidden;
}

.horizontal {
  position: absolute;
  height: 100%;
  will-change: transform;
  display: flex;
  flex-flow: row nowrap;
}

.cards {
  position: relative;
  height: 100%;
  display: flex;
  flex-flow: row nowrap;
  justify-content: flex-start;
  align-items: center;
}

.sample-card {
  position: relative;
  height: 100vh; /* Occupy full height */
  width: 100vw; /* Occupy full width for the first card */
  background-color: #1F1F1F;
  opacity: 1; /* Ensure it's visible by default */
  transform: scale(1); /* Ensure it's not scaled down initially */
  overflow: hidden; /* Ensure content doesn't overflow */
}

/* Remove margin-right to eliminate spacing between cards */
.sample-card + .sample-card {
  margin-left: 0; /* Remove any additional margin if added by previous cards */
}

/* Style for the video to cover the entire first card */
.desktop_intro {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  object-fit: cover; /* Ensures the video covers the whole area */
  z-index: -1; /* Places the video behind any content in the card */
}

/* Second card content styling */
.second-card {
  position: relative;
  left: 0; /* Make the second card visible from the start */
  opacity: 1; /* Ensure it's visible by default */
}

/* Image inside second card */
.image-benefit img {
  width: 50%;
  height: auto;
  display: block;
  margin: 0 auto;
}

/* Text inside second card */
