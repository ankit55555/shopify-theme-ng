    background-image: linear-gradient(-60deg, #16a085 0, #f4d03f 100%);
    top: 15px;
    left: 85px;
  }

  .card-text {
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    width: 100%;
  }

  .air-con1 {
    width: 100%;
    height: 100%;
    border-top-left-radius: 15px;
    border-bottom-left-radius: 15px;
    background-image: url("https://cdn.shopify.com/s/files/1/0804/5762/9975/files/Air_condcution_iamge_open_ear.webp?v=1761720819");
    background-position: center;
    background-size: cover;
    background-color: #1a1a1a;
    border-radius: 15px;
  }

  .bone-con1 {
    width: 100%;
    height: 100%;
    border-top-left-radius: 15px;
    border-bottom-left-radius: 15px;
    background-image: url("https://cdn.shopify.com/s/files/1/0804/5762/9975/files/Bone_condcution_iamge_open_ear.webp?v=1761720834");
    background-position: center;
    background-size: cover;
    background-color: #1a1a1a;
    border-radius: 15px;
  }

  .title-total {
    padding: 20px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .wrapper {
    padding: 30px 0;
    margin: 0;
    display: flex;
    justify-content: center;
    gap: 20px;
    flex-wrap: wrap;
  }
  .main-title.color-title{
    color: #4E5D70!important;
  }
  .description.color-title{
    color: #4E5D70 !important;
  }
  .actions a {
    letter-spacing: 1px;
    font-size: 12px;
    color: #ffffff !important;
    font-weight: 600 !important;
    background: transparent;
    border: 1px solid #d4af37;
    border-radius: 20px;
    padding: 8px 16px;
    text-decoration: none;
    display: inline-block;
    transition: all 0.3s ease;
  }

  .actions a:hover {
    background: #d4af37;
    color: #000000 !important;
  }
  .card.open-ear-card{
    background-color: #F1F2EC;
  }
</style>

