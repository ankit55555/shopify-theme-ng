<div id="open-ear-section">
  <div class="open-ear-container">
    <div class="content-wrapper">
      <div class="text-content">
        <h1 class="main-title color-title">Open Ear Technology</h1>
        <p class="description color-title">
          Open-ear technology provides a comfortable and safer alternative to in-ear headphones, eliminating the risk of
          ear infections and hearing loss from prolonged use. The open design allows for a natural sound experience
          while ensuring users remain connected to their environment.
        </p>
      </div>
      <div class="visual-content">
        <video style="" autoplay loop muted playsinline poster="https://cdn.shopify.com/s/files/1/0804/5762/9975/files/Open_Ear_main_image_light.webp?v=1761720527">
          {% comment %} <source src="https://cdn.shopify.com/videos/c/o/v/648901e609694c71bb3d8fdc263d5da3.mp4" type="video/mp4"> {% endcomment %}
          <img src="https://cdn.shopify.com/s/files/1/0804/5762/9975/files/Open_Ear_main_image_light.webp?v=1761720527" alt="Open Ear main image" loading="lazy" width="900" height="350" style="width:100%; height:100%; object-fit: cover; border-radius:10px;">
        </video>
      </div>
    </div>
  </div>

  <center>
    <div class="wrapper">
      <div class="card open-ear-card">
        <div class="card-text">
          <div class="air-con1"></div>
          <div class="title-total">
            <div class="title"></div>
            <h2 class="air-con-title">Air Conduction Technology</h2>
            <div class="actions buttons-open-ear">
              <a target="_blank" href="https://ngearsafe.com/pages/air-conduction">LEARN MORE</a>
            </div>
          </div>
        </div>
      </div>
      <div class="card open-ear-card">
        <div class="card-text">
          <div class="bone-con1"></div>
          <div class="title-total">
            <div class="title"></div>
            <h2 class="bone-con-title">Bone Conduction Technology</h2>
            <div class="actions buttons-open-ear">
              <a target="_blank" href="https://ngearsafe.com/pages/bone-conduction">LEARN MORE</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </center>
</div>

<style>
  /* Open Ear Technology Section Styles */
  #open-ear-section {
    /* background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%); */
    padding: 50px 0;
    position: relative;
    overflow: hidden;
  }
  .actions.buttons-open-ear a{
    color: #ffffff !important;
    background-color: #51bdc7;
    border: 0;
  }
  .open-ear-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .content-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 40px;
  }

  .text-content {
    width: 100%;
    max-width: 900px;
    text-align: center;
    z-index: 2;
  }
    .card-text .air-con-title{
      color: #1a1a1a !important;
    }
  .card-text .bone-con-title{
    color: #1a1a1a !important;
  }
  .main-title {
    font-size: 4rem;
    font-weight: 800;
    color: #ffffff;
    margin-bottom: 25px;
    line-height: 1.1;
    letter-spacing: -0.03em;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .description {
    font-size: 1.2rem;
    color: #e0e0e0;
    line-height: 1.7;
    max-width: 700px;
    margin: 0 auto;
    font-weight: 400;
    letter-spacing: 0.01em;
  }

  .visual-content {
    width: 100%;
    max-width: 900px;
    position: relative;
    height: 350px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
  }

  .visual-content video {
    max-width: 100%;
    max-height: 100%;
    object-fit: cover;
    border-radius: 10px;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.3);
  }

  /* Hide video controls */
  video::-webkit-media-controls {
    display: none;
  }

  /* Background Grid Pattern */
  /* #open-ear-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 50px 50px;
    opacity: 0.3;
    z-index: 1;
  } */

  /* Responsive Design */
  @media (max-width: 768px) {

    .visual-content video{
      width: 100%;
      border-radius: 0;
      box-shadow: none;
    }
    .open-ear-container {
      padding: 0;
    }
    .t4s_nt_se_{{ section.id }}{
      background-image: none !important;
    }

    .t4s_nt_se_{{ section.id }} .t4s-container{
      padding: 0;
    }

    .content-wrapper {
      gap: 30px;
    }

    .main-title {
      font-size: 2.8rem;
      font-weight: 700;
    }

    .description {
      font-size: 1.1rem;
      max-width: 100%;
    }

    .visual-content {
      {% comment %} height: 250px; {% endcomment %}
      max-width: 100%;
      opacity: 1;
      height: auto
    }

    .text-content {
      max-width: 100%;
    }
  }

  @media (max-width: 480px) {
    .main-title {
      font-size: 2.2rem;
    }

    .description {
      font-size: 1rem;
    }
  }


  .card {
    background: #2a2a2a;
    border-radius: 15px;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.3);
    max-width: 400px;
    display: inline-flex;
    flex-direction: row;
    position: relative;
    margin: 10px;
    overflow: hidden;
    border: 1px solid #3a3a3a;
  }

  .card h2 {
    margin: 0;
    padding: 0 1rem;
    font-size: 16px;
    color: #ffffff;
    font-weight: 600;
  }

  .card .title {
    padding: 1rem;
    text-align: right;
    color: green;
    font-weight: 700;
    font-size: 12px;
  }

  .card .desc {
    padding: .5rem 1rem;
    font-size: 12px;
  }

  .card .actions {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    align-items: center;
    padding: 1.5rem 1rem;
  }

  .card svg {
    width: 85px;
    height: 85px;
    margin: 0 auto;
  }

  .img-avatar {
