        "custom_liquid_Rc3fXq": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"accordion\">\n  <input type=\"checkbox\" id=\"accordion-toggle\">\n  <label class=\"accordion-label\" for=\"accordion-toggle\">Product Description</label>\n  <div class=\"accordion-content\">\n    <h6>DOMINATE NOISE. OWN YOUR SILENCE.</h6>\n    <p><span class=\"highlight\">Crush 25dB of chaos</span>—honking traffic, screeching jets, or thunderous concerts—with military-grade noise reduction. Waterproof armor (IP68) shields your ears underwater, while ultra-soft, sweat-proof design locks in blissful comfort.</p>\n    \n    <p>Sleep deeper. Focus harder. Swim freer. Your peace, unstoppable.</p>\n\n    <p><span class=\"highlight\">Features Description:</span></p>\n    <ul>\n      <li><strong>✅ 25 dB Noise Reduction –</strong> Block out loud and distracting sounds effortlessly, whether you’re working, sleeping, traveling, or relaxing.</li>\n      <li><strong>🌊 IP68 Waterproof Design –</strong> Swim without worry! Fully waterproof and reusable, perfect for bathing, swimming, or rainy commutes.</li>\n      <li><strong>👂 Ultra-Comfort Fit –</strong> Ergonomically designed to sit securely in your ear canal for long hours without discomfort.</li>\n      <li><strong>♻️ Reusable & Eco-Friendly –</strong> Durable construction makes it ideal for repeated use—great for the planet and your wallet.</li>\n      <li><strong>🧳 Multi-Use Versatility –</strong> Use it for flights, focus time, studying, concerts, and more. Comes with a carry pouch for hygiene and portability.</li>\n    </ul>\n  </div>\n</div>\n\n<style>\n.accordion {\n  width: 450px;\n  border: 1px solid #ddd;\n  border-radius: 5px;\n  overflow: hidden;\n  margin-bottom: 15px;\n}\n.accordion input {\n  display: none;\n}\n.accordion-label {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 5px 20px;\n  color: #252525;\n  cursor: pointer;\n  font-size: 15px;\n  font-weight: 600;\n  transition: background-color 0.3s ease;\n}\n.accordion-label::after {\n  content: '▼';\n  font-size: 16px;\n  transition: transform 0.3s ease;\n}\n.accordion input:checked + .accordion-label::after {\n  transform: rotate(180deg);\n}\n.accordion-content {\n  max-height: 0;\n  overflow: auto;\n  padding: 0 20px;\n  background-color: #fff;\n  color: #333;\n  font-size: 14px;\n  line-height: 1.6;\n  transition: max-height 0.4s ease, padding 0.3s ease;\n}\n.accordion input:checked ~ .accordion-content {\n  max-height: 500px;\n  padding: 15px 20px;\n}\n.accordion-content h6 {\n  margin-top: 0;\n  color: #28486e;\n}\n.accordion-content ul {\n  margin: 10px 0;\n  padding-left: 20px;\n}\n.accordion-content ul li {\n  list-style-type: disc;\n  margin-bottom: 8px;\n}\n.accordion-content p {\n  margin: 10px 0;\n}\n.accordion-content .highlight {\n  font-weight: bold;\n}\n@media only screen and (max-width: 768px) {\n  .accordion {\n    width: 100%;\n  }\n}\n</style>"
          }
        },
