    "83a135b9-30ff-430d-a7ed-dd7da7224ef0": {
      "type": "accordion",
      "blocks": {
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-1": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Can I sleep with NG EarPlugs?",
            "content": "<p>Yes! NG EarPlugs are made from ultra-soft silicone, making them ideal for <strong>side sleepers</strong> and anyone dealing with <strong>snoring partners</strong> or noisy surroundings. With up to <strong>25dB noise reduction</strong>, they help you sleep undisturbed.</p>"
          }
        },
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-2": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Are NG EarPlugs good for concerts and festivals?",
            "content": "<p>Absolutely. NG EarPlugs reduce harmful sound levels while letting you enjoy clear music. They're perfect <strong>concert earplugs</strong> for festivals, gigs, or clubs, offering both safety and comfort.</p>"
          }
        },
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-3": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Are they waterproof? Can I use them for swimming?",
            "content": "<p>Yes. NG EarPlugs are <strong>IP68 fully waterproof</strong>, making them suitable for <strong>swimming</strong>, showers, and water sports. For underwater audio, pair them with <strong>NG EarSafe Pro</strong>.</p>"
          }
        },
        "d3cd347d-e340-4be5-8075-724fb61f46c9": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Do they cancel noise completely?",
            "content": "<p>NG EarPlugs are <strong>noise reducing</strong> (not active noise cancelling). They lower noise by <strong>25dB</strong>, helping with <strong>snoring</strong>, <strong>traffic</strong>, <strong>engine sounds</strong>, and more—without fully cutting you off from the world.</p>"
          }
        },
        "c8df18a8-c3a3-47ba-a1d0-511389dc6c2b": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Are NG EarPlugs reusable?",
            "content": "<p>Yes, they’re <strong>reusable and washable</strong>. Made from durable silicone, you can clean and reuse them daily, making them a sustainable choice over foam plugs.</p>"
          }
        },
        "cb9f90a1-53a4-4f3a-bb30-97cc923f8403": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What sizes do they come in? Will they fit my ears?",
            "content": "<p>NG EarPlugs come with <strong>3 ear tip sizes</strong>, ensuring a snug, pressure-free fit for most ear canals, including <strong>small ears</strong>.</p>"
          }
        },
        "f8a2580d-f121-491c-8d46-eaa29c7acdac": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "How Will It Help In Flights?",
            "content": "<p>These are great as <strong>flight ear plugs</strong>. It reduces engine noise and helps you relax on planes, trains, and buses.</p>"
          }
        },
        "03f7bb3f-1225-459e-9f76-2ca5a55631b8": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "How do I clean NG EarPlugs?",
            "content": "<p>Wash them gently with lukewarm water and mild soap. Let them dry completely before storing them in the <strong>compact travel case</strong> provided.</p>"
          }
        },
        "63221feb-cd8f-4fb9-b052-2210cdd73abf": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Do NG EarPlugs fall out while sleeping?",
            "content": "<p>Not at all. With the right tip size, they stay secure even for <strong>side sleepers</strong>—without creating ear pressure.</p>"
          }
        },
        "ee28a4f7-8a1c-49dd-9d22-eeeef249d3cd": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Are these earplugs invisible or discreet?",
            "content": "<p>Yes. NG EarPlugs have a <strong>low-profile, invisible design</strong> that sits flush in your ear, making them perfect for use in public or during work.</p>"
          }
        }
      },
