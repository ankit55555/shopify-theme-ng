    "image_text_6wLq8M": {
      "type": "image_text",
      "blocks": {
        "bl_text_dNqGmf": {
          "type": "bl_text",
          "settings": {
            "col_dk": "12",
            "col_tb": "12",
            "text_size": "30,15",
            "txt_align": "start",
            "sub_heading": "",
            "heading": "",
            "text": "<h4><strong>Popular Searches<br/></strong></h4><p></p><p><a href=\"https://ngearsafe.com/products/ng-earsafe-comm-open-ear-headphones-with-noise-canceling-boom-mic\" target=\"_blank\" title=\"https://ngearsafe.com/products/ng-earsafe-comm-open-ear-headphones-with-noise-canceling-boom-mic\">NG EarSafe Comm Open Ear Headphones</a>‎ ‎ |‎ ‎ <a href=\"https://ngearsafe.com/products/earsafe-open-ear-bluetooth-headphones\" target=\"_blank\" title=\"https://ngearsafe.com/products/earsafe-open-ear-bluetooth-headphones\">NG EarSafe Open Ear Headphones  </a>‎ ‎ |‎ ‎ <a href=\"https://ngearsafe.com/products/ng-earsafe-lite-open-ear-headphones\" target=\"_blank\" title=\"https://ngearsafe.com/products/ng-earsafe-lite-open-ear-headphones\">NG EarSafe Lite Open Ear Headphones</a>‎ ‎ |‎ ‎ <a href=\"https://ngearsafe.com/products/ng-earsafe-pro-open-ear-bone-conduction-headphones\" target=\"_blank\" title=\"https://ngearsafe.com/products/ng-earsafe-pro-open-ear-bone-conduction-headphones\">NG EarSafe Pro Ear Headphone</a>‎ ‎ |‎ ‎ ‎<a href=\"https://ngearsafe.com/collections/open-ear-headphones\" target=\"_blank\" title=\"https://ngearsafe.com/collections/open-ear-headphones\">Open Ear Headphones  </a>‎ ‎ |‎ ‎ <a href=\"https://ngearsafe.com/products/ng-earsafe-comm-open-ear-headphones-with-noise-canceling-boom-mic\" target=\"_blank\" title=\"https://ngearsafe.com/products/ng-earsafe-comm-open-ear-headphones-with-noise-canceling-boom-mic\">Calling Headphone</a>‎ ‎ |‎ ‎ ‎<a href=\"https://help.ngearsafe.com/affiliate-collaboration\" target=\"_blank\" title=\"https://help.ngearsafe.com/affiliate-collaboration\">Affiliate Collaboration</a>‎ ‎ |‎ ‎ ‎<a href=\"https://ngearsafe.com/products/ng-earsafe-pro-open-ear-bone-conduction-headphones\" target=\"_blank\" title=\"https://ngearsafe.com/products/ng-earsafe-pro-open-ear-bone-conduction-headphones\">Bone conductor headphone<br/></a></p><h4><br/>Top Blog Search<strong><br/></strong></h4><p></p><p><a href=\"https://nge