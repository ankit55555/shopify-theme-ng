        "custom_liquid_N8y8bM": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"accordion\">\n  <input type=\"checkbox\" id=\"accordion-toggle\">\n  <label class=\"accordion-label\" for=\"accordion-toggle\">Product Description</label>\n\n  <div class=\"accordion-content\">\n    <h6>NG EarSafe Wired Open Ear Earphones: Safer, Smarter Listening</h6>\n\n    <p>\n      <strong>Product Overview</strong><br>\n      Experience safe, comfortable, and immersive audio with the NG EarSafe Wired Open Ear Earphones. \n      Designed for open–ear listening, these earphones allow you to stay aware of your surroundings while \n      enjoying music, making them ideal for outdoor use, commuting, workouts, and daily activities.\n    </p>\n\n    <p><strong>Top Highlights</strong></p>\n    <ul>\n      <li><strong>Brand:</strong> NG</li>\n      <li><strong>Colour:</strong> Black</li>\n      <li><strong>Ear Placement:</strong> Open Ear</li>\n      <li><strong>Form Factor:</strong> Wired | Ear Hook Design</li>\n      <li><strong>Impedance:</strong> 32Ω</li>\n    </ul>\n\n    <p><strong>Key Features</strong></p>\n    <ul>\n      <li>\n        <strong>Open-Ear Safety Design:</strong>\n        Enjoy music while staying fully aware of your surroundings, perfect for outdoor activities, sports, \n        commuting, and gym workouts.\n      </li>\n      <li>\n        <strong>Premium Audio Quality:</strong>\n        Equipped with 14.2mm dynamic drivers to deliver rich bass, clear vocals, and crisp treble for a superior sound experience.\n      </li>\n      <li>\n        <strong>Type-C Wired Connectivity:</strong>\n        Plug-and-play compatibility with Type-C supported Android and Apple devices, ensuring lossless audio without charging needs.\n      </li>\n      <li>\n        <strong>Feather-Light Comfort:</strong>\n        Ultra-light ergonomic build ensures long hours of listening without ear fatigue or discomfort.\n      </li>\n      <li>\n        <strong>Secure Ear-Hook Fit:</strong>\n        Flexible ear-hooks keep the earphones stable during movement, running, cycling, or workouts without falling off.\n      </li>\n    </ul>\n  </div>\n</div>\n\n<style>\n  .accordion{\n    width:450px;\n    border:1px solid #ddd;\n    border-radius:5px;\n    overflow:hidden;\n    margin-bottom:15px;\n  }\n  .accordion input{display:none}\n  .accordion-label{\n    display:flex;\n    justify-content:space-between;\n    align-items:center;\n    padding:5px 20px;\n    color:#252525;\n    cursor:pointer;\n    font-size:15px;\n    font-weight:600;\n    transition:background-color .3s ease;\n  }\n  .accordion-label::after{\n    content:'▼';\n    font-size:16px;\n    transition:transform 0.3s ease;\n  }\n  .accordion input:checked + .accordion-label::after{\n    transform:rotate(180deg);\n  }\n  .accordion-content{\n    max-height:0;\n    overflow:auto;\n    padding:0 20px;\n    background-color:#fff;\n    color:#333;\n    font-size:14px;\n    line-height:1.6;\n    transition:max-height 0.4s ease, padding 0.3s ease;\n  }\n  .accordion input:checked ~ .accordion-content{\n    max-height:500px;\n    padding:15px 20px;\n  }\n  .accordion-content h6{\n    margin-top:0;\n    color:#28486e;\n  }\n  .accordion-content ul{\n    margin:10px 0;\n    padding-left:20px;\n  }\n  .accordion-content ul li{\n    list-style-type:disc;\n    margin-bottom:8px;\n  }\n  .accordion-content p{\n    margin:10px 0;\n  }\n  .accordion-content .highlight{\n    font-weight:bold;\n  }\n  @media only screen and (max-width:768px){\n    .accordion{width:100%}\n  }\n</style>"
