    "83a135b9-30ff-430d-a7ed-dd7da7224ef0": {
      "type": "accordion",
      "blocks": {
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-1": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Does open-ear mean poor sound quality?",
            "content": "<p>Not at all. The 15mm NeoDynamic driver and S1 chip are engineered specifically for open-ear delivery — producing rich, full-range audio without sealing your ear canal. You get great sound and full awareness simultaneously.</p>"
          }
        },
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-2": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "How does real-time translation work?",
            "content": "<p>SphereLingo™ processes speech through the WeHear app in real time. In one-to-one mode, both speakers hear translations in their earbuds. Group mode handles multiple participants simultaneously across 100+ languages.</p>"
          }
        },
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-3": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Is the WeHear app free?",
            "content": "<p>Yes — free on iOS and Android. Core features are always free. Translation and AI Smart Notes are included with no subscription required for the first year.</p>"
          }
        },
        "8d42d8d4-8b59-4339-af47-78c859fa3f99": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What devices does PairHub™ connect to?",
            "content": "<p>PairHub™ supports simultaneous Bluetooth 5.4 connection to phones, laptops, and tablets. Switch active audio with a single tap. Works with iOS, Android, Windows, and macOS.</p>"
          }
        },
        "a7ca32a8-e1ac-4b07-8789-786cf58f7140": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Return and warranty policy?",
            "content": "<p>7-day no-questions-asked returns and 1-year manufacturer warranty</p>"
          }
        },
        "f5707af2-5e96-4991-bbf6-cd7df09ebaec": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What is Open Ear Air Conduction Technology?",
            "content": "<p>Open ear air conduction technology delivers immersive audio while keeping your ears open to ambient sounds. This ensures safety during outdoor activities like cycling or <a href=\"https://ngearsafe.com/blogs/open-ear-headphones/essential-running-gear\"><span style=\"text-decoration:underline\">running</span></a>, making these air conduction headphones ideal for sports enthusiasts.</p>"
          }
        },
        "3d75943e-9fb9-483d-a299-2db3629ede4f": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "How does the quad MIC ENC calling feature work?",
            "content": "<p>The quad microphone ENC (Environmental Noise Cancellation) includes dual MEMS microphones on each side. This feature ensures clear voice capture and reduces background noise, making these open ear buds with mic excellent for calls in noisy environments.</p>"
          }
        }
      },
