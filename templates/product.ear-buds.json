        "custom_liquid_tUwBjV": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"accordion\"><input type=\"checkbox\" id=\"accordion-toggle\"><label class=\"accordion-label\" for=\"accordion-toggle\">Product Description</label><div class=\"accordion-content\"><h6>Born to protect.\nBuilt to connect.</h6><p><span class=\"highlight\">Product Overview</span><br>Experience safety, comfort, and premium sound with NG x Wehear safebuds, Open Ear Earbuds, powered by advanced air conduction technology, packed with AI Capabilities.</p><p><span class=\"highlight\">Key Features</span></p><ul><li><strong>Air Conduction Technology:</strong> Provides crystal-clear sound while keeping your ear canal open.</li><li><strong>Ambient Sound Awareness:</strong> Stay connected to your surroundings during commuting, workouts, or gaming.</li><li><strong>Lightweight Design:</strong> Weighing just 9 grams, ensuring all-day comfort.</li><li><strong>Premium Finish:</strong> Skin-friendly silicone adds a touch of luxury to every wear.</li><li><strong>Dynamic Drivers:</strong> 12x17mm drivers deliver immersive, powerful, and balanced audio quality.</li><li><strong>IPX4 Waterproof and Sweatproof:</strong> Perfect for sports, running, cycling, and other outdoor activities.</li></ul><p><span class=\"highlight\">Packed with AI Features</span><br>100+ Languages live transalation, Live note taking, Custom EQ settings, All the AI power now in your ears.</p><p><span><strong>Order Now</strong></span><br>Transform your daily routine with NG x Wehear Safebuds Air Conduction Open Ear Earbuds. Upgrade to the best earbuds for workouts and beyond today!</p></div></div><style>.accordion{width:450px;border:1px solid #ddd;border-radius:5px;overflow:hidden;margin-bottom:15px}.accordion input{display:none}.accordion-label{display:flex;justify-content:space-between;align-items:center;padding:5px 20px;color:#252525;cursor:pointer;font-size:15px;font-weight:600;transition:background-color .3s ease}.accordion-label::after{content:'▼';font-size:16px;transition:transform .3s ease}.accordion input:checked+.accordion-label::after{transform:rotate(180deg)}.accordion-content{max-height:0;overflow:auto;padding:0 20px;background-color:#fff;color:#333;font-size:14px;line-height:1.6;transition:max-height .4s ease,padding .3s ease}.accordion input:checked~.accordion-content{max-height:500px;padding:15px 20px}.accordion-content h6{margin-top:0;color:#28486e}.accordion-content ul{margin:10px 0;padding-left:20px}.accordion-content ul li{list-style-type:disc;margin-bottom:8px}.accordion-content p{margin:10px 0}.accordion-content .highlight{font-weight:700}@media only screen and (max-width:768px){.accordion{width:100%}}</style>"
