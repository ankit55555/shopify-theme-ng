    "83a135b9-30ff-430d-a7ed-dd7da7224ef0": {
      "type": "accordion",
      "blocks": {
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-1": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What is open-ear bone conduction technology?",
            "content": "<p>Open-ear bone conduction technology allows sound to be transmitted through your cheekbones instead of your eardrums leaving your ears open to hear ambient sounds. This ensures both situational awareness and hearing health, making it a safer alternative to traditional headphones.</p>"
          }
        },
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-2": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Is this bone conduction technology safe for my ears?",
            "content": "<p>Yes, <a href=\"https://ngearsafe.com/pages/best-bone-conduction-headphones\" title=\"Ng EarSafe Bone Conduction Pro Mini\"><span style=\"text-decoration:underline\">bone conduction technology</span></a> is completely safe for your ears as it transmits sound through the bones, bypassing your eardrums, which helps reduce ear strain.</p>"
          }
        },
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-3": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": " Is NG EarSafe Pro Mini Waterproof?",
            "content": "<p>No, the NG EarSafe Pro Mini is water-resistant (IPX6), not waterproof. Its sweatproof and splash-resistant design makes it ideal for workouts and outdoor activities, but it shouldn’t be submerged in water.</p>"
          }
        },
        "8d42d8d4-8b59-4339-af47-78c859fa3f99": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What is Dual ENC?",
            "content": "<p>Dual ENC (Environmental Noise Cancellation) is a technology that reduces background noise during calls, ensuring clear voice transmission even in noisy environments. This helps you communicate better while on the move.</p>"
          }
        },
        "a7ca32a8-e1ac-4b07-8789-786cf58f7140": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Can other people hear when I am using bone conduction headphones or Bone Conduction Earphones?",
            "content": "<p>Not significantly. While bone conduction headphones or Bone Conduction Earphones minimize sound leakage, at very high volumes, some faint audio may be perceptible to those very close to you.</p>"
          }
        },
        "accor_item_QJXGwT": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What is the Bluetooth range of the NG EarSafe Pro Mini wireless bone conduction headphones or Bone Conduction Earphones?",
            "content": "<p>The Bluetooth range is up to 10 meters (33 feet) in an open space, providing stable connectivity.</p>"
          }
        },
        "accor_item_Gcd9JX": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What devices are NG EarSafe Pro Mini bone conduction headphones or Bone Conduction Earphones compatible with & does it have an in built mic?",
            "content": "<p>These headphones are compatible with all Bluetooth-enabled devices, including smartphones, tablets, laptops, and smartwatches. It also features a built-in mic for hands-free calls and voice commands.</p>"
          }
        },
        "accor_item_f4qDbF": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "How long does the battery last on a single charge?",
            "content": "<p>The NG EarSafe Pro Mini headphones provide up to <strong>9+ hours</strong> of continuous playback on a full charge, ensuring all-day use. Plus, just 10 minutes of charging gives you up to 70% battery perfect for those times when you’re in a rush and need power fast!</p>"
          }
        },
        "accor_item_zNNJ9h": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Where can I use these bonephones or bone conduction earphones?",
            "content": "<p>You can use these bonephones during workouts, outdoor activities, commuting, entertainment, or even while working. Their open-ear design ensures safety and comfort.</p>"
          }
        },
        "accor_item_Te7rEA": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "How many years of warranty do I get on this product?",
            "content": "<p>You get a <strong>1-year warranty</strong> on the NG EarSafe Pro Mini headphones against manufacturing defects.</p>"
          }
        },
        "accor_item_kPrDLh": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "How many days does it take for delivery across India?",
            "content": "<p>Delivery across India typically takes <strong>3 to 5 business days</strong>, depending on your location.</p>"
          }
        },
        "accor_item_Mjn4K8": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What is the return?",
            "content": "<p>We offer a <strong>7-day return policy</strong>. Ensure the product is in its original packaging, and for a smooth process, share an <strong>unboxing video</strong> if you've received a wrong or damaged item.</p>"
          }
        },
        "accor_item_8eyXL8": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Whom should I contact for customer support?",
            "content": "<p>For customer support, please contact us at <a href=\"mailto:support@ngearsafe.com\"><span style=\"text-decoration:underline\"><strong>https://help.ngearsafe.com/</strong></span></a> or call us at <strong>08047 165 643</strong>.</p>"
          }
        }
      },
