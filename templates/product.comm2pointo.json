        "custom_liquid_Rc3fXq": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<div class=\"accordion\">\n  <input type=\"checkbox\" id=\"accordion-toggle\">\n  <label class=\"accordion-label\" for=\"accordion-toggle\">Product Description</label>\n  <div class=\"accordion-content\">\n    <h6>NG EarSafe Comm 2.0 – Open Ear Headphones With Mic for Work, Walks & Everything In Between</h6>\n    <p><span class=\"highlight\">Your World. Your Sound. Your Voice.</span><br>\n    Meet the Open Ear Headphones With Mic– designed for those who hustle, commute, and communicate without skipping a beat. Engineered with directional air conduction and a noise-canceling boom mic, Comm 2.0 lets you stay aware of your surroundings while delivering crystal-clear call quality.</p>\n\n    <p>Whether you're at your desk, on the move, or in a virtual meeting, Comm 2.0 keeps you effortlessly connected with dual pairing and Bluetooth 5.3 for seamless switching across devices.</p>\n\n    <p><span class=\"highlight\">Why You'll Want It</span></p>\n    <ul>\n      <li><strong>Stay alert, sound sharp:</strong> The open-ear design lets in the world without letting out your voice.</li>\n      <li><strong>Mute in a Click:</strong> Toggle between calls and music with an instant mute button.</li>\n      <li><strong>Marathon Battery Life:</strong> 17+ hours of playtime and 10-minute fast charging for 70% boost.</li>\n      <li><strong>Built to Move:</strong> Lightweight, sweatproof (IPX5), and crafted for all-day comfort.</li>\n      <li><strong>Zero Sound Leakage:</strong> With directional audio tech, your conversations stay private.</li>\n    </ul>\n\n    <p>From calls on-the-go to power walks and WFH meetings, Comm 2.0 is your everyday essential—designed to keep your ears open and your mind focused.</p>\n\n    <p><span class=\"highlight\">Peace of Mind, Guaranteed</span></p>\n    <ul>\n      <li><strong>🚚 Free Shipping:</strong> Enjoy fast, hassle-free delivery straight to your doorstep.</li>\n      <li><strong>🔄 7-Day Return Policy:</strong> Changed your mind? Return within 7 days, no questions asked.</li>\n      <li><strong>🛠 1-Year Replacement Warranty with At-Home Service:</strong> We’ve got you covered—your comfort and satisfaction come first.</li>\n    </ul>\n  </div>\n</div>\n\n<style>\n.accordion{width:450px;border:1px solid #ddd;border-radius:5px;overflow:hidden;margin-bottom:15px;}\n.accordion input{display:none}\n.accordion-label{display:flex;justify-content:space-between;align-items:center;padding:5px 20px;color:#252525;cursor:pointer;font-size:15px;font-weight:600;transition:background-color .3s ease}\n.accordion-label::after{content:'▼';font-size:16px;transition:transform 0.3s ease}\n.accordion input:checked+.accordion-label::after{transform:rotate(180deg)}\n.accordion-content{max-height:0;overflow:auto;padding:0 20px;background-color:#fff;color:#333;font-size:14px;line-height:1.6;transition:max-height 0.4s ease,padding 0.3s ease}\n.accordion input:checked~.accordion-content{max-height:500px;padding:15px 20px}\n.accordion-content h6{margin-top:0;color:#28486e}\n.accordion-content ul{margin:10px 0;padding-left:20px}\n.accordion-content ul li{list-style-type:disc;margin-bottom:8px}\n.accordion-content p{margin:10px 0}\n.accordion-content .highlight{font-weight:bold}\n@media only screen and (max-width: 768px) {.accordion{width:100%}}\n</style>"
          }
        },
