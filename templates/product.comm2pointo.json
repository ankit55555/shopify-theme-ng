    "83a135b9-30ff-430d-a7ed-dd7da7224ef0": {
      "type": "accordion",
      "blocks": {
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-1": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What makes NG EarSafe Comm 2.0 different from regular headphones?",
            "content": "<p>NG Comm 2.0 uses <strong>air conduction open-ear technology</strong> with a <strong>boom mic</strong>, letting you hear your surroundings while making crystal-clear calls—perfect for work, commutes, or walks.</p>"
          }
        },
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-2": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Is the mic really good enough for Zoom, Teams, or phone calls?",
            "content": "<p>Yes! The <strong>noise-canceling boom mic</strong> is specially designed for professional-grade clarity, even in noisy environments. It’s ideal for remote work, virtual meetings, and calls.</p>"
          }
        },
        "template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-3": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Can I use these headphones for both calls and music?",
            "content": "<p>Yes, you can enjoy both calls and music effortlessly with NG EarSafe Comm 2.0. What’s more, the new Dual Mode feature lets you switch seamlessly between Communication and Music modes—perfect for when you want to elevate your experience and fully immerse yourself in the moment.</p>"
          }
        },
        "d3cd347d-e340-4be5-8075-724fb61f46c9": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Will these headphones block my ears like in-ear or over-ear models?",
            "content": "<p>No. These are <a href=\"https://ngearsafe.com/collections/open-ear-headphones\"><span style=\"text-decoration:underline\"><strong>open-ear headphones</strong></span></a>, meaning nothing goes inside or covers your ears. You get maximum comfort, breathability, and situational awareness.</p>"
          }
        },
        "c8df18a8-c3a3-47ba-a1d0-511389dc6c2b": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "How long does the battery last?",
            "content": "<p>NG Comm 2.0 delivers over <strong>17 hours of continuous playtime</strong>. Plus, just <strong>10 minutes of charging</strong> gives you up to 70% battery—perfect for busy days.</p>"
          }
        },
        "cb9f90a1-53a4-4f3a-bb30-97cc923f8403": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Are they waterproof or sweatproof?",
            "content": "<p>Yes, with an <strong>IPX5 water resistance rating</strong>, Comm 2.0 can handle sweat, light rain, and everyday splashes—ideal for workouts or outdoor use.</p>"
          }
        },
        "f8a2580d-f121-491c-8d46-eaa29c7acdac": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Can I connect them to two devices at once?",
            "content": "<p>Yes, with <strong>dual pairing</strong>, you can connect Comm 2.0 to your laptop and phone simultaneously—great for multitasking between calls and media.</p>"
          }
        },
        "03f7bb3f-1225-459e-9f76-2ca5a55631b8": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Do they leak sound like other open-ear headphones?",
            "content": "<p>Not at all. Thanks to <strong>directional audio technology</strong>, Comm 2.0 reduces sound leakage by up to 90%, keeping your audio private in public spaces.</p>"
          }
        },
        "63221feb-cd8f-4fb9-b052-2210cdd73abf": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "Is this suitable for people with ear pain or infections from regular earbuds?",
            "content": "<p>Definitely. Since they <strong>don’t go inside the ear</strong>, Comm 2.0 is a safer and more comfortable alternative, especially for those prone to ear fatigue or infections.</p>"
          }
        },
        "ee28a4f7-8a1c-49dd-9d22-eeeef249d3cd": {
          "type": "accor_item",
          "settings": {
            "icon": "none",
            "title": "What if I don’t like them after buying?",
            "content": "<p>No worries! You get <strong>Free Shipping</strong>, a <strong>7-Day Return Policy</strong>, and a <strong>1-Year Replacement Warranty with At-Home Service</strong>—so you can try Comm 2.0 risk-free. Visit the <a href=\"https://help.ngearsafe.com/\"><span style=\"text-decoration:underline\">NG EarSafe help center page</span></a>.</p>"
          }
        }
      },
