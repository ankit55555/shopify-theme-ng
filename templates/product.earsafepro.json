om_width":1000,"cl_bg":"","cl_bg_gradient":"","mg":",,50px,","pd":"","mg_tb":"","pd_tb":"","mg_mb":",,30px,","pd_mb":"","use_cus_css":false,"code_cus_css":""}},"16988598234be05800":{"type":"apps","blocks":{"judge_me_reviews_review_widget_CTMfQM":{"type":"shopify:\/\/apps\/judge-me-reviews\/blocks\/review_widget\/61ccd3b1-a9f2-4160-9fe9-4fec8413e5d8","settings":{}}},"block_order":["judge_me_reviews_review_widget_CTMfQM"],"custom_css":["@media only screen and (max-width: 768px) {.r-container {padding: 0 30px !important; }}"],"settings":{}},"83a135b9-30ff-430d-a7ed-dd7da7224ef0":{"type":"accordion","blocks":{"template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-1":{"type":"accor_item","settings":{"icon":"none","title":" Are they completely waterproof?","content":"<p>Yes, NG EarSafe Pro headphones are IP68-rated, which means they are waterproof and perfect for swimming. Whether you’re using them underwater, during heavy workouts, or in the rain, they are built to last and are great for sports and outdoor use.<\/p>"}},"template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-2":{"type":"accor_item","settings":{"icon":"none","title":"What are the color options?","content":"<p>NG EarSafe Pro, our open ear bone conduction headphones, is available in Black and Blue colors. These options make them perfect as lightweight over-ear headphones for everyday use or as stylish <a href=\"https:\/\/ngearsafe.com\/blogs\/open-ear-headphones\/best-running-headphone\" title=\"https:\/\/ngearsafe.com\/blogs\/open-ear-headphones\/best-running-headphone\">running headphones<\/a>.<\/p>"}},"template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-3":{"type":"accor_item","settings":{"icon":"none","title":"Is this technology safe for my ears?","content":"<p>Yes, NG EarSafe Pro uses bone conduction technology, which is one of the safest audio technologies. It transmits sound to your inner ear via vibrations through your cheekbones, keeping your ears open and safe. Unlike air conduction earphones, no part of the headphone goes inside your ear, reducing the risk of ear canal damage.<\/p>"}},"8d42d8d4-8b59-4339-af47-78c859fa3f99":{"type":"accor_item","settings":{"icon":"none","title":"How does the in-built memory work?","content":"<p>The EarSafe Pro comes with 8GB in-built memory & you can add up to 1000 songs, making it a versatile option for those looking for bone conduction headphones with a speaker feature. Store your favorite songs just like on a phone or tablet and listen to them on the go without needing a separate device, perfect for cycling or gym workouts.<\/p>"}},"a7ca32a8-e1ac-4b07-8789-786cf58f7140":{"type":"accor_item","settings":{"icon":"none","title":"Does the magnetic charging cable come inside the box and can we buy spare ones?","content":"<p>Yes, the box includes a magnetic charging cable. You can contact us if you need a spare cable for your waterproof Bluetooth headphones, ensuring you always stay powered up.<\/p>"}},"f5707af2-5e96-4991-bbf6-cd7df09ebaec":{"type":"accor_item","settings":{"icon":"none","title":"How is this different from your other open ear models?","content":"<p>NG EarSafe Pro features advanced bone conduction technology that transmits sound to your inner ears through vibrations, bypassing the outer and middle ear. This makes it suitable for individuals with certain hearing loss types. Our other models use air conduction technology, delivering sound through tiny speakers near the ears, ideal for those who prefer air conduction earphones for everyday use.<\/p>"}},"3d75943e-9fb9-483d-a299-2db3629ede4f":{"type":"accor_item","settings":{"icon":"none","title":"Is NG EarSafe Pro compatible with iPhone as well as Android?","content":"<p>Yes, these open ear wireless headphones are compatible with both iPhone and Android devices. Whether you use them as running headphones or during online meetings, their Bluetooth connectivity ensures seamless pairing.<\/p>"}},"997edcc4-6546-4b4b-9f3f-2a58893a6493":{"type":"accor_item","settings":{"icon":"none","title":"Can people with hearing loss hear through NG EarSafe Pro?","content":"<p>NG EarSafe Pro’s bone conduction technology allows individuals with partial hearing loss to hear clearly. It makes them one of the best bone-conduction headphones for those who need a safe and effective audio solution.<\/p>"}},"0fc5345d-97f9-47b2-8e24-8ec050136d74":{"type":"accor_item","settings":{"icon":"none","title":"Is there a return and replacement policy?","content":"<p>We offer a 7-day no-questions-asked return policy and a 1-year doorstep replacement warranty. These open sport headphones are designed for satisfaction, and our hassle-free policy ensures peace of mind.<\/p>"}}},"block_order":["template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-1","template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-2","template--20627092865303__83a135b9-30ff-430d-a7ed-dd7da7224ef0-accor_item-3","8d42d8d4-8b59-4339-af47-78c859fa3f99","a7ca32a8-e1ac-4b07-8789-786cf58f7140","f5707af2-5e96-4991-bbf6-cd7df09ebaec","3d75943e-9fb9-483d-a299-2db3629ede4f","997edcc4-6546-4b4b-9f3f-2a58893a6493","0fc5345d-97f9-47b2-8e24-8ec050136d74"],"settings":{"design_heading":"1","heading_align":"t4s-text-center","top_heading":"Frequently Asked Question","icon_heading":"las la-gem","top_subheading":"","tophead_mb":30,"accor_des":"1","title_cl":"#222222","bg_title_cl":"#f6f6f8","title_active_cl":"#000000","bg_title_active_cl":"#f6f6f8","content_cl":"#878787","bg_content_cl":"#ffffff","content_align":"t4s-text-start","auto_active":true,"layout":"t4s-container-wrap","custom_width":1000,"cl_bg":"","cl_bg_gradient":"","mg":"50px,,50px,","pd":"","mg_tb":"","pd_tb":"","mg_mb":",,30px,","pd_mb":"","use_cus_css":false,"code_cus_css":""}},"product-recommendations":{"type":"product-recommendations","settings":{"show":true,"design_heading":"1","heading_align":"t4s-text-center","top_heading":"You may also like","icon_h