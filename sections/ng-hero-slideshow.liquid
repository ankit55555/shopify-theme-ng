{{ 'ng-hero.css' | asset_url | stylesheet_tag }}

<section 
  class="ng-hero" 
  data-section-id="{{ section.id }}"
  style="--ng-hero-height-desktop: {{ section.settings.desktop_height }}vh; --ng-hero-height-mobile: {{ section.settings.mobile_height }}vh;">
  <div 
    class="ng-hero__slides"
    data-autoplay="{{ section.settings.autoplay }}"
    data-interval="{{ section.settings.autoplay_interval }}"
    data-loop="{{ section.settings.loop }}"
    data-pause="{{ section.settings.pause_on_hover }}"
    data-show-arrows="{{ section.settings.show_arrows }}"
    data-show-dots="{{ section.settings.show_dots }}"
    data-indicator="{{ section.settings.indicator_style }}">
    {% for block in section.blocks %}
      {% case block.type %}
        {% when 'slide' %}
          <div class="ng-hero__slide" {{ block.shopify_attributes }}>
            <picture class="ng-hero__image">
              {% if block.settings.image_mobile != blank %}
                <source media="(max-width: {{ section.settings.mobile_breakpoint }}px)" srcset="{{ block.settings.image_mobile | image_url: width: 2400 }}">
              {% endif %}
              {% if block.settings.image_desktop != blank %}
                <img src="{{ block.settings.image_desktop | image_url: width: 3200 }}" alt="{{ block.settings.alt | escape }}" loading="lazy" width="3200" height="auto">
              {% endif %}
            </picture>
            <div class="ng-hero__overlay" style="background-color: {{ block.settings.overlay_color }}; opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"></div>
            <div class="ng-hero__content ng-hero__content--{{ block.settings.text_align }}">
              {% if block.settings.heading != blank %}
                <h2 class="ng-hero__heading" style="color: {{ block.settings.heading_color }};">{{ block.settings.heading }}</h2>
              {% endif %}
              {% if block.settings.subheading != blank %}
                <p class="ng-hero__subheading" style="color: {{ block.settings.subheading_color }};">{{ block.settings.subheading }}</p>
              {% endif %}
              {% if block.settings.button_label != blank %}
                <a class="ng-hero__btn" href="{{ block.settings.button_link | default: routes.all_products_collection_url }}" style="color: {{ block.settings.button_text_color }}; background-color: {{ block.settings.button_bg_color }};">{{ block.settings.button_label }}</a>
              {% endif %}
            </div>
            {% if block.settings.show_scroll_hint %}
              <div class="ng-hero__scroll-hint">
                <span class="ng-hero__scroll-text">{{ block.settings.scroll_text | default: 'SCROLL TO DISCOVER' }}</span>
                <span class="ng-hero__scroll-icon" aria-hidden="true"></span>
              </div>
            {% endif %}
          </div>
      {% endcase %}
    {% endfor %}

    <button class="ng-hero__nav ng-hero__prev" aria-label="Previous slide"></button>
    <button class="ng-hero__nav ng-hero__next" aria-label="Next slide"></button>
    <div class="ng-hero__dots" role="tablist"></div>
    <div class="ng-hero__counter" aria-hidden="true">
      <span class="ng-hero__counter-current">01</span>
      <span class="ng-hero__counter-bar"></span>
      <span class="ng-hero__counter-total">01</span>
    </div>
  </div>
</section>

<script src="{{ 'ng-hero.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "NG Hero Slideshow",
  "tag": "section",
  "class": "ng-hero-section",
  "settings": [
    {
      "type": "range",
      "id": "desktop_height",
      "label": "Desktop height (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height (vh)",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "number",
      "id": "mobile_breakpoint",
      "label": "Mobile breakpoint (px)",
      "default": 768
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_interval",
      "label": "Autoplay interval (ms)",
      "min": 2000,
      "max": 9000,
      "step": 1000,
      "default": 5000
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop slides",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_arrows",
      "label": "Show arrows",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show dots",
      "default": true
    },
    {
      "type": "select",
      "id": "indicator_style",
      "label": "Indicator style",
      "options": [
        {"value": "dots", "label": "Dots"},
        {"value": "counter", "label": "Counter"},
        {"value": "none", "label": "None"}
      ],
      "default": "counter"
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        { "type": "image_picker", "id": "image_desktop", "label": "Image (desktop)" },
        { "type": "image_picker", "id": "image_mobile", "label": "Image (mobile)" },
        { "type": "text", "id": "alt", "label": "Image alt" },
        { "type": "text", "id": "heading", "label": "Heading", "default": "NG EarSafe Pro" },
        { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Bone Conduction Waterproof headphones. Beneficial for conductive hearing loss" },
        { "type": "text", "id": "button_label", "label": "Button label", "default": "SHOP NOW" },
        { "type": "url", "id": "button_link", "label": "Button link" },
        { "type": "select", "id": "text_align", "label": "Text position", "options": [
          {"value": "left", "label": "Left"},
          {"value": "center", "label": "Center"},
          {"value": "right", "label": "Right"}
        ], "default": "left" },
        { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#FFFFFF" },
        { "type": "color", "id": "subheading_color", "label": "Subheading color", "default": "#FFFFFF" },
        { "type": "color", "id": "button_text_color", "label": "Button text color", "default": "#FFFFFF" },
        { "type": "color", "id": "button_bg_color", "label": "Button background", "default": "#222222" },
        { "type": "color", "id": "overlay_color", "label": "Overlay color", "default": "#000000" },
        { "type": "range", "id": "overlay_opacity", "label": "Overlay opacity (%)", "min": 0, "max": 80, "step": 5, "default": 30 },
        { "type": "checkbox", "id": "show_scroll_hint", "label": "Show scroll hint", "default": false },
        { "type": "text", "id": "scroll_text", "label": "Scroll text", "default": "SCROLL TO DISCOVER" }
      ]
    }
  ],
  "presets": [
    { 
      "name": "NG Hero Slideshow", 
      "category": "Homepage",
      "blocks": [ {"type": "slide"}, {"type": "slide"} ] 
    }
  ]
}
{% endschema %}


