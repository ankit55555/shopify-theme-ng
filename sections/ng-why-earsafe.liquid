{% comment %}
  NG Why EarSafe Section
  - Desktop and mobile layout
  - Separate CSS/JS assets: ng-why-earsafe.css, ng-why-earsafe.js
  - Clickable feature list switches image and caption
{% endcomment %}

{%- liquid
  assign section_id = section.id
  assign classes = ''
-%}

<link rel="stylesheet" href="{{ 'ng-why-earsafe.css' | asset_url }}" media="all">

<section
  id="ng-why-earsafe-{{ section_id }}"
  class="ng-why-earsafe {{ classes }}"
  style="--pt: {{ section.settings.padding_top }}px; --pb: {{ section.settings.padding_bottom }}px; --bg: {{ section.settings.bg_color }}; --heading: {{ section.settings.heading_color }}; --text: {{ section.settings.text_color }}; --subdued: {{ section.settings.subdued_text_color }}; --accent: {{ section.settings.accent_color }}; --feature-inactive: {{ section.settings.feature_inactive_color }}; --feature-active-bg: {{ section.settings.feature_active_bg }}; --border: {{ section.settings.border_color }}; --caption: {{ section.settings.caption_color }};"
>
  <div class="ngwe-container">
    {%- if section.settings.heading != blank -%}
      <h2 class="ngwe-heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="ngwe-subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}

    <div class="ngwe-content" data-section-id="{{ section_id }}">
      <div class="ngwe-features" role="tablist" aria-orientation="vertical">
        {%- for block in section.blocks -%}
          {%- assign is_active = forloop.first -%}
          <button
            id="ngwe-tab-{{ section_id }}-{{ forloop.index }}"
            class="ngwe-feature{% if is_active %} is-active{% endif %}"
            role="tab"
            aria-selected="{% if is_active %}true{% else %}false{% endif %}"
            aria-controls="ngwe-panel-{{ section_id }}-{{ forloop.index }}"
            data-index="{{ forloop.index0 }}"
          >
            <span class="ngwe-feature-label">{{ block.settings.title | default: 'Feature' | escape }}</span>
          </button>
        {%- endfor -%}
      </div>

      <div class="ngwe-visual" role="tabpanel-group">
        {%- for block in section.blocks -%}
          {%- assign is_active = forloop.first -%}
          <figure
            id="ngwe-panel-{{ section_id }}-{{ forloop.index }}"
            class="ngwe-slide{% if is_active %} is-active{% endif %}"
            role="tabpanel"
            aria-labelledby="ngwe-tab-{{ section_id }}-{{ forloop.index }}"
          >
            {%- if block.settings.image != blank -%}
              {%- assign image = block.settings.image -%}
              <img
                srcset="{{ image | image_url: width: 400 }} 400w, {{ image | image_url: width: 800 }} 800w, {{ image | image_url: width: 1200 }} 1200w, {{ image | image_url: width: 1600 }} 1600w"
                sizes="(max-width: 749px) 100vw, 60vw"
                src="{{ image | image_url: width: 1200 }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                class="ngwe-image"
              >
            {%- else -%}
              {{ 'image' | placeholder_svg_tag: 'ngwe-image placeholder' }}
            {%- endif -%}
            {%- if block.settings.caption != blank -%}
              <figcaption class="ngwe-caption">{{ block.settings.caption }}</figcaption>
            {%- endif -%}
          </figure>
        {%- endfor -%}
      </div>
    </div>
  </div>

  <script src="{{ 'ng-why-earsafe.js' | asset_url }}" defer></script>
</section>

{% schema %}
{
  "name": "NG - Why EarSafe",
  "class": "section-ng-why-earsafe",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Why NG EarSafe" },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna." },
    { "type": "color", "id": "bg_color", "label": "Background color", "default": "#0f0f0f" },
    { "type": "color", "id": "heading_color", "label": "Heading color", "default": "#f5f5f5" },
    { "type": "color", "id": "text_color", "label": "Text color", "default": "#f5f5f5" },
    { "type": "color", "id": "subdued_text_color", "label": "Subheading color", "default": "#bdbdbd" },
    { "type": "color", "id": "feature_inactive_color", "label": "Feature text (inactive)", "default": "#9e9e9e" },
    { "type": "color", "id": "accent_color", "label": "Accent color (active text)", "default": "#E4B44A" },
    { "type": "color", "id": "feature_active_bg", "label": "Active pill background", "default": "#3b2c0b26" },
    { "type": "color", "id": "border_color", "label": "Pill border color", "default": "#ffffff14" },
    { "type": "color", "id": "caption_color", "label": "Caption color", "default": "#dddddd" },
    { "type": "range", "id": "padding_top", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Padding top", "default": 64 },
    { "type": "range", "id": "padding_bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "label": "Padding bottom", "default": 64 }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "title", "label": "Title", "default": "Connectivity" },
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "caption", "label": "Caption", "default": "Latency Free Bluetooth Connectivity" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "NG - Why EarSafe",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}


