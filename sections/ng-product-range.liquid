{%- comment -%} 
  NG Product Range section 
  - Responsive carousel of product cards 
  - Separate CSS (`assets/ng-product-range.css`) and JS (`assets/ng-product-range.js`) 
{%- endcomment -%}

{%- liquid
  assign section_id = section.id
  assign stt_layout = section.settings.layout
  if stt_layout == 't4s-se-container'
    assign html_layout = '<div class="t4s-container">__</div></div>' | split: '__'
  elsif stt_layout == 't4s-container-wrap'
    assign html_layout = '<div class="t4s-container">__</div>' | split: '__'
  else
    assign html_layout = '__' | split: '__'
  endif
-%}

{{- html_layout[0] -}}
<div
  class="ng-pr ng-pr--bg-{{ section.settings.bg_style }} ng-pr--cta-{{ section.settings.cta_style }} ng-pr--cta-size-{{ section.settings.cta_size }}"
  id="ng-pr-{{ section_id }}"
  data-section-id="{{ section_id }}">
  <style>
    #ng-pr-{{ section_id }} .ng-pr__title{font-size: {{ section.settings.heading_fs | default: 28 }}px}
    #ng-pr-{{ section_id }} .ng-pr__desc{font-size: {{ section.settings.desc_fs | default: 14 }}px}
    {%- if section.settings.card_bg_style == 'white' -%}
      #ng-pr-{{ section_id }} .ng-pr__card{background-color: #ffffff;border-color: rgba(0,0,0,0.08)}
    {%- elsif section.settings.card_bg_style == 'custom' -%}
      #ng-pr-{{ section_id }} .ng-pr__card{background-color: {{ section.settings.card_custom_bg_color | default: '#ffffff' }};border-color: {{ section.settings.card_border_color | default: 'rgba(0,0,0,0.08)' }}}
    {%- else -%}
      #ng-pr-{{ section_id }} .ng-pr__card{background-color: {{ section.settings.card_bg_color | default: 'rgba(255,255,255,0.04)' }};border-color: {{ section.settings.card_border_color | default: 'rgba(255,255,255,0.08)' }}}
    {%- endif -%}
    #ng-pr-{{ section_id }} .ng-pr__cta{background-color: {{ section.settings.cta_bg_color | default: 'transparent' }};color: {{ section.settings.cta_text_color | default: '#fff' }};border-color: {{ section.settings.cta_border_color | default: 'rgba(255,255,255,0.25)' }}}
    #ng-pr-{{ section_id }} .ng-pr__intro{background-color: {{ section.settings.intro_bg_color | default: 'rgba(255,255,255,0.04)' }}}
    #ng-pr-{{ section_id }} .ng-pr__price-current{color: {{ section.settings.price_color | default: '#ffd700' }}}
    #ng-pr-{{ section_id }} .ng-pr__title{color: {{ section.settings.heading_color | default: 'inherit' }}}
    #ng-pr-{{ section_id }} .ng-pr__desc{color: {{ section.settings.desc_color | default: 'inherit' }}}
    @media (max-width: 767.98px) {
      #ng-pr-{{ section_id }} .ng-pr__title{font-size: {{ section.settings.heading_fs_mobile | default: 24 }}px}
      #ng-pr-{{ section_id }} .ng-pr__desc{font-size: {{ section.settings.desc_fs_mobile | default: 12 }}px}
    }
  </style>
  <div class="ng-pr__row">
    <div class="ng-pr__intro">
      {%- if section.settings.heading != blank -%}
        <h2 class="ng-pr__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="ng-pr__desc">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.cta_label != blank and section.settings.cta_link != blank -%}
        <a class="ng-pr__cta" href="{{ section.settings.cta_link }}">{{ section.settings.cta_label }}</a>
      {%- endif -%}
    </div>

    <div class="ng-pr__viewport" data-autoplay="{{ section.settings.autoplay }}" data-autoplay-interval="{{ section.settings.autoplay_interval }}" data-show-arrows="{{ section.settings.show_arrows }}">
      {%- if section.settings.show_arrows -%}
      <button class="ng-pr__nav ng-pr__nav--prev" type="button" aria-label="Previous"></button>
      {%- endif -%}
      <div class="ng-pr__track" data-carousel>
    {%- for block in section.blocks -%}
      {%- assign prod = all_products[block.settings.product] -%}
      <article class="ng-pr__card" id="ng-pr-card-{{ block.id }}" data-product-handle="{{ prod.handle }}" data-product-url="{{ prod.url }}" {{ block.shopify_attributes }}>
        {%- if prod -%}
          {%- assign sel_var = prod.selected_or_first_available_variant -%}
          {%- assign featured = sel_var.featured_image | default: prod.featured_image -%}
          <a
            class="ng-pr__image"
            href="{{ prod.url }}"
            aria-label="{{ prod.title | escape }}">
            {%- if featured -%}
              <img
                src="{{ featured | image_url: width: 900 }}"
                alt="{{ featured.alt | escape }}"
                width="900"
                height="675"
                loading="lazy">
            {%- endif -%}
          </a>
          <div class="ng-pr__meta">
            <h3 class="ng-pr__name">
              <a class="ng-pr__link" href="{{ prod.url }}">{{ prod.title }}</a>
            </h3>
            {%- assign subtitle = prod.type -%}
            {%- if prod.metafields.custom.subtitle != blank -%}
              {%- assign subtitle = prod.metafields.custom.subtitle -%}
            {%- endif -%}
            {%- if subtitle != blank -%}
              <div class="ng-pr__sub">{{ subtitle }}</div>
            {%- endif -%}
            <div class="ng-pr__bottom">
              <div class="ng-pr__price" data-price>
                <span class="ng-pr__price-current" data-price-current>{{ sel_var.price | money }}</span>
                {%- if sel_var.compare_at_price > sel_var.price -%}
                  <span class="ng-pr__price-compare" data-price-compare>{{ sel_var.compare_at_price | money }}</span>
                {%- else -%}
                  <span class="ng-pr__price-compare" data-price-compare style="display:none"></span>
                {%- endif -%}
              </div>
              {%- if prod.has_only_default_variant == false and prod.options.size > 0 -%}
                {%- assign first_option_name = prod.options | first | downcase -%}
                {%- if first_option_name == 'color' or first_option_name == 'colour' -%}{% assign is_color = true %}{% else %}{% assign is_color = false %}{% endif -%}
                {%- assign values_csv = '' -%}
                {%- for v in prod.variants -%}
                  {%- if v.available -%}
                    {%- capture token -%},{{ v.option1 | strip }}{%- endcapture -%}
                    {%- unless values_csv contains token -%}
                      {%- assign values_csv = values_csv | append: token -%}
                    {%- endunless -%}
                  {%- endif -%}
                {%- endfor -%}
                {%- assign available_values = values_csv | remove_first: ',' | split: ',' -%}
                <ul class="ng-pr__swatches" role="list">
                  {%- for value in available_values -%}
                    <li>
                      <button type="button" class="ng-pr__swatch{% if value == sel_var.option1 %} is-active{% endif %}" data-option1="{{ value | escape }}" aria-label="{{ value | escape }}">
                        <span class="ng-pr__swatch-dot" {% if is_color %}style="background: {{ value | escape }}"{% endif %}></span>
                      </button>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </div>
          </div>
          <script type="application/json" class="ng-pr__data">{{ prod | json }}</script>
        {%- else -%}
          <div class="ng-pr__placeholder">
            <div class="ng-pr__ph-img"></div>
            <div class="ng-pr__ph-text"></div>
          </div>
        {%- endif -%}
      </article>
    {%- endfor -%}
      </div>
      {%- if section.settings.show_arrows -%}
      <button class="ng-pr__nav ng-pr__nav--next" type="button" aria-label="Next"></button>
      {%- endif -%}
    </div>
  </div>
  </div>
  {{- html_layout[1] -}}

 {%- comment -%} Assets {%- endcomment -%}
{%- assign css_key = 'ng-product-range.css' -%}
{%- assign js_key = 'ng-product-range.js' -%}
<link rel="stylesheet" href="{{ css_key | asset_url }}">
<script src="{{ js_key | asset_url }}" defer="defer"></script>

{% schema %}
  {
    "name": "NG Product Range",
    "settings": [
      {
        "type": "checkbox",
        "id": "show_arrows",
        "label": "Show navigation arrows",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "autoplay",
        "label": "Enable autoplay (used when arrows hidden)",
        "default": false
      },
      {
        "type": "range",
        "id": "autoplay_interval",
        "label": "Autoplay interval (ms)",
        "min": 2000,
        "max": 9500,
        "step": 500,
        "default": 4000
      },
      {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Our Product Range"
      }, {
        "type": "textarea",
        "id": "subheading",
        "label": "Description",
        "default": "Open-ear technology provides a comfortable and safer alternative to in-ear headphones"
      }, {
        "type": "range",
        "id": "heading_fs",
        "label": "Heading font size (px)",
        "min": 18,
        "max": 64,
        "step": 1,
        "default": 28
      }, {
        "type": "range",
        "id": "desc_fs",
        "label": "Description font size (px)",
        "min": 12,
        "max": 24,
        "step": 1,
        "default": 14
      }, {
        "type": "range",
        "id": "heading_fs_mobile",
        "label": "Heading font size - Mobile (px)",
        "min": 16,
        "max": 48,
        "step": 1,
        "default": 24
      }, {
        "type": "range",
        "id": "desc_fs_mobile",
        "label": "Description font size - Mobile (px)",
        "min": 10,
        "max": 20,
        "step": 1,
        "default": 12
      }, {
        "type": "text",
        "id": "cta_label",
        "label": "CTA label",
        "default": "View all"
      }, {
        "type": "url",
        "id": "cta_link",
        "label": "CTA link"
      }, {
        "type": "select",
        "id": "cta_style",
        "label": "CTA style",
        "default": "outline",
        "options": [
          {"value":"outline","label":"Outline"},
          {"value":"primary","label":"Primary"}
        ]
      }, {
        "type": "select",
        "id": "cta_size",
        "label": "CTA size",
        "default": "lg",
        "options": [
          {"value":"sm","label":"Small"},
          {"value":"md","label":"Medium"},
          {"value":"lg","label":"Large"}
        ]
      }, {
        "type": "select",
        "id": "bg_style",
        "label": "Background style",
        "default": "none",
        "options": [
          {"value":"none","label":"None"},
          {"value":"light","label":"Light"},
          {"value":"dark","label":"Dark"}
        ]
      }, {
        "type": "select",
        "id": "layout",
        "label": "Layout",
        "default": "t4s-container-wrap",
        "options": [
          { "value": "t4s-se-container", "label": "Container" },
          { "value": "t4s-container-wrap", "label": "Wrapped container" },
          { "value": "t4s-container-fluid", "label": "Full width" }
        ]
      }, {
        "type": "header",
        "content": "Colors & Backgrounds"
      }, {
        "type": "color",
        "id": "heading_color",
        "label": "Heading color",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "desc_color",
        "label": "Description color",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "intro_bg_color",
        "label": "Intro section background",
        "default": "rgba(255,255,255,0.04)"
      }, {
        "type": "color",
        "id": "card_bg_color",
        "label": "Card background",
        "default": "rgba(255,255,255,0.04)"
      }, {
        "type": "color",
        "id": "card_border_color",
        "label": "Card border color",
        "default": "rgba(255,255,255,0.08)"
      }, {
        "type": "color",
        "id": "price_color",
        "label": "Price color",
        "default": "#ffd700"
      }, {
        "type": "color",
        "id": "cta_bg_color",
        "label": "CTA background color",
        "default": "transparent"
      }, {
        "type": "color",
        "id": "cta_text_color",
        "label": "CTA text color",
        "default": "#ffffff"
      }, {
        "type": "color",
        "id": "cta_border_color",
        "label": "CTA border color",
        "default": "rgba(255,255,255,0.25)"
      }, {
        "type": "header",
        "content": "Product Card Background Options"
      }, {
        "type": "select",
        "id": "card_bg_style",
        "label": "Card background style",
        "default": "white",
        "options": [
          {"value":"white","label":"White"},
          {"value":"transparent","label":"Transparent"},
          {"value":"custom","label":"Custom Color"}
        ]
      }, {
        "type": "color",
        "id": "card_custom_bg_color",
        "label": "Custom card background color",
        "default": "#ffffff"
      }
    ],
    "blocks": [
      {
        "type": "product",
        "name": "Product card",
        "settings": [
          {
            "type": "product",
            "id": "product",
            "label": "Product"
          }
        ]
      }
    ],
    "max_blocks": 12,
    "presets": [
      {
        "name": "NG Product Range",
        "category": "Products"
      }
    ]
  }
{% endschema %}