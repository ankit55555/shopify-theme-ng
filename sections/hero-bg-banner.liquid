          },
          {
            "value": "right top",
            "label": "Right top"
          },
          {
            "value": "left center",
            "label": "Left center"
          }, {
            "value": "center center",
            "label": "Center"
          }, {
            "value": "right center",
            "label": "Right center"
          }, {
            "value": "left bottom",
            "label": "Left bottom"
          }, {
            "value": "center bottom",
            "label": "Center bottom"
          }, {
