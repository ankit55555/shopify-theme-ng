<!-- sections/ng-best-selling.liquid -->
{{ 'section.css' | asset_url | stylesheet_tag }}
{{ 'collections-showcase.css' | asset_url | stylesheet_tag }}
{%- liquid
  assign sid = section.id
  assign se_stts = section.settings
  assign stt_layout = se_stts.layout
  assign stt_image_bg = se_stts.image_bg
  
  # Determine source collection automatically (no manual picking needed)
  assign src_collection = blank
  if se_stts.auto_best
    # Prefer current collection context when available
    if se_stts.use_current_collection and collection and collection.products_count > 0
      assign src_collection = collection
    endif
    # Try preferred handle from settings
    if src_collection == blank and se_stts.best_handle != blank and collections[se_stts.best_handle]
      assign src_collection = collections[se_stts.best_handle]
    endif
    # Try common best-seller handles
    if src_collection == blank
      assign handles_try = 'best-sellers,bestsellers,best-seller,best_sellers' | split: ','
      for h in handles_try
        if collections[h] and collections[h].products_count > 0
          assign src_collection = collections[h]
          break
        endif
      endfor
    endif
    # Fallback to all products
    if src_collection == blank and collections['all']
      assign src_collection = collections['all']
    endif
  else
    # Manual override by collection setting
    if se_stts.collection != blank
      assign src_collection = collections[se_stts.collection]
    endif
  endif
  
  # Get products
  assign limit_pr = se_stts.limit_pr | default: 8
  assign has_products = false
  if src_collection != blank and src_collection.products_count > 0
    assign has_products = true
  endif
  
  if stt_layout == 't4s-se-container' 
    assign html_layout = '<div class="t4s-container">__</div></div>' | split: '__'
  elsif stt_layout == 't4s-container-wrap'
    assign html_layout = '<div class="t4s-container">__</div>' | split: '__'
  else
    assign html_layout = '__' | split: '__'
  endif
  
  assign t4s_se_class = 't4s_nt_se_' | append: sid
  if se_stts.use_cus_css and se_stts.code_cus_css != blank
    render 'se_cus_css', code_cus_css: se_stts.code_cus_css, t4s_se_class: t4s_se_class
  endif 
-%}
<div class="t4s-section-inner t4s_nt_se_{{ sid }} t4s_se_{{ sid }} {{ stt_layout }}{% if stt_image_bg != blank and stt_layout != 't4s-se-container' %} t4s-has-imgbg lazyloadt4s{% endif %}" {% if stt_image_bg != blank and stt_layout != 't4s-se-container' %} data-bgset="{{ stt_image_bg | image_url: width: 1 }}" data-sizes="auto"  data-optimumx="2"{% endif %} {% render 'section_style', se_stts: se_stts -%}>
  {{- html_layout[0] -}}
  {%- if stt_layout == 't4s-se-container' -%}<div class="t4s-container-inner{% if stt_image_bg != blank %} t4s-has-imgbg lazyloadt4s{% endif %}" {% if stt_image_bg != blank %} data-bgset="{{ stt_image_bg | image_url: width: 1 }}" data-sizes="auto"  data-optimumx="2"{% endif %}>{% endif -%}
  
  {%- render 'section_tophead', se_stts: se_stts -%}
  
  {%- if has_products -%}
    <div class="t4s-collections-showcase t4s-row t4s-row-cols-lg-{{ se_stts.col_dk }} t4s-row-cols-md-{{ se_stts.col_tb }} t4s-row-cols-{{ se_stts.col_mb }} t4s-g-lg-{{ se_stts.space_h_item }} t4s-g-md-{{ se_stts.space_h_item_tb }} t4s-g-{{ se_stts.space_h_item_mb }}" style="--label-color: {{ se_stts.label_color }}; --label-color-hover: {{ se_stts.label_color_hover }}; --label-font-size: {% if se_stts.label_font_size == 'small' %}14px{% elsif se_stts.label_font_size == 'large' %}20px{% else %}16px{% endif %}; --label-font-weight: {{ se_stts.label_font_weight }}; --label-space-top: {{ se_stts.label_space_top }}px; --item-rd: {{ se_stts.item_rd }}{{ se_stts.item_rd_unit }}; --space-h-item-tb: {{ se_stts.space_h_item_tb }}px; --space-h-item-mb: {{ se_stts.space_h_item_mb }}px;">
      {%- for product in src_collection.products limit: limit_pr -%}
        {%- liquid
          assign pr_url = product.url
          assign pid = product.id
          assign isDefault = product.has_only_default_variant
          assign pr_variants = product.variants
          assign current_variant = pr_variants.first
          assign isPreoder = false
          
          if product.tags contains 'isPreoder' or current_variant.inventory_policy == 'continue' and current_variant.inventory_management == 'shopify' and current_variant.inventory_quantity <= 0
            assign isPreoder = true
          endif
          
          if current_variant.inventory_management == 'shopify'
            assign max_qty = current_variant.inventory_quantity | default: 9999
          else
            assign max_qty = 9999
          endif
          if current_variant.quantity_rule.max and max_qty > current_variant.quantity_rule.max
            assign max_qty = current_variant.quantity_rule.max
          endif
          
          assign meta_theme = product.metafields.theme
          assign cus_qty = meta_theme.cus_qty | default: 1
          if current_variant.quantity_rule.min and cus_qty < current_variant.quantity_rule.min
            assign cus_qty = current_variant.quantity_rule.min
          endif
          
          assign color_count = 0
          assign size_count = 0
          assign enable_pr_color = true
          assign enable_pr_size = true
          assign stt_color_ck = settings.color_ck | default: ';'
          assign color_ck = stt_color_ck | append: ',color,colors,couleur,colour' | remove: ';,'
          assign get_color = color_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
          assign stt_size_ck = settings.size_ck | default: ';'
          assign size_ck = stt_size_ck | append: ',size,sizes,taille' | remove: ';,'
          assign get_size = size_ck | downcase | replace: ' ,', ',' | replace: ', ', ',' | split: ',' | uniq
          assign show_cl_type = '1'
          assign show_size_type = '1'
          
          if isDefault == false and enable_pr_color or enable_pr_size
            assign pr_options = product.options_with_values
            assign img_variants = pr_variants | where: "featured_image"
            assign available_variants = product.variants | where: "available"
            
            for option in pr_options
              assign name = option.name | downcase
              
              if enable_pr_color and get_color contains name and color_count == 0
                assign pr_option_color = 'option' | append: forloop.index
                assign color_variants_avai = available_variants | map: pr_option_color | uniq
                assign color_variants = option.values
                if show_cl_type == '1'
                  assign color_count = color_variants.size
                else
                  if pr_options.size == 1
                    assign color_variants = color_variants_avai
                  endif
                  assign color_count = color_variants_avai.size
                endif
              elsif enable_pr_size and get_size contains name and size_count == 0
                assign pr_option_size = 'option' | append: forloop.index 
                assign size_variants_avai = available_variants | map: pr_option_size | uniq
                assign size_variants = option.values
                if show_size_type == '1'
                  assign size_count = size_variants.size
                else
                  if pr_options.size == 1
                    assign size_variants = size_variants_avai
                  endif
                  assign size_count = size_variants_avai.size
                endif
              endif
            endfor
          endif
          
          assign enable_rating = settings.enable_rating
          assign app_review = settings.app_review
        -%}
        
        <div class="t4s-col-item t4s-collections-showcase-item t4s-showcase-product" data-product-id="{{ product.id }}">
          <div class="t4s-showcase-item-inner t4s-eff t4s-eff-{{ se_stts.img_effect }} t4s-eff-border-{{ se_stts.border_effect }}" timeline hdt-reveal="slide-in">
            <div class="t4s-showcase-image-wrap" data-current-variant-id="{{ current_variant.id }}">
              {%- assign item_image = product.featured_image -%}
              {%- if item_image != blank -%}
                <div class="t4s-showcase-image t4s-bg-11" style="--aspect-ratioapt: {{ item_image.aspect_ratio | default: 1.2 }}; background: url({{ item_image | image_url: width: 1 }});">
                  <img class="lazyloadt4s t4s-lz--fadeIn t4s-obj-eff" 
                       data-src="{{ item_image | image_url: width: 1 }}" 
                       data-widths="[100,200,400,600,700,800,900,1000,1200,1400,1600]" 
                       data-optimumx="2" 
                       data-sizes="auto" 
                       src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" 
                       width="{{ item_image.width }}" 
                       height="{{ item_image.height }}" 
                       alt="{{ item_image.alt | escape }}">
                </div>
              {%- else -%}
                <div class="t4s-showcase-image t4s-bg-11" style="--aspect-ratioapt: 1.2;">
                  {%- capture current -%}{%- cycle 1, 2, 3, 4, 5, 6 -%}{%- endcapture -%}
                  {{ 'collection-' | append: current | placeholder_svg_tag: 't4s-placeholder-svg t4s-obj-eff' }}
                </div>
              {%- endif -%}
              
              <div class="t4s-showcase-product-btns">
                {%- if settings.enable_quickview -%}
                  <a data-id="{{ pid }}" href="{{ pr_url }}" data-tooltip rel="nofollow" class="t4s-pr-item-btn t4s-pr-quickview" data-action-quickview>
                    <span class="t4s-svg-pr-icon"><svg viewBox="0 0 24 24"><use xlink:href="#t4s-icon-qv"></use></svg></span>
                    <span class="t4s-text-pr">{{ 'products.product_card.quick_view' | t }}</span>
                  </a>
                {%- endif -%}
                {%- if settings.enable_atc -%}
                  <a href="{{ pr_url }}" class="t4s-pr-item-btn t4s-pr-addtocart" data-variant-id="{{ current_variant.id }}" data-action-atc rel="nofollow">
                    <span class="t4s-svg-pr-icon"><svg viewBox="0 0 24 24"><use xlink:href="#t4s-icon-atc"></use></svg></span>
                    <span class="t4s-text-pr">{% if isPreoder %}{{ 'products.product.pre_order' | t }}{% else %}{{ 'products.product.add_to_cart' | t }}{% endif %}</span>
                  </a>
                {%- endif -%}
              </div>
            </div>
            
            <div class="t4s-showcase-content">
              <h3 class="t4s-showcase-product-title">
                <a href="{{ pr_url }}">{{ product.title }}</a>
              </h3>
              
              <div class="t4s-showcase-product-actions">
                {%- if settings.enable_atc -%}
                  <a href="{{ pr_url }}" class="t4s-showcase-btn t4s-showcase-btn-atc" data-variant-id="{{ current_variant.id }}" data-action-atc rel="nofollow"{% unless current_variant.available %} aria-disabled="true"{% endunless %}>
                    <span class="t4s-showcase-btn-text">{% if current_variant.available == false %}{{ 'products.product.sold_out' | t }}{% elsif isPreoder %}{{ 'products.product.pre_order' | t }}{% else %}{{ 'products.product.add_to_cart' | t }}{% endif %}</span>
                    <span class="t4s-loading__spinner" hidden>
                      <svg width="16" height="16" hidden class="t4s-svg-spinner" focusable="false" role="presentation" viewBox="0 0 66 66" xmlns="http://www.w3.org/2000/svg"><circle class="t4s-path" fill="none" stroke-width="6" cx="33" cy="33" r="30"></circle></svg>
                    </span>
                  </a>
                {%- endif -%}
                <a href="{{ pr_url }}" class="t4s-showcase-btn t4s-showcase-btn-buynow" data-variant-id="{{ current_variant.id }}" data-action-buynow rel="nofollow"{% unless current_variant.available %} aria-disabled="true"{% endunless %}>
                  <span class="t4s-showcase-btn-text">Buy Now</span>
                </a>
              </div>
              
              {%- assign selv = current_variant -%}
              <div class="t4s-product-price">
                {%- if selv.compare_at_price > selv.price -%}
                  {%- assign discount_pct = selv.compare_at_price | minus: selv.price | times: 100 | divided_by: selv.compare_at_price | round -%}
                  <del>{{ selv.compare_at_price | money }}</del>
                  <ins>{{ selv.price | money }}</ins>
                  <span class="t4s-badge-sale">-{{ discount_pct }}%</span>
                {%- else -%}
                  <ins>{{ selv.price | money }}</ins>
                {%- endif -%}
              </div>
              
              {%- if enable_rating -%}
                {%- render 'product-rating', product: product, app_review: app_review -%}
              {%- endif -%}
              
              {%- if color_count > 0 -%}
                <div class="t4s-product-colors swatch_color_style_2 t4s-showcase-product-colors">
                  {%- assign color_opt_key = pr_option_color -%}
                  {%- for color_val in color_variants -%}
                    {%- assign v_match = product.variants | where: color_opt_key, color_val | first -%}
                    {%- if v_match -%}
                      <a href="#" class="t4s-pr-color__item" aria-label="{{ color_val }}"
                        data-variant-id="{{ v_match.id }}"
                        data-price="{{ v_match.price }}"
                        data-compare="{{ v_match.compare_at_price }}"
                        data-url="{{ product.url }}?variant={{ v_match.id }}"
                        {%- if v_match.featured_image -%}data-image="{{ v_match.featured_image | image_url: width: 1 }}" data-image-w="{{ v_match.featured_image.width }}" data-image-h="{{ v_match.featured_image.height }}"{%- endif -%}>
                        <span class="t4s-pr-color__value bg_color_{{ color_val | handle }}"></span>
                      </a>
                    {%- endif -%}
                  {%- endfor -%}
                </div>
              {%- endif -%}
              
              
            </div>
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="t4s-empty-collection">
      <p>No products found in this collection.</p>
    </div>
  {%- endif -%}
  
  {%- if stt_layout == 't4s-se-container' -%}</div>{% endif -%}
  {{- html_layout[1] -}}
</div>

<script>
  (function(){
    var root = document.querySelector('.t4s_se_{{ sid }}');
    if(!root) return;

    function fmt(cents){
      try {
        if (window.Shopify && Shopify.formatMoney) return Shopify.formatMoney(cents, Shopify.money_format);
      } catch(e) {}
      var v = (Number(cents||0)/100);
      return v.toLocaleString(undefined, { style: 'currency', currency: (window.Shopify && Shopify.currency && Shopify.currency.active) || 'USD' });
    }

    root.addEventListener('click', function(e){
      var btn = e.target.closest('.t4s-pr-color__item');
      if(!btn) return;
      var card = btn.closest('.t4s-collections-showcase-item');
      if(!card) return;

      var variantId = btn.getAttribute('data-variant-id');
      var price = parseInt(btn.getAttribute('data-price') || '0', 10);
      var compare = parseInt(btn.getAttribute('data-compare') || '0', 10);
      var url = btn.getAttribute('data-url');
      var imgUrl = btn.getAttribute('data-image');
      var imgW = btn.getAttribute('data-image-w');
      var imgH = btn.getAttribute('data-image-h');

      // Update ATC button
      var atc = card.querySelector('[data-action-atc]');
      if(atc){ atc.setAttribute('data-variant-id', variantId); if(url){ atc.setAttribute('href', url); } }
      
      // Update Buy Now button
      var buyNow = card.querySelector('[data-action-buynow]');
      if(buyNow){ buyNow.setAttribute('data-variant-id', variantId); if(url){ buyNow.setAttribute('href', url); } }

      // Selected state on swatches
      var group = btn.parentElement;
      if(group){
        Array.prototype.forEach.call(group.querySelectorAll('.t4s-pr-color__item'), function(el){ el.classList.remove('is-swatch--selected'); });
        btn.classList.add('is-swatch--selected');
      }

      // Update title link
      var titleLink = card.querySelector('.t4s-showcase-product-title a');
      if(titleLink && url){ titleLink.setAttribute('href', url); }

      // Update price
      var priceWrap = card.querySelector('.t4s-product-price');
      if(priceWrap){
        var html = '';
        if(compare && compare > price){
          var pct = Math.round((compare - price) * 100 / compare);
          html = '<del>'+fmt(compare)+'</del><ins>'+fmt(price)+'</ins><span class="t4s-badge-sale">-'+pct+'%</span>';
        } else {
          html = '<ins>'+fmt(price)+'</ins>';
        }
        priceWrap.innerHTML = html;
      }

      // Update image
      if(imgUrl){
        var wrap = card.querySelector('.t4s-showcase-image-wrap');
        var holder = card.querySelector('.t4s-showcase-image');
        var img = card.querySelector('.t4s-showcase-image img');
        if(holder){ holder.style.backgroundImage = 'url('+imgUrl+')'; }
        if(img){
          img.setAttribute('data-src', imgUrl);
          img.setAttribute('src', imgUrl);
          if(imgW) img.setAttribute('width', imgW);
          if(imgH) img.setAttribute('height', imgH);
        }
        if(wrap){ wrap.setAttribute('data-current-variant-id', variantId); }
      }

      e.preventDefault();
    });
    
    // Handle Buy Now button clicks
    root.addEventListener('click', function(e){
      var btn = e.target.closest('[data-action-buynow]');
      if(!btn) return;
      e.preventDefault();
      
      var card = btn.closest('.t4s-collections-showcase-item');
      if(!card) return;
      
      var variantId = btn.getAttribute('data-variant-id');
      var url = btn.getAttribute('href');
      
      if(!variantId || !url) return;
      
      // Add to cart and redirect to checkout
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
        },
        body: JSON.stringify({
          id: variantId,
          quantity: 1
        })
      })
      .then(function(response) {
        if(response.ok) {
          window.location.href = '/checkout';
        } else {
          return response.json().then(function(data) {
            throw new Error(data.description || 'Failed to add to cart');
          });
        }
      })
      .catch(function(error) {
        console.error('Error:', error);
        // Fallback to product page
        window.location.href = url;
      });
    });
  })();
</script>

{%- schema -%}
{
  "name": "NG Best Selling Products",
  "tag": "section",
  "class": "t4s-section t4s-section-all t4s_tp_cdt t4s-collections-showcase-wrapper",
  "enabled_on": {
    "templates": ["collection", "list-collections", "index", "page"]
  },
  "settings": [
    {
      "type": "header",
      "content": "1. Collection Settings"
    },
    {
      "type": "checkbox",
      "id": "auto_best",
      "label": "Auto-pick best sellers (no manual selection)",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "use_current_collection",
      "label": "Prefer current collection when available",
      "default": true
    },
    {
      "type": "text",
      "id": "best_handle",
      "label": "Preferred best-sellers collection handle",
      "default": "best-sellers",
      "info": "If present, this collection will be used (sorted by best-selling). Common handles: best-sellers, bestsellers."
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Manual override collection",
      "info": "Optional. Only used if Auto-pick is disabled."
    },
    {
      "type": "range",
      "id": "limit_pr",
      "min": 2,
      "max": 20,
      "step": 1,
      "label": "Number of products to show",
      "default": 8
    },
    {
      "type": "header",
      "content": "2. Heading options"
    },
    {
      "type": "select",
      "id": "design_heading",
      "label": "+ Design heading",
      "default": "1",
      "options": [
        { "value": "1", "label": "Design 01" },
        { "value": "2", "label": "Design 02" },
        { "value": "3", "label": "Design 03" },
        { "value": "4", "label": "Design 04" },
        { "value": "5", "label": "Design 05" },
        { "value": "6", "label": "Design 06 (width line-awesome)" },
        { "value": "7", "label": "Design 07" },
        { "value": "8", "label": "Design 08" },
        { "value": "9", "label": "Design 09" },
        { "value": "10", "label": "Design 10" },
        { "value": "11", "label": "Design 11" },
        { "value": "12", "label": "Design 12" },
        { "value": "13", "label": "Design 13" },
        { "value": "14", "label": "Design 14" },
        { "value": "15", "label": "Design 15" },
        { "value": "16", "label": "Design 16" }
      ]
    },
    {
      "type": "select",
      "id": "heading_align",
      "label": "+ Heading align",
      "default": "t4s-text-start",
      "options": [
        { "value": "t4s-text-start", "label": "Left" },
        { "value": "t4s-text-center", "label": "Center" },
        { "value": "t4s-text-end", "label": "Right" }
      ]
    },
    {
      "type": "text",
      "id": "top_heading",
      "label": "+ Heading",
      "default": "Best Selling Products"
    },
    {
      "type": "text",
      "id": "icon_heading",
      "label": "Enter a icon name on heading",
      "info": "Only used for design 6 [LineAwesome](https://kalles.the4.co/font-lineawesome/)",
      "default": "las la-gem"
    },
    {
      "type": "textarea",
      "id": "top_subheading",
      "label": "+ Subheading"
    },
    {
      "type": "number",
      "id": "tophead_mb",
      "label": "+ Space bottom (px)",
      "info": "The vertical spacing between heading and content",
      "default": 30
    },
    {
      "type": "header",
      "content": "3. General options"
    },
    {
      "type": "select",
      "id": "col_dk",
      "label": "Items per row (Desktop)",
      "default": "4",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" },
        { "value": "6", "label": "6" }
      ]
    },
    {
      "type": "select",
      "id": "col_tb",
      "label": "Items per row (Tablet)",
      "default": "3",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "select",
      "id": "col_mb",
      "label": "Items per row (Mobile)",
      "default": "2",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ]
    },
    {
      "type": "range",
      "id": "space_h_item",
      "min": 0,
      "max": 50,
      "step": 1,
      "label": "Horizontal space between items",
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "space_h_item_tb",
      "min": 0,
      "max": 50,
      "step": 1,
      "label": "Horizontal space between items (Tablet)",
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "space_h_item_mb",
      "min": 0,
      "max": 50,
      "step": 1,
      "label": "Horizontal space between items (Mobile)",
      "unit": "px",
      "default": 10
    },
    {
      "type": "header",
      "content": "4. Image options"
    },
    {
      "type": "select",
      "id": "img_effect",
      "label": "Image hover effect",
      "default": "zoom",
      "options": [
