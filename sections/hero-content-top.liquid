{%- assign s = section.settings -%}

<section class="hero-content-top hero-content-top--{{ section.id }}{% if s.contain_content %} hero-content-top--contained{% endif %}">
  <div class="hero-content-top__content-wrapper" style="background-color: {{ s.content_bg_color }}; padding-top: {{ s.content_padding_top }}px; padding-bottom: {{ s.content_padding_bottom }}px;">
    <div class="hero-content-top__container">
      <div class="hero-content-top__content hero-content-top__content--h-{{ s.horizontal_align }}" style="max-width: {{ s.content_max_width }}px; color: {{ s.text_color }};">
        {%- if s.heading != blank -%}
          <div class="hero-content-top__heading rte">{{ s.heading }}</div>
        {%- endif -%}
        {%- if s.middle_text != blank -%}
          <div class="hero-content-top__middle-text rte" style="color: {{ s.middle_text_color }};">{{ s.middle_text }}</div>
        {%- endif -%}
        {%- if s.subheading != blank -%}
          <div class="hero-content-top__subheading rte" style="font-weight:600;">{{ s.subheading }}</div>
        {%- endif -%}
        {%- if s.cta_label != blank and s.cta_link != blank -%}
          <a
            href="{{ s.cta_link }}"
            class="hero-content-top__cta hero-content-top__cta--{{ s.cta_style }}"
            style="--cta-color: {{ s.button_color }}; --cta-text: {{ s.button_text_color }};">
            <span>{{ s.cta_label }}</span>
            <svg
              class="hero-content-top__cta-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true">
              <path
                d="M12 2a10 10 0 1 1 0 20 10 10 0 0 1 0-20Z"
                fill="currentColor"
                opacity=".15" />
              <path
                d="M10 8l4 4-4 4"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round" />
            </svg>
          </a>
        {%- endif -%}
      </div>
    </div>
  </div>

  <div class="hero-content-top__image-wrapper">
    {%- style -%}
      #shopify-section-{{ section.id }} .hero-content-top__image-wrapper {
        position: relative;
        isolation: isolate;
        padding-top: {{ s.padding_top }}px;
        padding-bottom: {{ s.padding_bottom }}px;
        min-height: {{ s.height_desktop }}px;
        background-color: #000;
        background-repeat: no-repeat;
        background-size: cover;
        background-position: {{ s.bg_position_desktop }};
        {% if s.image_desktop != blank %}
          background-image: url('{{ s.image_desktop | img_url: '2000x' }}');
        {% endif %}
      }

      #shopify-section-{{ section.id }} .hero-content-top__image-wrapper:before {
        content: "";
        position: absolute;
        inset: 0;
        background: {{ s.overlay_color }};
        opacity: {{ s.overlay_opacity | divided_by: 100.0 }};
        z-index: 0;
      }

      #shopify-section-{{ section.id }} .hero-content-top__content-wrapper {
        width: 100%;
      }

      #shopify-section-{{ section.id }} .hero-content-top--contained .hero-content-top__container {
        width: 100%;
        max-width: {{ s.container_max_width }}px;
        margin: 0 auto;
        padding-left: 20px;
        padding-right: 20px;
      }

      /* Ensure contained layout honors horizontal alignment */
      #shopify-section-{{ section.id }} .hero-content-top--contained .hero-content-top__content--h-left {
        margin-left: 0;
        margin-right: auto;
      }
      #shopify-section-{{ section.id }} .hero-content-top--contained .hero-content-top__content--h-center {
        margin-left: auto;
        margin-right: auto;
      }
      #shopify-section-{{ section.id }} .hero-content-top--contained .hero-content-top__content--h-right {
        margin-left: auto;
        margin-right: 0;
      }

      #shopify-section-{{ section.id }} .hero-content-top__container {
        width: 100%;
      }

      #shopify-section-{{ section.id }} .hero-content-top__content {
        display: flex;
        flex-direction: column;
        gap: 18px;
      }

      #shopify-section-{{ section.id }} .hero-content-top__content--h-left {
        margin-left: 0;
        margin-right: auto;
      }
      #shopify-section-{{ section.id }} .hero-content-top__content--h-center {
        margin-left: auto;
        margin-right: auto;
      }
      #shopify-section-{{ section.id }} .hero-content-top__content--h-right {
        margin-left: auto;
        margin-right: 0;
      }

      #shopify-section-{{ section.id }} .hero-content-top__heading {
        font-size: 56px;
        line-height: 1.1;
        font-weight: 700;
      }

      #shopify-section-{{ section.id }} .hero-content-top__middle-text {
        font-size: 20px;
        line-height: 1.4;
        font-weight: 600;
      }

      #shopify-section-{{ section.id }} .hero-content-top__subheading {
        font-size: 16px;
        line-height: 1.6;
        opacity: .9;
      }

      #shopify-section-{{ section.id }} .hero-content-top__cta {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        width: max-content;
        text-decoration: none;
        color: var(--cta-text);
      }

      #shopify-section-{{ section.id }} .hero-content-top__cta--solid {
        background: var(--cta-color);
        color: var(--cta-text);
        padding: 12px 18px;
        border-radius: 999px;
        font-weight: 600;
      }

      #shopify-section-{{ section.id }} .hero-content-top__cta--outline {
        background: transparent;
        color: var(--cta-color);
        border: 2px solid var(--cta-color);
        padding: 10px 16px;
        border-radius: 999px;
        font-weight: 600;
      }

      #shopify-section-{{ section.id }} .hero-content-top__cta--link {
        color: var(--cta-color);
        font-weight: 600;
      }

      #shopify-section-{{ section.id }} .hero-content-top__cta-icon {
        display: inline-block;
      }

      @media (max-width: 749px) {
        #shopify-section-{{ section.id }} .hero-content-top__image-wrapper {
          min-height: {{ s.height_mobile }}px;
          background-position: {{ s.bg_position_mobile }};
          {% if s.image_mobile != blank %}
            background-image: url('{{ s.image_mobile | img_url: '1200x' }}');
          {% endif %}
        }
        #shopify-section-{{ section.id }} .hero-content-top__heading {
          font-size: 34px;
        }
        #shopify-section-{{ section.id }} .hero-content-top__subheading {
          font-size: 15px;
        }
      }
    {%- endstyle -%}
  </div>
</section>

