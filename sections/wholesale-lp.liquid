{{ 'https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap' | stylesheet_tag }}

<style>
.wh-wrap{--wh-navy:#102442;--wh-ocean:#39869b;--wh-cyan:#54c1c8;--wh-frost:#E8F6F7;--wh-chalk:#F4F4F2;--wh-paper:#FFFFFF;--wh-ink:#102442;--wh-ink-soft:#3d5266;--wh-muted:#5c7185;--wh-line:rgba(16,36,66,0.12);--wh-line-soft:rgba(16,36,66,0.08);--wh-shadow:0 20px 44px -28px rgba(16,36,66,0.35);
  font-family:'Poppins',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;color:var(--wh-ink);background:var(--wh-chalk);}
.wh-wrap *{box-sizing:border-box;}
.wh-wrap img{max-width:100%;display:block;}
.wh-wrap a{color:inherit;}
.wh-wrap h1,.wh-wrap h2,.wh-wrap h3{margin:0;font-weight:600;letter-spacing:-0.01em;}
.wh-wrap p{margin:0;}
.wh-inner{max-width:1180px;margin:0 auto;padding:0 28px;}
.wh-eyebrow{display:inline-flex;align-items:center;gap:8px;font-size:12.5px;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:var(--wh-ocean);}
.wh-eyebrow::before{content:"";width:16px;height:2px;background:var(--wh-cyan);border-radius:2px;}

.wh-hero{position:relative;background:radial-gradient(720px 420px at 82% -10%,rgba(84,193,200,0.22),transparent 60%),linear-gradient(180deg,#102442 0%,#0c1c34 100%);color:#fff;overflow:hidden;}
.wh-hero-inner{max-width:820px;margin:0 auto;padding:76px 28px 68px;text-align:center;}
.wh-hero .wh-eyebrow{color:var(--wh-cyan);}
.wh-hero .wh-eyebrow::before{background:var(--wh-cyan);}
.wh-hero h1{font-size:clamp(32px,4.2vw,50px);line-height:1.1;font-weight:700;margin-top:18px;color:#fff;}
.wh-hero h1 em{font-style:normal;color:var(--wh-cyan);}
.wh-hero .wh-sub{margin:20px auto 0;font-size:17px;color:rgba(255,255,255,0.78);max-width:52ch;font-weight:400;}
.wh-hero-actions{margin-top:32px;display:flex;gap:14px;flex-wrap:wrap;align-items:center;justify-content:center;}
.wh-btn{display:inline-flex;align-items:center;justify-content:center;gap:8px;padding:14px 26px;border-radius:100px;font-family:inherit;font-size:14.5px;font-weight:600;cursor:pointer;border:1px solid transparent;text-decoration:none;transition:transform .15s ease,box-shadow .15s ease,background .15s ease,border-color .15s ease;}
.wh-btn:active{transform:translateY(1px);}
.wh-btn-primary{background:var(--wh-cyan);color:#08222b;}
.wh-btn-primary:hover{background:#68cdd3;}
.wh-btn-ghost{background:transparent;border-color:rgba(255,255,255,0.32);color:#fff;}
.wh-btn-ghost:hover{border-color:rgba(255,255,255,0.6);}
.wh-hero-stats{margin-top:44px;display:flex;gap:32px;flex-wrap:wrap;justify-content:center;}
.wh-hero-stat b{display:block;font-size:24px;font-weight:700;color:#fff;font-variant-numeric:tabular-nums;}
.wh-hero-stat span{font-size:12.5px;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:0.08em;}

.wh-sec{padding:76px 0;}
.wh-sec-head{max-width:640px;margin:0 auto 40px;text-align:center;}
.wh-sec-head h2{font-size:clamp(24px,3vw,34px);margin-top:14px;color:var(--wh-navy);}
.wh-sec-head p{margin-top:12px;color:var(--wh-muted);font-size:15.5px;}

.wh-about{background:var(--wh-paper);}
.wh-about-inner{display:grid;grid-template-columns:0.9fr 1.1fr;gap:56px;align-items:center;}
.wh-about-copy h2{font-size:clamp(24px,3vw,32px);color:var(--wh-navy);margin:14px 0 16px;}
.wh-about-copy p{color:var(--wh-ink-soft);font-size:15.5px;margin-bottom:14px;}
.wh-about-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--wh-line);border:1px solid var(--wh-line);border-radius:14px;overflow:hidden;}
.wh-about-cell{background:var(--wh-paper);padding:26px 22px;}
.wh-about-cell b{display:block;font-size:26px;font-weight:700;color:var(--wh-ocean);font-variant-numeric:tabular-nums;}
.wh-about-cell span{display:block;margin-top:6px;font-size:12.5px;color:var(--wh-muted);text-transform:uppercase;letter-spacing:0.06em;}

.wh-models{background:var(--wh-chalk);}
.wh-model-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:20px;}
.wh-model-card{background:var(--wh-paper);border:1px solid var(--wh-line);border-radius:20px;overflow:hidden;display:flex;flex-direction:column;box-shadow:var(--wh-shadow);text-decoration:none;color:inherit;transition:transform .18s ease,box-shadow .18s ease,border-color .18s ease;}
.wh-model-card:hover{transform:translateY(-4px);border-color:var(--wh-cyan);box-shadow:0 26px 50px -26px rgba(84,193,200,0.45);}
.wh-model-media{position:relative;aspect-ratio:4/3;background:var(--wh-frost);display:flex;align-items:center;justify-content:center;overflow:hidden;}
.wh-model-media img{width:100%;height:100%;object-fit:cover;transition:transform .35s ease;}
.wh-model-card:hover .wh-model-media img{transform:scale(1.05);}
.wh-model-tag{position:absolute;top:12px;left:12px;font-size:10.5px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;padding:5px 10px;border-radius:100px;background:rgba(16,36,66,0.82);color:#fff;white-space:nowrap;}
.wh-model-body{padding:20px 22px 22px;display:flex;flex-direction:column;gap:12px;flex:1;}
.wh-model-name{font-size:17.5px;font-weight:700;color:var(--wh-navy);line-height:1.25;}
.wh-model-for{font-size:12.5px;color:var(--wh-ocean);font-weight:600;text-transform:uppercase;letter-spacing:0.04em;}
.wh-model-desc{font-size:13.5px;color:var(--wh-ink-soft);line-height:1.6;}
.wh-model-specs{display:flex;flex-wrap:wrap;gap:7px;margin-top:auto;padding-top:12px;border-top:1px solid var(--wh-line-soft);}
.wh-spec-pill{font-size:11.5px;font-weight:500;color:var(--wh-ink-soft);background:var(--wh-frost);padding:5px 9px;border-radius:8px;}
.wh-model-link{display:flex;align-items:center;gap:6px;font-size:12.5px;font-weight:600;color:var(--wh-ocean);margin-top:4px;}
.wh-model-link svg{width:13px;height:13px;transition:transform .15s ease;}
.wh-model-card:hover .wh-model-link svg{transform:translateX(3px);}

.wh-clients{background:var(--wh-paper);}
.wh-client-note{text-align:center;font-size:13px;color:var(--wh-muted);margin-top:6px;}
.wh-collage{margin-top:44px;display:grid;grid-template-columns:repeat(8,1fr);grid-auto-rows:74px;gap:16px;}
.wh-logo-tile{background:var(--wh-paper);border:1px solid var(--wh-line);border-radius:16px;box-shadow:var(--wh-shadow);display:flex;align-items:center;justify-content:center;gap:10px;padding:14px 18px;transition:transform .18s ease,box-shadow .18s ease;}
.wh-logo-tile:hover{transform:translateY(-3px) rotate(0deg) !important;box-shadow:0 26px 48px -26px rgba(16,36,66,0.35);}
.wh-logo-tile img{max-height:38px;width:auto;object-fit:contain;}
.wh-logo-mark{flex:none;width:38px;height:38px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;color:#fff;letter-spacing:-0.02em;}
.wh-logo-wordmark{font-weight:600;font-size:14.5px;color:var(--wh-navy);letter-spacing:-0.01em;white-space:nowrap;}
.wh-lt-1{grid-column:1/4;grid-row:1/3;transform:rotate(-1.2deg);}
.wh-lt-2{grid-column:4/7;grid-row:1/2;transform:rotate(0.8deg);}
.wh-lt-3{grid-column:7/9;grid-row:1/3;transform:rotate(-0.6deg);}
.wh-lt-4{grid-column:4/6;grid-row:2/4;transform:rotate(1.1deg);}
.wh-lt-5{grid-column:1/4;grid-row:3/4;transform:rotate(0.5deg);}
.wh-lt-6{grid-column:6/9;grid-row:3/4;transform:rotate(-0.9deg);}
.wh-lt-7{grid-column:1/9;grid-row:4/5;transform:rotate(0.3deg);}

.wh-inquiry{background:var(--wh-chalk);}
.wh-inquiry-shell{background:var(--wh-paper);border:1px solid var(--wh-line);border-radius:24px;box-shadow:var(--wh-shadow);display:grid;grid-template-columns:0.85fr 1.15fr;overflow:hidden;}
.wh-inquiry-side{background:linear-gradient(160deg,var(--wh-navy),#0c1c34);color:#fff;padding:44px 36px;display:flex;flex-direction:column;gap:22px;}
.wh-inquiry-side .wh-eyebrow{color:var(--wh-cyan);}
.wh-inquiry-side .wh-eyebrow::before{background:var(--wh-cyan);}
.wh-inquiry-side h3{color:#fff;font-size:22px;margin-top:4px;}
.wh-inquiry-side p{color:rgba(255,255,255,0.72);font-size:14.5px;line-height:1.6;}
.wh-reassure-list{display:flex;flex-direction:column;gap:14px;margin-top:auto;}
.wh-reassure-item{display:flex;gap:10px;align-items:flex-start;font-size:13.5px;color:rgba(255,255,255,0.85);}
.wh-reassure-item svg{flex:none;margin-top:2px;width:16px;height:16px;color:var(--wh-cyan);}
.wh-inquiry-form{padding:40px 40px;}
.wh-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:18px 16px;}
.wh-field{display:flex;flex-direction:column;gap:7px;}
.wh-field.wh-full{grid-column:1/-1;}
.wh-field label{font-size:12.5px;font-weight:600;color:var(--wh-ink-soft);text-transform:uppercase;letter-spacing:0.04em;}
.wh-field input,.wh-field select{font-family:inherit;font-size:14.5px;color:var(--wh-ink);background:var(--wh-chalk);border:1px solid var(--wh-line);border-radius:10px;padding:12px 14px;outline:none;transition:border-color .15s ease,box-shadow .15s ease;width:100%;}
.wh-field input:focus,.wh-field select:focus{border-color:var(--wh-cyan);box-shadow:0 0 0 3px rgba(84,193,200,0.45);}
.wh-field .wh-hint{font-size:12px;color:var(--wh-muted);font-weight:400;text-transform:none;letter-spacing:0;}
.wh-form-submit{margin-top:22px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;}
.wh-form-note{font-size:12.5px;color:var(--wh-muted);max-width:34ch;}
.wh-btn-submit{background:var(--wh-ocean);color:#fff;border:none;padding:14px 30px;border-radius:100px;font-family:inherit;font-size:14.5px;font-weight:600;cursor:pointer;}
.wh-btn-submit:hover{background:#2f7386;}
.wh-form-success{background:var(--wh-frost);border:1px solid var(--wh-cyan);border-radius:14px;padding:20px 22px;font-size:14.5px;color:var(--wh-navy);font-weight:500;}

@media (max-width:920px){
  .wh-about-inner{grid-template-columns:1fr;}
  .wh-model-grid{grid-template-columns:repeat(2,1fr);}
  .wh-collage{grid-template-columns:repeat(4,1fr);grid-auto-rows:64px;}
  .wh-lt-1{grid-column:1/3;grid-row:1/3;}
  .wh-lt-2{grid-column:3/5;grid-row:1/2;}
  .wh-lt-3{grid-column:3/5;grid-row:2/3;}
  .wh-lt-4{grid-column:1/3;grid-row:3/4;}
  .wh-lt-5{grid-column:3/5;grid-row:3/4;}
  .wh-lt-6{grid-column:1/3;grid-row:4/5;}
  .wh-lt-7{grid-column:1/5;grid-row:5/6;}
  .wh-inquiry-shell{grid-template-columns:1fr;}
  .wh-form-grid{grid-template-columns:1fr;}
  .wh-sec{padding:56px 0;}
}
@media (max-width:520px){
  .wh-hero-actions{flex-direction:column;align-items:stretch;}
  .wh-model-grid{grid-template-columns:1fr;}
  .wh-collage{grid-template-columns:repeat(2,1fr);grid-auto-rows:60px;}
}
</style>

<div class="wh-wrap" id="wholesale-lp">

  <section class="wh-hero">
    <div class="wh-hero-inner">
      <span class="wh-eyebrow">{{ section.settings.hero_eyebrow | default: 'Corporate & bulk orders' }}</span>
      <h1>{{ section.settings.hero_heading | default: 'Gear your team wears all day. Gifts they actually keep on.' }}</h1>
      <p class="wh-sub">{{ section.settings.hero_sub | default: "India's open-ear audio brand, built into operational headsets for call-and-ops floors and premium gifting your people will use in every meeting — not leave in a drawer." }}</p>
      <div class="wh-hero-actions">
        <a class="wh-btn wh-btn-primary" href="#wholesale-inquiry">{{ section.settings.hero_cta_primary | default: 'Get bulk pricing' }}</a>
        <a class="wh-btn wh-btn-ghost" href="#wholesale-models">{{ section.settings.hero_cta_secondary | default: 'See which model fits' }}</a>
      </div>
      <div class="wh-hero-stats">
        <div class="wh-hero-stat"><b>6 yrs</b><span>Category ownership</span></div>
        <div class="wh-hero-stat"><b>~1L</b><span>Customers served</span></div>
        <div class="wh-hero-stat"><b>7+</b><span>Enterprise accounts served</span></div>
      </div>
    </div>
  </section>

  <section class="wh-sec wh-about">
    <div class="wh-inner wh-about-inner">
      <div class="wh-about-copy">
        <span class="wh-eyebrow">About NG EarSafe</span>
        <h2>Six years building the only open-ear category in India.</h2>
        <p>N.G Consumertech Pvt Ltd, founded 2020. We started with one belief: the way most people listen — sealed, pressurized, for hours — is doing quiet damage. Open-ear keeps the canal clear and the wearer aware of their room, their call, and the people around them.</p>
        <p>That belief scales directly into corporate use: ops floors that need agents alert for a full shift, and gifting programs that want something an employee actually reaches for again. We're not a general electronics vendor selling headphones in bulk — this is the one thing we've built for six straight years, and enterprise teams buy from us because of it.</p>
      </div>
      <div class="wh-about-grid">
        <div class="wh-about-cell"><b>2020</b><span>Founded, Mumbai</span></div>
        <div class="wh-about-cell"><b>Open-ear</b><span>Category we created</span></div>
        <div class="wh-about-cell"><b>~1L</b><span>Customers served</span></div>
        <div class="wh-about-cell"><b>D2C + B2B</b><span>Direct &amp; enterprise</span></div>
      </div>
    </div>
  </section>

  <section class="wh-sec wh-models" id="wholesale-models">
    <div class="wh-inner">
      <div class="wh-sec-head">
        <span class="wh-eyebrow">Model fit</span>
        <h2>Built for four different corporate needs.</h2>
        <p>Tell us the use case and we'll confirm the fit — most orders map cleanly to one of the models below.</p>
      </div>
      <div class="wh-model-grid">
        {% for model in (1..4) %}
          {% assign p_key = 'model_' | append: model | append: '_product' %}
          {% assign img_key = 'model_' | append: model | append: '_image' %}
          {% assign name_key = 'model_' | append: model | append: '_name' %}
          {% assign for_key = 'model_' | append: model | append: '_for' %}
          {% assign desc_key = 'model_' | append: model | append: '_desc' %}
          {% assign tag_key = 'model_' | append: model | append: '_tag' %}
          {% assign spec1_key = 'model_' | append: model | append: '_spec1' %}
          {% assign spec2_key = 'model_' | append: model | append: '_spec2' %}
          {% assign product = section.settings[p_key] %}
          {% assign card_url = '#' %}
          {% if product %}{% assign card_url = product.url %}{% endif %}
          <a class="wh-model-card" href="{{ card_url }}" {% if product %}target="_blank" rel="noopener"{% endif %}>
            <div class="wh-model-media">
              <span class="wh-model-tag">{{ section.settings[tag_key] }}</span>
              {% if section.settings[img_key] %}
                {{ section.settings[img_key] | image_url: width: 700 | image_tag: loading: 'lazy', alt: section.settings[name_key] }}
              {% elsif product and product.featured_image %}
                {{ product.featured_image | image_url: width: 700 | image_tag: loading: 'lazy', alt: section.settings[name_key] }}
              {% endif %}
            </div>
            <div class="wh-model-body">
              <div>
                <div class="wh-model-name">{{ section.settings[name_key] }}</div>
                <div class="wh-model-for">{{ section.settings[for_key] }}</div>
              </div>
              <p class="wh-model-desc">{{ section.settings[desc_key] }}</p>
              <div class="wh-model-specs">
                {% if section.settings[spec1_key] != blank %}<span class="wh-spec-pill">{{ section.settings[spec1_key] }}</span>{% endif %}
                {% if section.settings[spec2_key] != blank %}<span class="wh-spec-pill">{{ section.settings[spec2_key] }}</span>{% endif %}
              </div>
              <span class="wh-model-link">View product page
                <svg viewBox="0 0 24 24" fill="none"><path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
              </span>
            </div>
          </a>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="wh-sec wh-clients">
    <div class="wh-inner">
      <div class="wh-sec-head">
        <span class="wh-eyebrow">Past orders</span>
        <h2>Teams that have already ordered from us.</h2>
        <p class="wh-client-note">A cross-section of the operational and gifting orders we've fulfilled — from pharma to finance to industrial automation.</p>
      </div>
      <div class="wh-collage">
        {% assign names = "Dr Reddy's Laboratories,Accenture,IBM,Augmont Gold,Bharat Petroleum,Amstrad,Endress+Hauser" | split: ',' %}
        {% assign initials = 'DR,A,IBM,AU,BP,AM,EH' | split: ',' %}
        {% assign bg_colors = '#00205B,#A100FF,#052FAD,#B8860B,#EE2E24,#102442,#39869b' | split: ',' %}
        {% for i in (1..7) %}
          {% assign idx = forloop.index0 %}
          {% assign logo_key = 'client_logo_' | append: i %}
          <div class="wh-logo-tile wh-lt-{{ i }}">
            {% if section.settings[logo_key] %}
              {{ section.settings[logo_key] | image_url: width: 240 | image_tag: loading: 'lazy', alt: names[idx] }}
            {% else %}
              <span class="wh-logo-mark" style="background:{{ bg_colors[idx] }};">{{ initials[idx] }}</span>
              <span class="wh-logo-wordmark">{{ names[idx] }}</span>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </section>

  <section class="wh-sec wh-inquiry" id="wholesale-inquiry">
    <div class="wh-inner">
      <div class="wh-sec-head">
        <span class="wh-eyebrow">Get a quote</span>
        <h2>Tell us what you need. We'll come back with pricing.</h2>
      </div>
      <div class="wh-inquiry-shell">
        <div class="wh-inquiry-side">
          <span class="wh-eyebrow">What happens next</span>
          <h3>A reply within one business day, not a ticket queue.</h3>
          <p>This goes directly to our B2B team at NG EarSafe — no distributor, no reseller markup. You'll hear back with per-unit pricing for your quantity band and, if useful, a sample unit before you commit.</p>
          <div class="wh-reassure-list">
            <div class="wh-reassure-item"><svg viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Direct pricing, no markup layer</div>
            <div class="wh-reassure-item"><svg viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Sample unit available before you order</div>
            <div class="wh-reassure-item"><svg viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>Pan-India delivery, single or multi-city</div>
          </div>
        </div>

        {% form 'contact', id: 'WholesaleInquiryForm', class: 'wh-inquiry-form' %}
          {% if form.posted_successfully? %}
          <div class="wh-form-success">Thanks — your enquiry is in. Our B2B team will reply within one business day.</div>
          {% else %}
          <div class="wh-form-grid">
            <div class="wh-field">
              <label for="WholesaleModel">Model preference</label>
              <select id="WholesaleModel" name="contact[Model preference]" required>
                <option value="" disabled selected>Select a model</option>
                <option>NG EarSafe Comm 2.0 — Operational headset</option>
                <option>NG x WeHear SafeBuds — Premium gifting</option>
                <option>NG EarSafe Lite — Budget gifting</option>
                <option>NG EarSafe OpenWire — Volume gifting</option>
                <option>Not sure — recommend one for us</option>
              </select>
            </div>
            <div class="wh-field">
              <label for="WholesaleQty">Quantity</label>
              <input id="WholesaleQty" name="contact[Quantity]" type="number" min="10" placeholder="e.g. 150" required />
              <span class="wh-hint">Most corporate orders run 100–2,000 units</span>
            </div>
            <div class="wh-field wh-full">
              <label for="WholesaleLocation">Delivery location</label>
              <input id="WholesaleLocation" name="contact[Delivery location]" type="text" placeholder="City / cities, or pan-India" required />
            </div>
            <div class="wh-field">
              <label for="WholesaleName">Your name</label>
              <input id="WholesaleName" name="contact[name]" type="text" placeholder="Full name" required />
            </div>
            <div class="wh-field">
              <label for="WholesaleCompany">Company</label>
              <input id="WholesaleCompany" name="contact[Company]" type="text" placeholder="Company name" required />
            </div>
            <div class="wh-field">
              <label for="WholesaleEmail">Work email</label>
              <input id="WholesaleEmail" name="contact[email]" type="email" placeholder="you@company.com" required {% if customer %}value="{{ customer.email }}"{% endif %} />
            </div>
            <div class="wh-field">
              <label for="WholesalePhone">Phone</label>
              <input id="WholesalePhone" name="contact[Phone]" type="tel" placeholder="+91" required />
            </div>
          </div>
          <input type="hidden" name="contact[body]" value="New corporate/wholesale enquiry submitted via the Corporate & Bulk Orders page." />

          <div class="wh-form-submit">
            <span class="wh-form-note">By submitting, you agree to be contacted by NG EarSafe's B2B team about this enquiry.</span>
            <button class="wh-btn-submit" type="submit">Request pricing</button>
          </div>
          {% endif %}
        {% endform %}
      </div>
    </div>
  </section>

</div>

{% schema %}
{
  "name": "Wholesale / Corporate LP",
  "settings": [
    { "type": "header", "content": "Hero" },
    { "type": "text", "id": "hero_eyebrow", "label": "Eyebrow", "default": "Corporate & bulk orders" },
