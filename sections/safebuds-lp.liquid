<!-- HERO -->
<section class="sb-hero">
  <div class="sb-wrap">
    <div class="sb-hero-grid">

      <div class="sb-hero-copy">
        <div class="sb-badge">✦ {{ section.settings.hero_badge }}</div>
        <h1>{{ section.settings.hero_h1_line1 }}<br>{{ section.settings.hero_h1_prefix }} <em>{{ section.settings.hero_h1_em }}</em><br>{{ section.settings.hero_h1_line3 }}</h1>
        <p class="sb-hero-sub">{{ section.settings.hero_sub }}</p>

        <div class="sb-price-row">
          <span class="sb-price-big">{{ product.price | money }}</span>
          <span class="sb-price-note">{{ section.settings.price_note }}</span>
        </div>
        <div class="sb-color-row">
          <span class="sb-color-lbl">Colour</span>
          {% for variant in product.variants %}
            {% assign v_color = variant.option1 | downcase | remove: ' ' %}
            {% if v_color == 'black' %}
              <div class="sw {% if forloop.first %}active{% endif %}" style="background:#1a1a1a" data-variant="{{ variant.id }}" onclick="sbSetColor('{{ v_color }}',this,{{ variant.id }})"></div>
            {% elsif v_color == 'ivory' %}
              <div class="sw" style="background:#F5EFE0;border:1px solid #ddd" data-variant="{{ variant.id }}" onclick="sbSetColor('{{ v_color }}',this,{{ variant.id }})"></div>
            {% endif %}
          {% endfor %}
          <span class="sw-name" id="sbSwName">{{ product.variants.first.option1 }}</span>
        </div>

        <div class="sb-cta-stack" id="buy">
          <button class="sb-btn-main" onclick="sbAddToCart()">{{ section.settings.btn_atc }}</button>
          <button class="sb-btn-sec" onclick="sbBuyNow()">{{ section.settings.btn_buy }}</button>
        </div>

        <div class="sb-micro">
          <span class="sb-mi">{% render 'icon-check' %} 7-day returns</span>
          <span class="sb-mi">{% render 'icon-check' %} 1-year warranty</span>
          <span class="sb-mi">{% render 'icon-check' %} ENT certified</span>
          <span class="sb-mi">{% render 'icon-check' %} Ships in 1–2 days</span>
        </div>
      </div>

      <div class="sb-hero-img-wrap">
        <div class="sb-fc sb-fc-rating">
          <div class="num">{{ section.settings.review_score }}</div>
          <div class="stars">★★★★★</div>
          <div class="cnt">{{ section.settings.review_count }}</div>
        </div>
        <div class="sb-fc sb-fc-ent">
          <div class="sb-fc-ent-ico">🩺</div>
          <div class="sb-fc-ent-txt"><strong>ENT Certified</strong><span>Safe for all-day wear</span></div>
        </div>

        {% if section.settings.hero_video_url != blank %}
          <video id="sbHeroVideo" class="sb-hero-video" autoplay muted loop playsinline>
            <source src="{{ section.settings.hero_video_url }}" type="video/mp4"/>
          </video>
        {% else %}
          <img id="sbHeroImg" class="sb-hero-img"
               src="{{ product.featured_image | image_url: width: 900 }}"
               alt="{{ product.title | escape }}"/>
        {% endif %}

        <div class="sb-thumbs">
          {% for image in product.images limit: 8 %}
            <img class="sb-thumb {% if forloop.first %}active{% endif %}"
