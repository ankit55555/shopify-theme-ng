<script>
  /* ── Variant data from Liquid ── */
  const SB_VARIANTS = {
    {% for variant in product.variants %}
    "{{ variant.option1 | downcase | remove: ' ' }}": {
      id: {{ variant.id }},
      img: "{% if variant.image %}{{ variant.image | image_url: width: 900 }}{% else %}{{ product.featured_image | image_url: width: 900 }}{% endif %}",
      thumb: "{% if variant.image %}{{ variant.image | image_url: width: 120 }}{% else %}{{ product.featured_image | image_url: width: 120 }}{% endif %}"
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  };
  let sbCurrentVariantId = {{ current_variant.id }};

  /* ── Cart actions ── */
  function sbAddToCart() {
    const btn = document.querySelector('.sb-btn-main');
    if (btn) { btn.disabled = true; btn.textContent = 'Adding…'; }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: sbCurrentVariantId, quantity: 1 }] })
    })
    .then(r => r.json())
    .then(() => { window.location.href = '/cart'; })
    .catch(() => {
      if (btn) { btn.disabled = false; btn.textContent = '{{ section.settings.btn_atc }}'; }
      alert('Could not add to cart. Please try again.');
    });
  }

  function sbBuyNow() {
    if (window.gokwikSDK && typeof window.gokwikSDK.triggerPopup === 'function') {
      window.gokwikSDK.triggerPopup({
        lineItems: [{ variant_id: sbCurrentVariantId, quantity: 1 }]
      });
    } else {
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: sbCurrentVariantId, quantity: 1 }] })
      })
      .then(() => { window.location.href = '/checkout'; })
      .catch(() => alert('Could not proceed to checkout. Please try again.'));
    }
  }


  /* ── Hero image / colour swap ── */
  function sbSwp(el, src) {
    const hero = document.getElementById('sbHeroImg');
    const video = document.getElementById('sbHeroVideo');
    if (hero) { hero.src = src; }
    if (video) { video.style.display = 'none'; if (hero) hero.style.display = 'block'; }
    document.querySelectorAll('.sb-thumb').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
  }

  function sbSetColor(c, el, variantId) {
    document.querySelectorAll('.sw').forEach(s => s.classList.remove('active'));
    el.classList.add('active');
    document.getElementById('sbSwName').textContent = c.charAt(0).toUpperCase() + c.slice(1);
    sbCurrentVariantId = variantId;
    const v = SB_VARIANTS[c];
    if (v && v.img) {
      sbSwp(null, v.img);
      document.querySelectorAll('.sb-thumb').forEach(t => {
        t.classList.toggle('active', t.src.includes(v.thumb.split('?')[0].split('/').pop().split('_')[0]));
      });
    }
  }

  /* ── Audience tabs ── */
  function sbTab(btn, id) {
    document.querySelectorAll('.sb-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.sb-panel').forEach(p => p.classList.remove('active'));
    btn.classList.add('active');
    const panel = document.getElementById(id);
    if (panel) panel.classList.add('active');
  }

  /* ── FAQ accordion ── */
  function sbFaq(btn) {
    const item = btn.parentElement;
    const open = item.classList.contains('open');
    document.querySelectorAll('.sb-faq-item').forEach(i => i.classList.remove('open'));
    if (!open) item.classList.add('open');
  }

  /* ── Scroll reveal ── */
  const sbObs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('v'); sbObs.unobserve(e.target); } });
  }, { threshold: 0.08 });
  document.querySelectorAll('.r').forEach(el => sbObs.observe(el));
</script>
  /* ── UGC carousel ── */
  (function() {
    const track = document.getElementById('sbUgcTrack');
    const dots  = document.getElementById('sbUgcDots');
    if (!track || !dots) return;
    const slides = track.querySelectorAll('.sb-ugc-slide');
    slides.forEach((_, i) => {
      const d = document.createElement('button');
      d.className = 'sb-ugc-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('aria-label', 'Slide ' + (i + 1));
      d.onclick = () => track.scrollTo({ left: slides[i].offsetLeft, behavior: 'smooth' });
      dots.appendChild(d);
    });
    track.addEventListener('scroll', () => {
      const center = track.scrollLeft + track.clientWidth / 2;
      let active = 0;
      slides.forEach((s, i) => { if (s.offsetLeft + s.offsetWidth / 2 <= center) active = i; });
      dots.querySelectorAll('.sb-ugc-dot').forEach((d, i) => d.classList.toggle('active', i === active));
    }, { passive: true });
  })();

  function sbUgcScroll(dir) {
    const track = document.getElementById('sbUgcTrack');
    const slide = track && track.querySelector('.sb-ugc-slide');
    if (track && slide) track.scrollBy({ left: dir * (slide.offsetWidth + 12), behavior: 'smooth' });
  }


