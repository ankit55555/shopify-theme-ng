{% liquid
  assign product = all_products['ngwehear']
  assign current_variant = product.selected_or_first_available_variant
  assign review_blocks = section.blocks | where: "type", "review"
%}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500&family=Lora:ital@1&display=swap" rel="stylesheet"/>

<style>
  :root {
    --navy:  #102442;
    --ocean: #39869b;
    --cyan:  #54c1c8;
    --frost: #E8F6F7;
    --chalk: #F4F4F2;
    --muted: #4a6070;
  }
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; }
  .sb-page { font-family: 'DM Sans', sans-serif; background: var(--chalk); color: var(--navy); -webkit-font-smoothing: antialiased; }
  .sb-page img { display: block; max-width: 100%; }
  .sb-page a { color: inherit; text-decoration: none; }
  .sb-page button { font-family: inherit; cursor: pointer; border: none; }

  .sb-wrap { max-width: 1160px; margin: 0 auto; padding: 0 clamp(20px,5vw,72px); }
  .sb-sec { padding: clamp(64px,8vw,104px) 0; }
  .sb-lbl { font-size: 11px; font-weight: 500; letter-spacing: .12em; text-transform: uppercase; color: var(--ocean); display: block; margin-bottom: 12px; }
  .sb-page h2 { font-size: clamp(26px,4vw,46px); font-weight: 500; line-height: 1.1; letter-spacing: -.02em; }
  .sb-page h2 em { font-style: normal; color: var(--ocean); }

  /* ANNOUNCEMENT */
  .sb-ann { background: var(--navy); color: rgba(255,255,255,.65); text-align: center; padding: 9px 16px; font-size: 13px; }
  .sb-ann strong { color: var(--cyan); }

  /* HERO */
  .sb-hero { background: var(--chalk); padding: clamp(48px,7vw,88px) 0 0; }
  .sb-hero-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(32px,5vw,72px); align-items: start; }
  .sb-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--frost); border: 1px solid rgba(84,193,200,.3); border-radius: 50px; padding: 5px 14px; font-size: 12px; font-weight: 500; color: var(--ocean); margin-bottom: 22px; }
  .sb-page h1 { font-size: clamp(34px,5vw,60px); font-weight: 500; line-height: 1.06; letter-spacing: -.025em; margin-bottom: 18px; }
  .sb-page h1 em { font-style: normal; color: var(--ocean); }
  .sb-hero-sub { font-size: clamp(15px,1.6vw,17px); color: var(--muted); line-height: 1.7; max-width: 460px; margin-bottom: 28px; }
  .sb-price-row { display: flex; align-items: baseline; gap: 10px; margin-bottom: 6px; }
  .sb-price-big { font-size: clamp(30px,3.5vw,40px); font-weight: 500; letter-spacing: -.02em; }
  .sb-price-note { font-size: 13px; color: #6a8090; }
.sb-color-row { display: flex; align-items: center; gap: 10px; margin-bottom: 22px; }
  .sb-color-lbl { font-size: 12px; color: #6a8090; text-transform: uppercase; letter-spacing: .06em; }
  .sw { width: 28px; height: 28px; border-radius: 50%; border: 2px solid transparent; cursor: pointer; transition: all .15s; }
  .sw.active { border-color: var(--ocean); box-shadow: 0 0 0 2px rgba(57,134,155,.2); }
  .sw-name { font-size: 13px; color: var(--muted); }
  .sb-cta-stack { display: flex; flex-direction: column; gap: 10px; margin-bottom: 24px; }
  .sb-btn-main { width: 100%; padding: 17px; background: var(--navy); color: #fff; border-radius: 12px; font-size: 16px; font-weight: 500; transition: all .2s; border: none; cursor: pointer; }
  .sb-btn-main:hover { background: #1d3a60; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(16,36,66,.18); }
  .sb-btn-main:disabled { opacity: .6; cursor: not-allowed; transform: none; }
  .sb-btn-sec { width: 100%; padding: 15px; background: var(--frost); color: var(--navy); border-radius: 12px; font-size: 15px; font-weight: 500; border: 1.5px solid rgba(16,36,66,.1); transition: all .2s; cursor: pointer; }
  .sb-btn-sec:hover { border-color: var(--ocean); background: #fff; }
  .sb-micro { display: flex; flex-wrap: wrap; gap: 14px; }
  .sb-mi { display: flex; align-items: center; gap: 5px; font-size: 12.5px; color: #6a8090; }

  /* Hero image side */
  .sb-hero-img-wrap { position: relative; }
  .sb-hero-img { width: 100%; border-radius: 16px; background: var(--frost); display: block; aspect-ratio: 1/1; object-fit: cover; }
  .sb-hero-video { width: 100%; border-radius: 16px; display: block; aspect-ratio: 1/1; object-fit: cover; }
  .sb-thumbs { display: flex; gap: 8px; margin-top: 10px; overflow-x: auto; }
  .sb-thumb { width: 58px; height: 58px; border-radius: 8px; object-fit: cover; flex-shrink: 0; cursor: pointer; border: 2px solid transparent; transition: border-color .15s; background: var(--frost); }
  .sb-thumb.active { border-color: var(--cyan); }
  .sb-fc { position: absolute; border-radius: 12px; box-shadow: 0 8px 32px rgba(16,36,66,.15); }
  .sb-fc-rating { top: 20px; right: -14px; background: var(--navy); color: #fff; padding: 12px 16px; text-align: center; min-width: 100px; }
  .sb-fc-rating .num { font-size: 22px; font-weight: 500; line-height: 1; }
  .sb-fc-rating .stars { color: var(--cyan); font-size: 12px; letter-spacing: 1px; margin: 3px 0; }
  .sb-fc-rating .cnt { font-size: 10px; color: rgba(255,255,255,.5); }
  .sb-fc-ent { bottom: 80px; left: -14px; background: #fff; padding: 12px 16px; display: flex; gap: 10px; align-items: center; min-width: 190px; }
  .sb-fc-ent-ico { width: 36px; height: 36px; border-radius: 9px; background: var(--frost); display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
  .sb-fc-ent-txt strong { display: block; font-size: 13px; }
  .sb-fc-ent-txt span { font-size: 11px; color: #6a8090; }

  @media(max-width:900px) { .sb-hero-grid { grid-template-columns: 1fr; } .sb-hero-img-wrap { order: -1; } .sb-fc { display: none; } }

  /* PROOF STRIP */
  .sb-proof { background: var(--navy); padding: 22px 0; }
  .sb-proof-inner { display: flex; justify-content: space-between; align-items: center; gap: 16px; flex-wrap: wrap; }
  .sb-pi { display: flex; align-items: center; gap: 10px; color: #fff; flex: 1; min-width: 130px; }
  .sb-pi strong { display: block; font-size: 16px; color: var(--cyan); font-weight: 500; }
  .sb-pi span { font-size: 11.5px; color: rgba(255,255,255,.5); }
  .sb-pd { width: 1px; height: 30px; background: rgba(255,255,255,.1); }
  @media(max-width:680px) { .sb-pd { display: none; } .sb-pi { min-width: calc(50% - 8px); } }

  /* FOUR PILLARS */
  .sb-pillars { background: #fff; }
  .sb-pillars-head { text-align: center; margin-bottom: 48px; }
  .sb-pillars-head p { color: var(--muted); font-size: 16px; margin-top: 10px; max-width: 480px; margin-left: auto; margin-right: auto; }
  .sb-pillars-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 20px; }
  .sb-pillar { background: var(--chalk); border-radius: 14px; padding: 28px 22px; transition: all .2s; border: 1.5px solid transparent; }
  .sb-pillar:hover { border-color: rgba(84,193,200,.3); background: var(--frost); }
  .sb-pillar .ic { font-size: 30px; margin-bottom: 14px; }
  .sb-pillar strong { display: block; font-size: 16px; font-weight: 500; color: var(--navy); margin-bottom: 8px; }
  .sb-pillar p { font-size: 13.5px; color: var(--muted); line-height: 1.65; }
  @media(max-width:900px) { .sb-pillars-grid { grid-template-columns: 1fr 1fr; } }
  @media(max-width:500px) { .sb-pillars-grid { grid-template-columns: 1fr; } }

  /* NG × WEHEAR PARTNERSHIP */
  .sb-partner { background: var(--navy); }
  .sb-partner .sb-lbl { color: var(--cyan); }
  .sb-partner h2 { color: #fff; }
  .sb-partner-lead { color: rgba(255,255,255,.55); font-size: 16px; line-height: 1.65; margin: 16px 0 32px; max-width: 480px; }
  .sb-partner-grid { display: grid; grid-template-columns: 1fr; max-width: 680px; }
  .sb-partner-cards { display: flex; flex-direction: column; gap: 14px; margin-bottom: 28px; }
  .sb-pcard { display: flex; gap: 16px; background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.1); border-radius: 12px; padding: 18px 20px; align-items: flex-start; }
  .sb-pcard-mark { width: 38px; height: 38px; border-radius: 9px; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 700; letter-spacing: .04em; flex-shrink: 0; margin-top: 2px; }
  .sb-pcard-mark.ng, .sb-pcard-mark.wh { background: transparent; padding: 0; }
  .sb-pcard strong { display: block; font-size: 15px; font-weight: 500; color: #fff; margin-bottom: 7px; }
  .sb-pcard p { font-size: 13.5px; color: rgba(255,255,255,.45); line-height: 1.65; }
  .shark-badge-inline { font-size: 11px; background: rgba(230,51,41,.18); color: #ff6b5b; border-radius: 4px; padding: 2px 7px; margin-left: 6px; font-weight: 500; }
  .sb-partner-quote { border-left: 3px solid var(--cyan); padding-left: 18px; font-size: 15px; color: rgba(255,255,255,.55); line-height: 1.7; font-style: italic; }
  .sb-partner-quote cite { display: block; margin-top: 10px; font-size: 12px; font-style: normal; color: var(--cyan); letter-spacing: .04em; }
  .sb-partner-img-box { position: relative; background: rgba(255,255,255,.05); border-radius: 16px; overflow: hidden; margin-bottom: 20px; }
  .sb-partner-img-box img { width: 100%; display: block; }
  .sb-partner-stamp { position: absolute; bottom: 0; left: 0; right: 0; background: linear-gradient(transparent, rgba(16,36,66,.88)); padding: 36px 20px 18px; }
  .ps-line1 { display: block; font-size: 10px; color: var(--cyan); text-transform: uppercase; letter-spacing: .1em; font-weight: 500; }
  .ps-line2 { display: block; font-size: 22px; font-weight: 500; color: #fff; margin: 2px 0; }
  .ps-line3 { display: block; font-size: 11px; color: rgba(255,255,255,.4); }
  .sb-partner-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 12px; }
  .sb-pstat { background: rgba(255,255,255,.06); border-radius: 10px; padding: 16px 14px; text-align: center; }
  .sb-pstat strong { display: block; font-size: 26px; font-weight: 500; color: var(--cyan); line-height: 1; margin-bottom: 5px; }
  .sb-pstat span { font-size: 11.5px; color: rgba(255,255,255,.4); line-height: 1.4; }
  @media(max-width:900px) { .sb-partner-grid { grid-template-columns: 1fr; } }

  /* WHO IT'S FOR */
  .sb-audience { background: var(--chalk); }
  .sb-audience-head { text-align: center; margin-bottom: 40px; }
  .sb-audience-head p { color: var(--muted); margin-top: 10px; font-size: 16px; }
  .sb-tab-bar { display: flex; background: var(--frost); border-radius: 12px; padding: 4px; max-width: 680px; margin: 0 auto 40px; overflow-x: auto; gap: 2px; }
  .sb-tab { flex: 1; padding: 10px 12px; border-radius: 9px; font-size: 13px; font-weight: 500; color: var(--muted); background: transparent; cursor: pointer; white-space: nowrap; transition: all .2s; border: none; }
  .sb-tab.active { background: var(--navy); color: #fff; }
  .sb-panel { display: none; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .sb-panel.active { display: grid; }
  .sb-panel-img { border-radius: 14px; overflow: hidden; background: var(--frost); aspect-ratio: 4/3; }
  .sb-panel-img img { width: 100%; height: 100%; object-fit: cover; }
  .panel-eyebrow { font-family: 'Lora', serif; font-style: italic; font-size: 15px; color: var(--ocean); display: block; margin-bottom: 10px; }
  .sb-panel h3 { font-size: clamp(20px,2.8vw,32px); font-weight: 500; line-height: 1.2; margin-bottom: 16px; }
  .sb-panel-scene { font-size: 14.5px; color: var(--muted); line-height: 1.75; margin-bottom: 18px; font-style: italic; border-left: 3px solid var(--cyan); padding-left: 14px; }
  .sb-panel-body { font-size: 14.5px; line-height: 1.75; margin-bottom: 20px; color: var(--navy); }
  .sb-panel-pts { display: flex; flex-direction: column; gap: 9px; }
  .sb-pt { display: flex; gap: 9px; align-items: flex-start; font-size: 14px; }
  .sb-pt-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--cyan); flex-shrink: 0; margin-top: 6px; }
  @media(max-width:900px) { .sb-panel.active { grid-template-columns: 1fr; } .sb-panel-img { order: -1; } }
  @media(max-width:560px) { .sb-tab-bar { flex-wrap: wrap; max-width: 100%; } .sb-tab { flex: 1 1 calc(50% - 4px); } }

  /* COMPARISON */
  .sb-cmp { background: var(--frost); }
  .sb-cmp-head { margin-bottom: 36px; }
  .sb-cmp-head p { color: var(--muted); font-size: 16px; margin-top: 10px; max-width: 520px; }
  .sb-cmp-table { background: #fff; border-radius: 14px; overflow: hidden; box-shadow: 0 4px 24px rgba(16,36,66,.07); }
  .sb-cmp-row { display: grid; grid-template-columns: 1.5fr 1fr 1fr; border-bottom: 1px solid rgba(16,36,66,.06); }
  .sb-cmp-row:last-child { border-bottom: none; }
  .sb-cmp-row.head-row { font-size: 13px; font-weight: 500; border-bottom: 2px solid rgba(16,36,66,.08); }
  .cc { padding: 15px 20px; font-size: 13.5px; display: flex; align-items: center; }
  .cc:first-child { background: var(--chalk); font-weight: 500; font-size: 14px; }
  .cc:nth-child(2) { justify-content: center; color: var(--muted); }
  .cc:nth-child(3) { justify-content: center; background: rgba(16,36,66,.02); }
  .head-row .cc:nth-child(3) { background: var(--navy); color: #fff; justify-content: center; flex-direction: column; align-items: center; gap: 2px; }
  .head-row .cc:nth-child(3) small { color: var(--cyan); font-size: 11px; font-weight: 400; }
  .good { color: #2e7d32; font-size: 13px; font-weight: 500; }
  .bad  { color: #b71c1c; font-size: 13px; }
  .ck { color: #2e7d32; font-size: 16px; margin-right: 4px; }
  .xk { color: #c62828; font-size: 16px; }
  @media(max-width:600px) {
    .sb-cmp-table { overflow-x: auto; -webkit-overflow-scrolling: touch; }
    .sb-cmp-row { grid-template-columns: 140px 130px 130px; min-width: 400px; }
    .cc { padding: 11px 12px; font-size: 12px; }
    .cc:first-child { font-size: 12px; }
    .sb-cmp-row.head-row { font-size: 11px; }
  }

  /* REVIEWS */
  .sb-revs { background: #fff; }
  .sb-revs-head { text-align: center; margin-bottom: 44px; }
  .sb-revs-head p { color: var(--muted); margin-top: 8px; font-size: 16px; }
  .sb-rev-sum { display: flex; align-items: center; justify-content: center; gap: 32px; margin-bottom: 36px; flex-wrap: wrap; }
  .sb-rev-num { font-size: 52px; font-weight: 500; letter-spacing: -.03em; line-height: 1; }
  .sb-rev-stars { color: #f5a623; font-size: 20px; letter-spacing: 3px; margin: 5px 0; }
  .sb-rev-ct { font-size: 12px; color: #6a8090; }
  .sb-rev-bars { max-width: 240px; flex: 1; }
  .sb-br { display: flex; align-items: center; gap: 8px; margin-bottom: 5px; }
  .sb-br-l { font-size: 11.5px; color: #6a8090; width: 24px; }
  .sb-br-t { flex: 1; height: 5px; background: rgba(16,36,66,.08); border-radius: 3px; overflow: hidden; }
  .sb-br-f { height: 100%; background: var(--ocean); border-radius: 3px; }
  .sb-br-n { font-size: 11.5px; color: #6a8090; width: 18px; }
  .sb-rev-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; }
  .sb-rc { background: var(--chalk); border-radius: 12px; padding: 22px; }
  .sb-rc .stars { color: #f5a623; font-size: 13px; letter-spacing: 1px; margin-bottom: 10px; }
  .sb-rc p { font-size: 14px; line-height: 1.7; margin-bottom: 14px; }
  .sb-rc-meta { display: flex; align-items: center; gap: 9px; }
  .sb-rc-av { width: 30px; height: 30px; border-radius: 50%; background: var(--frost); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 500; color: var(--ocean); flex-shrink: 0; }
  .sb-rc-name { font-size: 12.5px; font-weight: 500; }
  .sb-rc-loc { font-size: 11px; color: #6a8090; }
  .sb-rc-tag { margin-top: 10px; display: inline-block; background: var(--frost); color: var(--ocean); font-size: 11px; font-weight: 500; padding: 3px 10px; border-radius: 50px; }
  @media(max-width:760px) { .sb-rev-grid { grid-template-columns: 1fr; } }

  /* FAQ */
  .sb-faq { background: var(--chalk); }
  .sb-faq-wrap { max-width: 680px; margin: 0 auto; }
  .sb-faq-head { text-align: center; margin-bottom: 32px; }
  .sb-faq-item { background: #fff; border-radius: 10px; margin-bottom: 8px; overflow: hidden; border: 1px solid rgba(16,36,66,.07); }
  .sb-faq-q { width: 100%; background: none; padding: 18px 20px; display: flex; justify-content: space-between; align-items: center; font-size: 14.5px; font-weight: 500; text-align: left; gap: 14px; transition: background .15s; color: var(--navy); cursor: pointer; border: none; }
  .sb-faq-q:hover { background: var(--frost); }
  .sb-faq-ic { width: 22px; height: 22px; border-radius: 50%; background: var(--frost); display: flex; align-items: center; justify-content: center; font-size: 15px; color: var(--ocean); flex-shrink: 0; transition: transform .2s, background .2s; }
  .sb-faq-item.open .sb-faq-ic { transform: rotate(45deg); background: var(--navy); color: #fff; }
  .sb-faq-a { max-height: 0; overflow: hidden; transition: max-height .3s ease, padding .2s; padding: 0 20px; }
  .sb-faq-item.open .sb-faq-a { max-height: 300px; padding: 0 20px 18px; }
  .sb-faq-a p { font-size: 14px; color: var(--muted); line-height: 1.75; }

  /* FINAL CTA */
  .sb-final { background: var(--navy); padding: clamp(72px,9vw,112px) 0; text-align: center; position: relative; overflow: hidden; }
  .sb-final::before { content: ''; position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 500px; height: 500px; background: radial-gradient(circle, rgba(84,193,200,.08) 0%, transparent 65%); pointer-events: none; }
  .sb-final-inner { position: relative; z-index: 1; max-width: 560px; margin: 0 auto; }
  .sb-final h2 { color: #fff; margin-bottom: 14px; }
  .sb-final h2 em { color: var(--cyan); font-style: normal; }
  .sb-final p { color: rgba(255,255,255,.55); font-size: 16px; line-height: 1.65; margin-bottom: 30px; }
  .sb-final-price { font-size: clamp(34px,5vw,50px); font-weight: 500; color: #fff; letter-spacing: -.025em; margin-bottom: 4px; }
  .sb-final-price span { color: var(--cyan); }
  .sb-final-pre { font-size: 13.5px; color: rgba(255,255,255,.4); margin-bottom: 28px; }
  .sb-final-pre strong { color: var(--cyan); }
  .sb-final-btns { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin-bottom: 28px; }
  .sb-fbm { padding: 17px 36px; border-radius: 50px; font-size: 15px; font-weight: 500; background: var(--cyan); color: var(--navy); border: none; cursor: pointer; transition: all .2s; }
  .sb-fbm:hover { background: #43b0b7; transform: translateY(-1px); }
  .sb-fbo { padding: 17px 36px; border-radius: 50px; font-size: 15px; font-weight: 500; background: transparent; color: #fff; border: 1.5px solid rgba(255,255,255,.3); cursor: pointer; transition: all .2s; }
  .sb-fbo:hover { border-color: #fff; }
  .sb-final-gs { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }
  .sb-fg { font-size: 12.5px; color: rgba(255,255,255,.4); display: flex; align-items: center; gap: 5px; }

  /* UGC CAROUSEL */
  .sb-ugc { background: var(--chalk); padding: clamp(40px,5vw,64px) 0; overflow: hidden; }
  .sb-ugc-carousel { position: relative; margin-top: 28px; }
  .sb-ugc-track { display: flex; flex-wrap: nowrap; overflow-x: scroll; scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch; scrollbar-width: none; -ms-overflow-style: none; gap: 12px; }
  .sb-ugc-track::-webkit-scrollbar { display: none; }
  .sb-ugc-slide { flex: 0 0 calc(33.333% - 8px); flex-shrink: 0; scroll-snap-align: start; border-radius: 14px; overflow: hidden; aspect-ratio: 9/16; background: var(--frost); }
  .sb-ugc-slide video { width: 100%; height: 100%; object-fit: cover; display: block; }
  .sb-ugc-dots { display: flex; justify-content: center; gap: 6px; margin-top: 16px; }
  .sb-ugc-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(16,36,66,.2); border: none; cursor: pointer; padding: 0; transition: all .25s; }
  .sb-ugc-dot.active { background: var(--ocean); width: 24px; border-radius: 4px; }
  .sb-ugc-nav { position: absolute; top: 50%; transform: translateY(-50%); width: 38px; height: 38px; border-radius: 50%; background: #fff; border: 1.5px solid rgba(16,36,66,.1); box-shadow: 0 2px 10px rgba(16,36,66,.12); display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 2; font-size: 18px; color: var(--navy); line-height: 1; }
  .sb-ugc-prev { left: 0; }
  .sb-ugc-next { right: 0; }
  @media(max-width:760px) { .sb-ugc-slide { flex: 0 0 calc(50% - 6px); } .sb-ugc-nav { display: none; } }
  @media(max-width:480px) { .sb-ugc-slide { flex: 0 0 82%; } }


  /* Shark Tank logo badge */
