  .st-stname { font-size: 13px; font-weight: 900; background: linear-gradient(180deg, #5bbfdb 0%, #1565c0 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; font-style: italic; letter-spacing: -.01em; line-height: 1.1; }
