{%- comment -%}
  NG Feature Grid (Desktop reference)
  Layout: Top row has 2 large cards, Bottom row has 3 medium cards.
  Add exactly five Feature Card blocks for the intended layout.
{%- endcomment -%}

{{ 'section-ng-feature-grid.css' | asset_url | stylesheet_tag }}

{%- assign _id = section.id -%}
{%- liquid
  assign stt_layout = section.settings.layout
  if stt_layout == 't4s-se-container'
    assign html_layout = '<div class="t4s-container">__</div></div>' | split: '__'
  elsif stt_layout == 't4s-container-wrap'
    assign html_layout = '<div class="t4s-container">__</div>' | split: '__'
  else
    assign html_layout = '__' | split: '__'
  endif
-%}
<section id="ng-feature-grid-{{ _id }}" class="ng-feature-grid"
  style="--ng-fg-padding: {{ section.settings.section_padding | default: 48 }}px; --ng-fg-bg: {{ section.settings.background | default: 'transparent' }}; --ng-fg-title-color: {{ section.settings.title_color | default: '#111111' }}; --ng-fg-text-color: {{ section.settings.text_color | default: '#ffffff' }}; --ng-fg-gap: {{ section.settings.gap | default: 20 }}px;">
  {{- html_layout[0] -}}
    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="ng-fg-header">
      {%- if section.settings.heading != blank -%}
        <h2 class="ng-fg-heading" style="color: var(--ng-fg-title-color);">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="ng-fg-subheading" style="color: var(--ng-fg-title-color);">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>
    {%- endif -%}

    <div class="ng-fg-grid" style="background: var(--ng-fg-bg); padding: var(--ng-fg-padding);">
      <div class="ng-fg-row ng-fg-row--top" style="gap: var(--ng-fg-gap);">
        {%- for block in section.blocks limit: 2 -%}
          {%- render 'ng-fg-card', block: block, placement: 'top' -%}
        {%- endfor -%}
      </div>
      <div class="ng-fg-row ng-fg-row--bottom" style="gap: var(--ng-fg-gap);">
        {%- for block in section.blocks offset: 2 limit: 3 -%}
          {%- render 'ng-fg-card', block: block, placement: 'bottom' -%}
        {%- endfor -%}
      </div>
    </div>
  {{- html_layout[1] -}}
</section>

{%- comment -%}
  Pseudo-snippet renderer: we define a throwaway snippet name and include it through Liquid's runtime rendering.
{%- endcomment -%}
{% schema %}
{
  "name": "NG Feature Grid",
  "tag": "section",
  "class": "section ng-feature-grid-section",
  "settings": [
    { "type": "select", "id": "layout", "label": "Layout", "default": "t4s-container-wrap", "options": [
      { "value": "t4s-se-container", "label": "Container" },
      { "value": "t4s-container-wrap", "label": "Wrapped container" },
      { "value": "t4s-container-fluid", "label": "Full width" }
    ]},
    { "type": "text", "id": "heading", "label": "Heading", "default": "Product Features" },
    { "type": "text", "id": "subheading", "label": "Subheading", "default": "Explore highlights" },
    { "type": "color", "id": "title_color", "label": "Heading color", "default": "#111111" },
    { "type": "color", "id": "text_color", "label": "Card text color", "default": "#ffffff" },
    { "type": "color", "id": "background", "label": "Section background", "default": "#f6f7f8" },
    { "type": "range", "id": "section_padding", "label": "Section padding (px)", "default": 24, "min": 0, "max": 96, "step": 4 },
    { "type": "range", "id": "gap", "label": "Grid gap (px)", "default": 16, "min": 0, "max": 48, "step": 2 },
    { "type": "paragraph", "content": "Add 5 Feature Card blocks. The first 2 appear on the top row; the next 3 appear on the bottom row (desktop)." }
  ],
  "blocks": [
    {
      "type": "feature_card",
      "name": "Feature Card",
      "limit": 5,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature title" },
        { "type": "text", "id": "subtitle", "label": "Subtitle" },
        { "type": "range", "id": "title_size", "label": "Title size (px)", "min": 18, "max": 56, "step": 1, "default": 36 },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "text", "id": "cta_label", "label": "CTA label", "default": "Know more" },
        { "type": "select", "id": "text_align", "label": "Text alignment", "default": "left", "options": [
          {"value": "left", "label": "Left"},
          {"value": "center", "label": "Center"},
          {"value": "right", "label": "Right"}
        ]},
        { "type": "range", "id": "overlay_strength", "label": "Overlay strength (%)", "min": 0, "max": 100, "step": 5, "default": 60 }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    { "name": "NG Feature Grid", "category": "Image" }
  ]
}
{% endschema %}

{% stylesheet %}
/* No inline CSS. See section-ng-feature-grid.css */
{% endstylesheet %}

{% javascript %}
{% endjavascript %}


