<!-- sections/responsive-video.liquid -->
<div class="vid_section_responsive-video-section">
  <div class="vid_section_video-container">
    <!-- Desktop Video -->
    <video 
      class="vid_section_desktop-video"
      autoplay 
      muted 
      loop 
      playsinline
      preload="metadata"
      poster="{{ section.settings.desktop_poster | img_url: '1920x1080' }}"
    >
      <source src="{{ section.settings.desktop_video_url }}" type="video/mp4">
      Your browser does not support the video tag.
    </video>
    
    <!-- Mobile Video -->
    <video 
      class="vid_section_mobile-video"
      autoplay 
      muted 
      loop 
      playsinline
      preload="metadata"
      poster="{{ section.settings.mobile_poster | img_url: '750x1334' }}"
    >
      <source src="{{ section.settings.mobile_video_url }}" type="video/mp4">
      Your browser does not support the video tag.
    </video>
    
    <!-- Optional overlay content -->
    {% if section.settings.show_overlay %}
      <div class="vid_section_video-overlay">
        <div class="vid_section_overlay-content">
          {% if section.settings.overlay_heading != blank %}
            <h2 class="vid_section_overlay-heading">{{ section.settings.overlay_heading }}</h2>
          {% endif %}
          {% if section.settings.overlay_text != blank %}
            <p class="vid_section_overlay-text">{{ section.settings.overlay_text }}</p>
          {% endif %}
          {% if section.settings.overlay_button_text != blank and section.settings.overlay_button_url != blank %}
            <a href="{{ section.settings.overlay_button_url }}" class="vid_section_overlay-button btn">
              {{ section.settings.overlay_button_text }}
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}
  </div>
</div>

<style>
  .vid_section_responsive-video-section {
    position: relative;
    width: 100%;
    overflow: hidden;
  }
  
  .vid_section_video-container {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 400px;
  }
  
  .vid_section_desktop-video,
  .vid_section_mobile-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  
  /* Show desktop video by default, hide mobile */
  .vid_section_desktop-video {
    display: block;
  }
  
  .vid_section_mobile-video {
    display: none;
  }
  
  /* Mobile breakpoint - show mobile video, hide desktop */
  @media screen and (max-width: 768px) {
    .vid_section_desktop-video {
      display: none;
    }
    
    .vid_section_mobile-video {
      display: block;
      {% comment %} object-fit: contain; {% endcomment %}
    }
    
    .vid_section_video-container {
      height: 58vh !important;
      min-height: 300px;
    }
  }
  
  /* Overlay styles */
  .vid_section_video-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
  }
  
  .vid_section_overlay-content {
    text-align: center;
    color: white;
    max-width: 600px;
    padding: 2rem;
  }
  
  .vid_section_overlay-heading {
    font-size: 3rem;
    font-weight: bold;
    margin-bottom: 1rem;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
  }
  
  .vid_section_overlay-text {
    font-size: 1.2rem;
    margin-bottom: 2rem;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.5);
  }
  
  .vid_section_overlay-button {
    display: inline-block;
    padding: 12px 24px;
    background-color: #ffffff;
    color: #000000;
    text-decoration: none;
    border-radius: 4px;
    font-weight: bold;
    transition: background-color 0.3s ease;
  }
  
  .vid_section_overlay-button:hover {
    background-color: #f0f0f0;
    color: #000000;
  }
  
  /* Responsive text sizing */
  @media screen and (max-width: 768px) {
    .vid_section_overlay-content {
      padding: 1rem;
    }
    
    .vid_section_overlay-heading {
      font-size: 2rem;
    }
    
    .vid_section_overlay-text {
      font-size: 1rem;
    }
  }
  
  /* Tablet adjustments */
  @media screen and (min-width: 769px) and (max-width: 1024px) {
    .vid_section_video-container {
      height: 80vh;
    }
    
    .vid_section_overlay-heading {
      font-size: 2.5rem;
    }
  }
  
  /* Loading and fallback styles */
  .vid_section_desktop-video,
  .vid_section_mobile-video {
    background-color: #f5f5f5;
  }
  
  /* Ensure videos don't exceed container */
  @media screen and (max-width: 480px) {
    .vid_section_video-container {
      height: 100vh;
      /* min-height: 250px; */
    }
  }
</style>

{% schema %}
{
  "name": "Responsive Video Section",
  "tag": "section",
  "class": "section-responsive-video",
  "settings": [
    {
      "type": "text",
      "id": "desktop_video_url",
      "label": "Desktop Video URL",
      "default": "https://cdn.shopify.com/videos/c/o/v/c07d80e2214f43f4921eaba089d1097c.mp4"
    },
    {
      "type": "text",
      "id": "mobile_video_url", 
      "label": "Mobile Video URL",
      "default": "https://cdn.shopify.com/videos/c/o/v/aebc3e8e44144e9d81a9803acee62196.mp4"
    },
    {
      "type": "image_picker",
      "id": "desktop_poster",
      "label": "Desktop Poster Image (Optional)",
      "info": "Thumbnail shown before video loads"
    },
    {
      "type": "image_picker", 
      "id": "mobile_poster",
      "label": "Mobile Poster Image (Optional)",
      "info": "Thumbnail shown before video loads"
    },
    {
      "type": "header",
      "content": "Overlay Content"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show overlay content",
      "default": false
    },
    {
      "type": "text",
      "id": "overlay_heading",
      "label": "Overlay Heading"
    },
    {
      "type": "textarea",
      "id": "overlay_text", 
      "label": "Overlay Text"
    },
    {
      "type": "text",
      "id": "overlay_button_text",
      "label": "Button Text"
    },
    {
      "type": "text",
      "id": "overlay_button_url",
      "label": "Button URL"
    }
  ],
  "presets": [
    {
      "name": "Responsive Video",
      "settings": {
        "desktop_video_url": "https://cdn.shopify.com/videos/c/o/v/c07d80e2214f43f4921eaba089d1097c.mp4",
        "mobile_video_url": "https://cdn.shopify.com/videos/c/o/v/aebc3e8e44144e9d81a9803acee62196.mp4"
      }
    }
  ]
}
{% endschema %}