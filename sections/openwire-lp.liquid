{% liquid
  # Product resolution: section setting → template context (product templates) → handle fallback
  assign product = section.settings.product | default: product
  if product == blank
    assign product = all_products['openwire']
  endif
  assign current_variant = product.selected_or_first_available_variant
  assign review_blocks = section.blocks | where: "type", "review"
  assign faq_blocks = section.blocks | where: "type", "faq"
%}

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet"/>

<style>
  .ow-page {
    --ow-ink:    #1b2b3a;
    --ow-muted:  #5c6f7e;
    --ow-teal:   #1f8a96;
    --ow-teal-d: #16707a;
    --ow-mist:   #eef6f7;
    --ow-bg:     #ffffff;
    --ow-bg-alt: #f7fafb;
    --ow-line:   #e4ebee;
  }
  .ow-page, .ow-page *, .ow-page *::before, .ow-page *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .ow-page { font-family: 'Poppins', sans-serif; background: var(--ow-bg); color: var(--ow-ink); -webkit-font-smoothing: antialiased; overflow-x: hidden; }
  .ow-page img { display: block; max-width: 100%; }
  .ow-page a { color: inherit; text-decoration: none; }
  .ow-page button { font-family: inherit; cursor: pointer; border: none; background: none; }

  .ow-wrap { max-width: 1080px; margin: 0 auto; padding: 0 clamp(18px,5vw,48px); }
  .ow-sec { padding: clamp(48px,8vw,96px) 0; }
  .ow-lbl { font-size: 11px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; color: var(--ow-teal); display: block; margin-bottom: 12px; }
  .ow-page h2 { font-size: clamp(26px,4.6vw,42px); font-weight: 600; line-height: 1.14; letter-spacing: -.02em; }

  /* ── HERO / PDP ── */
  .ow-hero { background: linear-gradient(180deg, var(--ow-mist) 0%, var(--ow-bg) 100%); padding-top: clamp(20px,4vw,56px); }
  .ow-hero-grid { display: grid; grid-template-columns: 1.05fr 1fr; grid-template-rows: auto 1fr; grid-template-areas: "gallery title" "gallery info"; column-gap: clamp(28px,5vw,56px); align-items: start; padding-bottom: clamp(36px,5vw,72px); }
  .ow-title { grid-area: title; }
  .ow-gallery { grid-area: gallery; }
  .ow-info { grid-area: info; }
  .ow-badge { display: inline-block; background: #fff; border: 1px solid var(--ow-line); border-radius: 50px; padding: 6px 14px; font-size: 12px; font-weight: 500; color: var(--ow-teal); margin-bottom: 14px; }
  .ow-page h1 { font-size: clamp(26px,4.6vw,40px); font-weight: 600; line-height: 1.12; letter-spacing: -.02em; margin-bottom: 8px; }
  .ow-sub { font-size: clamp(13.5px,1.5vw,15.5px); color: var(--ow-muted); line-height: 1.6; margin-bottom: 16px; }

  .ow-price { display: flex; align-items: baseline; gap: 10px; margin: 4px 0 16px; flex-wrap: wrap; }
  .ow-price b { font-size: clamp(28px,3.5vw,34px); font-weight: 600; letter-spacing: -.02em; }
  .ow-price s { font-size: 16px; color: var(--ow-muted); font-weight: 400; }
  .ow-price span { font-size: 12.5px; color: var(--ow-muted); }

  .ow-trust-cards { display: grid; grid-template-columns: repeat(3,1fr); gap: 10px; margin-bottom: 18px; }
  .ow-tcard { background: #fff; border: 1px solid var(--ow-line); border-radius: 12px; padding: 12px 8px; text-align: center; }
  .ow-tcard .ic { display: block; font-size: 18px; margin-bottom: 6px; }
  .ow-tcard b { display: block; font-size: 12px; font-weight: 600; line-height: 1.25; }
  .ow-tcard span { font-size: 10.5px; color: var(--ow-muted); }

  .ow-cta-row { display: flex; gap: 10px; flex-wrap: wrap; margin: 0; }
  .ow-cta-row button { flex: 1 1 150px; text-align: center; }
  /* Beat the theme's 'gokwik' snippet styles on #gokwik-buy-now (its own bg / uppercase / 100% width) */
  .ow-page #gokwik-buy-now.ow-btn-buy { width: auto; height: auto; text-transform: none; line-height: normal; margin-bottom: 0; }
  .ow-page #gokwik-buy-now.ow-btn-buy.disabled { opacity: 1; cursor: pointer; }
  .ow-btn-buy[disabled], .ow-btn-cart[disabled] { opacity: .55; cursor: not-allowed; }
  /* SafeBuds button palette; !important guards against the theme's global button styles */
  .ow-page .ow-btn-buy { background: #102442 !important; color: #ffffff !important; border: none !important; padding: 15px 32px; border-radius: 12px; font-size: 15.5px; font-weight: 600; transition: all .2s; cursor: pointer; }
  .ow-page .ow-btn-buy:hover { background: #1d3a60 !important; color: #ffffff !important; transform: translateY(-1px); box-shadow: 0 6px 20px rgba(16,36,66,.18); }
  .ow-page .ow-btn-buy:disabled { opacity: .6; cursor: not-allowed; transform: none; }
  .ow-page .ow-btn-cart { background: #E8F6F7 !important; color: #102442 !important; border: 1.5px solid rgba(16,36,66,.1) !important; padding: 14px 32px; border-radius: 12px; font-size: 15.5px; font-weight: 600; transition: all .2s; cursor: pointer; }
  .ow-page .ow-btn-cart:hover { background: #ffffff !important; color: #102442 !important; border-color: var(--ow-teal) !important; }
  .ow-page .ow-btn-cart:disabled { opacity: .6; cursor: not-allowed; }

  .ow-ht { display: inline-flex; align-items: center; gap: 6px; font-size: 12px; font-weight: 500; color: var(--ow-muted); background: #fff; border: 1px solid var(--ow-line); border-radius: 50px; padding: 6px 12px; }

  .ow-stage { background: #fff; border: 1px solid var(--ow-line); border-radius: 20px; padding: clamp(12px,2vw,20px); box-shadow: 0 20px 50px rgba(27,43,58,.08); }
  .ow-stage img { width: 100%; aspect-ratio: 1/1; object-fit: contain; border-radius: 12px; background: #fff; }
  .ow-thumbs { display: flex; gap: 8px; margin-top: 12px; justify-content: center; flex-wrap: wrap; }
  .ow-thumb { width: 48px; height: 48px; border-radius: 10px; object-fit: cover; cursor: pointer; border: 2px solid var(--ow-line); transition: border-color .15s; background: #fff; }
  .ow-thumb.active { border-color: var(--ow-teal); }

  @media(max-width:860px){
    .ow-hero-grid { grid-template-columns: 1fr; grid-template-rows: auto; grid-template-areas: "title" "gallery" "info"; row-gap: 16px; }
    .ow-gallery { max-width: 460px; margin: 0 auto; width: 100%; }
  }

  /* ── SPEC STRIP ── */
  .ow-specs { border-top: 1px solid var(--ow-line); border-bottom: 1px solid var(--ow-line); background: var(--ow-bg); padding: 22px 0; }
  .ow-specs-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; text-align: center; }
  .ow-sp .n { font-size: clamp(20px,3vw,28px); font-weight: 600; color: var(--ow-teal); line-height: 1; }
  .ow-sp .t { font-size: 12px; color: var(--ow-muted); margin-top: 6px; }
  @media(max-width:640px){ .ow-specs-grid { grid-template-columns: repeat(2,1fr); gap: 18px 12px; } }

  /* ── BENEFITS ── */
  .ow-why { background: var(--ow-bg-alt); }
  .ow-why-head { text-align: center; max-width: 560px; margin: 0 auto 44px; }
  .ow-why-head p { color: var(--ow-muted); font-size: 15.5px; margin-top: 12px; line-height: 1.6; }
  .ow-bgrid { display: grid; grid-template-columns: repeat(4,1fr); gap: 16px; }
  .ow-bcard { background: #fff; border: 1px solid var(--ow-line); border-radius: 16px; padding: 26px 22px; }
  .ow-bcard .ic { width: 44px; height: 44px; border-radius: 12px; background: var(--ow-mist); display: flex; align-items: center; justify-content: center; margin-bottom: 16px; }
  .ow-bcard h3 { font-size: 16px; font-weight: 600; margin-bottom: 8px; line-height: 1.3; }
  .ow-bcard p { font-size: 13px; color: var(--ow-muted); line-height: 1.6; }
  @media(max-width:900px){ .ow-bgrid { grid-template-columns: 1fr 1fr; } }
  @media(max-width:520px){ .ow-bgrid { grid-template-columns: 1fr; } }

  /* ── SHOWCASE ── */
  .ow-show-grid { display: grid; grid-template-columns: 1fr 1fr; gap: clamp(28px,5vw,56px); align-items: center; }
  .ow-show-lead { font-size: 15.5px; color: var(--ow-muted); line-height: 1.7; max-width: 440px; margin: 16px 0 22px; }
  .ow-show-pts { display: flex; flex-direction: column; gap: 12px; }
  .ow-spt { display: flex; gap: 11px; align-items: center; font-size: 14px; font-weight: 500; }
  .ow-spt .dot { width: 24px; height: 24px; border-radius: 50%; background: var(--ow-mist); display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ow-show-img { border-radius: 20px; overflow: hidden; border: 1px solid var(--ow-line); box-shadow: 0 20px 50px rgba(27,43,58,.08); }
  .ow-show-img img { width: 100%; }
  @media(max-width:820px){ .ow-show-grid { grid-template-columns: 1fr; } .ow-show-img { order: -1; max-width: 420px; margin: 0 auto; } }

  /* ── COMPARISON ── */
  .ow-cmp { background: var(--ow-bg-alt); }
  .ow-cmp-head { text-align: center; max-width: 560px; margin: 0 auto 40px; }
  .ow-cmp-head p { color: var(--ow-muted); font-size: 15px; margin-top: 12px; line-height: 1.6; }
  .ow-cmp-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; max-width: 800px; margin: 0 auto; }
  .ow-ccard { border-radius: 18px; padding: 26px 24px; background: #fff; border: 1px solid var(--ow-line); }
  .ow-ccard.us { border: 2px solid var(--ow-teal); box-shadow: 0 16px 40px rgba(31,138,150,.12); }
  .ow-ccard-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; padding-bottom: 16px; border-bottom: 1px solid var(--ow-line); }
  .ow-ccard-name { font-size: 16px; font-weight: 600; }
  .ow-ccard-name small { display: block; font-size: 11.5px; color: var(--ow-muted); font-weight: 400; margin-top: 2px; }
  .ow-ccard.us .ow-ccard-name small { color: var(--ow-teal); }
  .ow-ccard-pill { font-size: 11px; padding: 5px 12px; border-radius: 50px; font-weight: 600; background: var(--ow-bg-alt); color: var(--ow-muted); }
  .ow-ccard.us .ow-ccard-pill { background: var(--ow-teal); color: #fff; }
  .ow-crow { display: flex; align-items: flex-start; gap: 10px; padding: 9px 0; font-size: 13.5px; line-height: 1.5; color: var(--ow-muted); }
  .ow-ccard.us .ow-crow { color: var(--ow-ink); }
  .ow-crow .ico { flex-shrink: 0; width: 19px; height: 19px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 11px; margin-top: 1px; background: rgba(198,40,40,.08); color: #c62828; }
  .ow-crow.ok .ico { background: var(--ow-mist); color: var(--ow-teal); }
  @media(max-width:680px){ .ow-cmp-cards { grid-template-columns: 1fr; } .ow-ccard.them { order: 2; } }

  /* ── REVIEWS ── */
  .ow-revs-head { text-align: center; margin-bottom: 36px; }
  .ow-score { display: inline-flex; align-items: center; gap: 10px; background: var(--ow-bg-alt); border: 1px solid var(--ow-line); border-radius: 50px; padding: 9px 20px; margin-top: 14px; }
  .ow-score b { font-size: 18px; font-weight: 600; }
  .ow-score .st { color: #f5a623; font-size: 14px; letter-spacing: 2px; }
  .ow-score span { font-size: 12px; color: var(--ow-muted); }
  .ow-rev-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 16px; max-width: 800px; margin: 0 auto; }
  .ow-rc { background: var(--ow-bg-alt); border: 1px solid var(--ow-line); border-radius: 16px; padding: 22px; }
  .ow-rc .stars { color: #f5a623; font-size: 12.5px; letter-spacing: 1px; margin-bottom: 10px; }
  .ow-rc p { font-size: 13.5px; line-height: 1.65; margin-bottom: 14px; }
  .ow-rc-meta { display: flex; align-items: center; gap: 10px; }
  .ow-rc-av { width: 30px; height: 30px; border-radius: 50%; background: var(--ow-mist); display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 600; color: var(--ow-teal); flex-shrink: 0; }
  .ow-rc-name { font-size: 12.5px; font-weight: 600; }
  .ow-rc-loc { font-size: 11px; color: var(--ow-muted); }
  @media(max-width:640px){ .ow-rev-grid { grid-template-columns: 1fr; } }

  /* ── UGC / COMMUNITY CAROUSEL ── */
  .ow-ugc { background: var(--ow-mist); padding: clamp(40px,6vw,72px) 0; }
  .ow-ugc-head { text-align: center; }
  .ow-ugc-carousel { position: relative; margin-top: 28px; }
  .ow-ugc-track { display: flex; overflow-x: auto; scroll-snap-type: x mandatory; scrollbar-width: none; -ms-overflow-style: none; gap: 12px; }
  .ow-ugc-track::-webkit-scrollbar { display: none; }
  .ow-ugc-slide { flex: 0 0 calc(33.333% - 8px); scroll-snap-align: start; border-radius: 14px; overflow: hidden; aspect-ratio: 1/1; background: #fff; border: 1px solid var(--ow-line); }
  .ow-ugc-slide img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ow-ugc-dots { display: flex; justify-content: center; gap: 6px; margin-top: 16px; }
  .ow-ugc-dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(27,43,58,.18); border: none; cursor: pointer; padding: 0; transition: all .25s; }
  .ow-ugc-dot.active { background: var(--ow-teal); width: 24px; border-radius: 4px; }
  .ow-ugc-nav { position: absolute; top: 50%; transform: translateY(-50%); width: 38px; height: 38px; border-radius: 50%; background: #fff; border: 1.5px solid var(--ow-line); box-shadow: 0 2px 10px rgba(27,43,58,.1); display: flex; align-items: center; justify-content: center; cursor: pointer; z-index: 2; font-size: 18px; color: var(--ow-ink); line-height: 1; }
  .ow-ugc-prev { left: -19px; }
  .ow-ugc-next { right: -19px; }
  @media(max-width:760px) { .ow-ugc-slide { flex: 0 0 calc(50% - 6px); } .ow-ugc-nav { display: none; } }
  @media(max-width:480px) { .ow-ugc-slide { flex: 0 0 78%; } }

  /* ── FAQ ── */
  .ow-faq { background: var(--ow-bg-alt); }
  .ow-faq-wrap { max-width: 680px; margin: 0 auto; }
  .ow-faq-head { text-align: center; margin-bottom: 28px; }
  .ow-faq-item { background: #fff; border: 1px solid var(--ow-line); border-radius: 14px; margin-bottom: 10px; overflow: hidden; }
  .ow-faq-q { width: 100%; padding: 18px 20px; display: flex; justify-content: space-between; align-items: center; font-size: 14.5px; font-weight: 500; text-align: left; gap: 14px; color: var(--ow-ink); background: none; }
  .ow-faq-ic { width: 24px; height: 24px; border-radius: 50%; background: var(--ow-mist); display: flex; align-items: center; justify-content: center; font-size: 16px; color: var(--ow-teal); flex-shrink: 0; transition: transform .2s; }
  .ow-faq-item.open .ow-faq-ic { transform: rotate(45deg); }
  .ow-faq-a { max-height: 0; overflow: hidden; transition: max-height .3s ease; }
  .ow-faq-item.open .ow-faq-a { max-height: 300px; }
  .ow-faq-a p { font-size: 13.5px; color: var(--ow-muted); line-height: 1.7; padding: 0 20px 18px; }

  /* ── FINAL CTA ── */
  .ow-final { text-align: center; padding: clamp(56px,9vw,100px) 0; background: linear-gradient(180deg, var(--ow-bg) 0%, var(--ow-mist) 100%); }
  .ow-final-inner { max-width: 520px; margin: 0 auto; }
  .ow-final h2 { margin-bottom: 12px; }
  .ow-final p { color: var(--ow-muted); font-size: 15px; line-height: 1.65; margin-bottom: 24px; }
  .ow-final-price { font-size: clamp(34px,5.5vw,46px); font-weight: 600; letter-spacing: -.02em; }
  .ow-final-note { font-size: 12.5px; color: var(--ow-muted); margin: 4px 0 24px; }
  .ow-final .ow-cta-row { max-width: 420px; margin: 0 auto; }
  .ow-final-gs { display: flex; gap: 8px; justify-content: center; flex-wrap: wrap; margin-top: 24px; }

  /* reveal */
  .ow-r { opacity: 0; transform: translateY(14px); transition: opacity .5s ease, transform .5s ease; }
  .ow-r.v { opacity: 1; transform: none; }
  @media(prefers-reduced-motion: reduce){ .ow-page * { transition: none !important; } .ow-r { opacity: 1; transform: none; } }

  /* ── OTHER MODELS ── */
  .ow-more { background: var(--ow-mist); }
  .ow-more-head { text-align: center; max-width: 580px; margin: 0 auto 44px; }
  .ow-more-head p { color: var(--ow-muted); font-size: 15.5px; margin-top: 12px; line-height: 1.6; }
  .ow-more h2 em { font-style: normal; color: var(--ow-teal); }
  .ow-more-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 16px; }
  .ow-mcard { background: #fff; border: 1px solid var(--ow-line); border-radius: 16px; overflow: hidden; display: flex; flex-direction: column; transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease; }
  .ow-mcard:hover { transform: translateY(-3px); border-color: var(--ow-teal); box-shadow: 0 16px 40px rgba(31,138,150,.12); }
  .ow-mcard-img { aspect-ratio: 1/1; background: #fff; overflow: hidden; }
  .ow-mcard-img img { width: 100%; height: 100%; object-fit: cover; }
  .ow-mcard-body { padding: 20px 20px 22px; display: flex; flex-direction: column; flex: 1; }
  .ow-mcard-name { font-size: 15px; font-weight: 600; line-height: 1.3; }
  .ow-mcard-why { font-size: 13px; color: var(--ow-muted); line-height: 1.6; margin-top: 8px; flex: 1; }
  .ow-mcard-foot { display: flex; align-items: center; justify-content: space-between; margin-top: 16px; }
  .ow-mcard-price { font-size: 16px; font-weight: 600; }
  .ow-mcard-link { font-size: 12.5px; font-weight: 600; color: var(--ow-teal); }

  .ow-macc-head { display: flex; align-items: center; gap: 14px; margin: 44px 0 20px; }
  .ow-macc-head span { font-size: 11px; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; color: var(--ow-muted); white-space: nowrap; }
  .ow-macc-head::after { content: ""; flex: 1; height: 1px; background: var(--ow-line); }
  .ow-macc-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 12px; }
  .ow-macc { background: #fff; border: 1px solid var(--ow-line); border-radius: 12px; padding: 12px; display: flex; align-items: center; gap: 12px; transition: border-color .2s; }
  .ow-macc:hover { border-color: var(--ow-teal); }
  .ow-macc-img { width: 50px; height: 50px; flex: 0 0 50px; border-radius: 8px; overflow: hidden; background: var(--ow-bg-alt); }
  .ow-macc-img img { width: 100%; height: 100%; object-fit: cover; }
  .ow-macc-name { font-size: 12.5px; font-weight: 600; line-height: 1.3; }
  .ow-macc-price { font-size: 12px; color: var(--ow-muted); margin-top: 2px; }

  @media(max-width:900px){ .ow-more-grid { grid-template-columns: 1fr 1fr; } .ow-macc-grid { grid-template-columns: 1fr 1fr; } }
  @media(max-width:520px){ .ow-more-grid { grid-template-columns: 1fr 1fr; gap: 12px; } .ow-mcard-body { padding: 14px; } .ow-mcard-why { display: none; } .ow-macc-grid { grid-template-columns: 1fr; } }
</style>

{% if product == blank %}
<div style="padding:60px 20px;text-align:center;font-family:sans-serif;">Assign the OpenWire product in the section settings.</div>
{% else %}
<div class="ow-page">

<!-- HERO / PDP -->
<section class="ow-hero">
  <div class="ow-wrap">
    <div class="ow-hero-grid">

      <div class="ow-title">
        <span class="ow-badge">{{ section.settings.hero_badge }}</span>
        <h1>{{ section.settings.hero_title }}</h1>
        <p class="ow-sub">{{ section.settings.hero_sub }}</p>
      </div>

      <div class="ow-gallery">
        <div class="ow-stage">
          <img id="owHeroImg" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape | default: product.title }}"/>
        </div>
        <div class="ow-thumbs">
          <img class="ow-thumb active" src="{{ product.featured_image | image_url: width: 120 }}" onclick="owSwp(this, '{{ product.featured_image | image_url: width: 1200 }}')" alt="{{ product.title }} product photo"/>
          {% for i in (1..6) %}
            {% liquid
              assign key = 'listing_img' | append: i
              assign img = section.settings[key]
            %}
            {% if img != blank %}
              <img class="ow-thumb" src="{{ img | image_url: width: 120 }}" onclick="owSwp(this, '{{ img | image_url: width: 1200 }}')" alt="{{ img.alt | escape | default: product.title }}"/>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      <div class="ow-info">
        <div class="ow-price">
          <b>{{ current_variant.price | money }}</b>
          {% if current_variant.compare_at_price > current_variant.price %}<s>{{ current_variant.compare_at_price | money }}</s>{% endif %}
          <span>{{ section.settings.price_note }}</span>
        </div>

        <div class="ow-trust-cards">
          <div class="ow-tcard"><span class="ic">🔄</span><b>7-Day Returns</b><span>No-questions pickup</span></div>
          <div class="ow-tcard"><span class="ic">🚚</span><b>Free Shipping</b><span>All over India</span></div>
          <div class="ow-tcard"><span class="ic">💵</span><b>COD Available</b><span>Pay on delivery</span></div>
        </div>

        {%- comment -%}
          Real product form: GoKwik's merchant.integration.js reads the variant from a
          form[action="/cart/add"] and binds its popup to the #gokwik-buy-now button.
          Both are required — the theme's 'gokwik' snippet enables #gokwik-buy-now on gokwikLoaded.
        {%- endcomment -%}
        <form action="/cart/add" method="post" enctype="multipart/form-data" id="ow-product-form" class="ow-cta-row" data-ow-form>
          <input type="hidden" name="id" value="{{ current_variant.id }}"/>
          <input type="hidden" name="quantity" value="1"/>
          {% if current_variant.available %}
            {%- comment -%}
              Markup mirrors snippets/gokwik-buy-now.liquid exactly. The trigger is
