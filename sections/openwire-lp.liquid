<script>
  var owVariantId = {{ current_variant.id | default: 0 }};

  /* ── Cart actions ──
     Buy Now is handled natively by GoKwik: merchant.integration.js binds the popup to
     #gokwik-buy-now and reads the variant from #ow-product-form. No JS needed here.
     Add to Cart posts via AJAX, honouring HTTP status (fetch does NOT reject on 4xx/5xx —
     that bug previously redirected an empty cart to /checkout, which bounces to the homepage). */
  function owAddToCart(btn) {
    if (btn) { btn.disabled = true; btn.dataset.owLabel = btn.textContent; btn.textContent = 'Adding…'; }
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: owVariantId, quantity: 1 }] })
    })
    .then(function(r){
      if (!r.ok) { return r.json().then(function(e){ throw new Error(e.description || e.message || 'Unavailable'); }); }
      return r.json();
    })
    .then(function(){ window.location.href = '/cart'; })
    .catch(function(err){
      if (btn) { btn.disabled = false; btn.textContent = btn.dataset.owLabel || '{{ section.settings.btn_atc }}'; }
      alert(err.message || 'Could not add to cart. Please try again.');
    });
    return false; // block the form's native submit
  }

  /* The theme's gokwik snippet re-enables #gokwik-buy-now via jQuery, which it loads over http://
     (blocked as mixed content on https). Enable it here too, dependency-free, so Buy Now is never
     left permanently disabled. */
  (function(){
    function owEnableBuyNow(){
      var b = document.getElementById('gokwik-buy-now');
      if (!b) return;
      b.disabled = false;
      b.classList.remove('disabled');
    }
    window.addEventListener('gokwikLoaded', owEnableBuyNow);
    // In case gokwikLoaded fired before this script ran:
    if (window.gokwikSdk || window.gokwikSDK || typeof window.onBuyNowClick === 'function') owEnableBuyNow();
    setTimeout(owEnableBuyNow, 3000);
  })();

  /* Final-CTA buttons proxy to the single GoKwik-bound button / cart button in the hero form. */
  function owProxyBuy() {
    var b = document.getElementById('gokwik-buy-now');
    if (b) { b.click(); b.scrollIntoView({ behavior: 'smooth', block: 'center' }); }
  }
  function owProxyCart() {
    var b = document.querySelector('#ow-product-form .ow-btn-cart');
    if (b) b.click();
  }

  /* ── Gallery swap ── */
  function owSwp(el, src) {
    var hero = document.getElementById('owHeroImg');
    if (hero) hero.src = src;
    document.querySelectorAll('.ow-thumb').forEach(function(t){ t.classList.remove('active'); });
    if (el) el.classList.add('active');
  }

  /* ── FAQ accordion ── */
  function owFaq(btn) {
    var item = btn.parentElement;
    var open = item.classList.contains('open');
    document.querySelectorAll('.ow-faq-item').forEach(function(i){ i.classList.remove('open'); });
    if (!open) item.classList.add('open');
  }

  /* ── UGC carousel ── */
  (function(){
    var track = document.getElementById('owUgcTrack');
    var dots  = document.getElementById('owUgcDots');
    if (!track || !dots) return;
    var slides = track.querySelectorAll('.ow-ugc-slide');
    slides.forEach(function(_, i){
      var d = document.createElement('button');
      d.className = 'ow-ugc-dot' + (i === 0 ? ' active' : '');
      d.setAttribute('aria-label', 'Slide ' + (i + 1));
      d.onclick = function(){ track.scrollTo({ left: slides[i].offsetLeft, behavior: 'smooth' }); };
      dots.appendChild(d);
    });
    track.addEventListener('scroll', function(){
      var center = track.scrollLeft + track.clientWidth / 2;
      var active = 0;
      slides.forEach(function(s, i){ if (s.offsetLeft + s.offsetWidth / 2 <= center) active = i; });
      dots.querySelectorAll('.ow-ugc-dot').forEach(function(d, i){ d.classList.toggle('active', i === active); });
    }, { passive: true });
  })();
  function owUgcScroll(dir) {
    var track = document.getElementById('owUgcTrack');
    var slide = track && track.querySelector('.ow-ugc-slide');
    if (track && slide) track.scrollBy({ left: dir * (slide.offsetWidth + 12), behavior: 'smooth' });
  }

  /* ── Scroll reveal ── */
  var owObs = new IntersectionObserver(function(entries){
    entries.forEach(function(e){ if (e.isIntersecting) { e.target.classList.add('v'); owObs.unobserve(e.target); } });
  }, { threshold: 0.12 });
  document.querySelectorAll('.ow-r').forEach(function(el){ owObs.observe(el); });

</script>

