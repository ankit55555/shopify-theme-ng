{% comment %}
  Content Card Section
  - Clean card to display help/contact or any rich text
  - Customizable spacing, colors, width, alignment, border radius and shadow
  - Styles are scoped to this section instance
{% endcomment %}

{%- assign section_id = 'content-card-' | append: section.id -%}

<section id="{{ section_id }}" class="content-card-section" style="
  {% if section.settings.background != blank %}background-color: {{ section.settings.background }};{% endif %}
  {% if section.settings.text_color != blank %}color: {{ section.settings.text_color }};{% endif %}
  padding-top: {{ section.settings.padding_top | default: 40 }}px;
  padding-bottom: {{ section.settings.padding_bottom | default: 40 }}px;
">
  <div class="content-card-container">
    {%- if section.settings.heading != blank -%}
      <div class="content-card-header content-card-header--{{ section.settings.align }}">
        <h2 class="content-card-title">{{ section.settings.heading | escape }}</h2>
      </div>
    {%- endif -%}

    <div class="content-card-box content-card-box--{{ section.settings.align }}">
      {%- if section.settings.content != blank -%}
        <div class="content-card-rich rte">
          {{ section.settings.content }}
        </div>
      {%- else -%}
        <div class="content-card-rich">
          <p>Add your content in the theme editor. This block supports headings, paragraphs, and links.</p>
        </div>
      {%- endif -%}

      {%- if section.settings.button_label != blank and section.settings.button_link != blank -%}
        <div class="content-card-action">
          <a href="{{ section.settings.button_link }}" class="content-card-button" {% if section.settings.button_new_tab %}target="_blank" rel="noopener noreferrer"{% endif %}>
            {{ section.settings.button_label | escape }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>

  <style>
    #{{ section_id }} .content-card-container {
      max-width: {{ section.settings.max_width | default: 900 }}px;
      margin: 0 auto;
      padding-left: 16px;
      padding-right: 16px;
    }
    #{{ section_id }} .content-card-header {
      margin-bottom: 16px;
      text-align: {% if section.settings.align == 'center' %}center{% else %}left{% endif %};
    }
    #{{ section_id }} .content-card-title {
      margin: 0;
      font-size: clamp(20px, 2.6vw, 32px);
      line-height: 1.25;
    }
    #{{ section_id }} .content-card-box {
      background: {{ section.settings.card_background | default: 'rgba(0,0,0,0.04)' }};
      border-radius: {{ section.settings.radius | default: 12 }}px;
      padding: {{ section.settings.card_padding | default: 24 }}px;
      box-shadow: {% if section.settings.shadow %}0 8px 24px rgba(0,0,0,0.08){% else %}none{% endif %};
      border: {% if section.settings.card_border != blank %}1px solid {{ section.settings.card_border }}{% else %}none{% endif %};
      text-align: {% if section.settings.align == 'center' %}center{% else %}left{% endif %};
    }
    #{{ section_id }} .content-card-rich {
      font-size: 16px;
      line-height: 1.6;
      opacity: 0.95;
    }
    #{{ section_id }} .content-card-rich p {
      margin: 0 0 10px 0;
    }
    #{{ section_id }} .content-card-action {
      margin-top: 14px;
    }
    #{{ section_id }} .content-card-button {
      display: inline-block;
      padding: 10px 16px;
      border-radius: 8px;
      background: {% if section.settings.button_background != blank %}{{ section.settings.button_background }}{% else %}#111{% endif %};
      color: {% if section.settings.button_color != blank %}{{ section.settings.button_color }}{% else %}#fff{% endif %};
      text-decoration: none;
      font-weight: 600;
    }
  </style>
</section>

{% schema %}
{
  "name": "Content card",
  "tag": "section",
  "class": "section-content-card",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Need help?" },
    { "type": "richtext", "id": "content", "label": "Content", "default": "<p>Still stuck? Our team’s just a ping away.</p><p>Email: support@example.com</p><p>Working hours: 10:30am–6:30pm (Mon–Sat)</p>" },
    { "type": "select", "id": "align", "label": "Alignment", "default": "left", "options": [
      { "value": "left", "label": "Left" },
      { "value": "center", "label": "Center" }
    ] },
    { "type": "number", "id": "max_width", "label": "Content max width (px)", "default": 900 },
    { "type": "color", "id": "background", "label": "Section background" },
    { "type": "color", "id": "text_color", "label": "Section text color" },
    { "type": "range", "id": "padding_top", "label": "Top padding (px)", "min": 0, "max": 160, "step": 4, "default": 40 },
    { "type": "range", "id": "padding_bottom", "label": "Bottom padding (px)", "min": 0, "max": 160, "step": 4, "default": 40 },

    { "type": "color", "id": "card_background", "label": "Card background" },
    { "type": "color", "id": "card_border", "label": "Card border color" },
    { "type": "range", "id": "radius", "label": "Card corner radius (px)", "min": 0, "max": 32, "step": 2, "default": 12 },
    { "type": "range", "id": "card_padding", "label": "Card padding (px)", "min": 8, "max": 64, "step": 4, "default": 24 },
    { "type": "checkbox", "id": "shadow", "label": "Show shadow", "default": true },

    { "type": "text", "id": "button_label", "label": "Button label" },
    { "type": "url", "id": "button_link", "label": "Button link" },
    { "type": "checkbox", "id": "button_new_tab", "label": "Open button in new tab", "default": false },
    { "type": "color", "id": "button_background", "label": "Button background" },
    { "type": "color", "id": "button_color", "label": "Button text color" }
  ],
  "presets": [
    {
      "name": "Content card",
      "category": "Content"
    }
  ]
}
{% endschema %}


